{%- comment -%}
  Inline stroke icons for the LS Product Detail assurance pills.
  Param: name - one of truck | pickup | returns | shield
{%- endcomment -%}
{%- case name -%}
  {%- when 'truck' -%}
    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M2 6h11v10H2zM13 9h4l4 3.5V16h-8z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><circle cx="6" cy="18" r="1.6" stroke="currentColor" stroke-width="1.5"/><circle cx="17.5" cy="18" r="1.6" stroke="currentColor" stroke-width="1.5"/></svg>
  {%- when 'pickup' -%}
    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 10l1.2-4.2A2 2 0 0 1 7.1 4.3h9.8a2 2 0 0 1 1.9 1.5L20 10M4 10h16v8a1 1 0 0 1-1 1h-2v-3H7v3H5a1 1 0 0 1-1-1z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
  {%- when 'returns' -%}
    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 8a8 8 0 1 1-1 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M4 4v4h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
  {%- when 'shield' -%}
    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 3l7 2.5v5c0 4.6-3 8.6-7 10-4-1.4-7-5.4-7-10v-5z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M9 12l2 2 4-4.2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
  {%- else -%}
    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="8" stroke="currentColor" stroke-width="1.5"/></svg>
{%- endcase -%}
