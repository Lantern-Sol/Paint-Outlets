{%- comment -%}
  Renders a 5-star row with fractional (partial) fill.

  Params:
    rating - number 0..5, decimals supported (e.g. 4.5 fills four and a half)
    prefix - BEM block for the class names, e.g. 'ls-hero' or 'ls-review'

  Each star is two stacked copies of the same glyph: a muted background and a
  foreground clipped to that star's fill percentage via --star-fill. The caller
  owns the colors and sizing:
    {prefix}__star      sizing + position: relative
    {prefix}__star-svg  position: absolute; inset: 0
    {prefix}__star-bg   fill: <muted>
    {prefix}__star-fg   fill: <star color>; clip-path uses var(--star-fill)
{%- endcomment -%}
{%- liquid
  assign star_rating = rating | default: 0 | at_most: 5 | at_least: 0
-%}
{%- for star in (1..5) -%}
  {%- assign star_fill = star_rating | minus: star | plus: 1 -%}
  {%- if star_fill > 1 -%}
    {%- assign star_fill = 1 -%}
  {%- elsif star_fill < 0 -%}
    {%- assign star_fill = 0 -%}
  {%- endif -%}
  {%- assign star_fill_pct = star_fill | times: 100 -%}
  <span class="{{ prefix }}__star" style="--star-fill: {{ star_fill_pct }}%">
    <svg class="{{ prefix }}__star-svg {{ prefix }}__star-bg" viewBox="0 0 32 32" role="presentation" aria-hidden="true"><path d="M31.547 12a.848.848 0 00-.677-.577l-9.427-1.376-4.224-8.532a.847.847 0 00-1.516 0l-4.218 8.534-9.427 1.355a.847.847 0 00-.467 1.467l6.823 6.664-1.612 9.375a.847.847 0 001.23.893l8.428-4.434 8.432 4.432a.847.847 0 001.229-.894l-1.615-9.373 6.822-6.665a.845.845 0 00.214-.869z"></path></svg>
    <svg class="{{ prefix }}__star-svg {{ prefix }}__star-fg" viewBox="0 0 32 32" role="presentation" aria-hidden="true"><path d="M31.547 12a.848.848 0 00-.677-.577l-9.427-1.376-4.224-8.532a.847.847 0 00-1.516 0l-4.218 8.534-9.427 1.355a.847.847 0 00-.467 1.467l6.823 6.664-1.612 9.375a.847.847 0 001.23.893l8.428-4.434 8.432 4.432a.847.847 0 001.229-.894l-1.615-9.373 6.822-6.665a.845.845 0 00.214-.869z"></path></svg>
  </span>
{%- endfor -%}
