{%- comment -%}
  LS Collection
  -------------
  Self-contained collection (category) page matching the Figma layout:
  breadcrumb · title + count + assurance pills · sidebar facets (native Shopify
  filtering) · quick-filter pills + sort · 4-up product-card grid · load more.

  Reads the live `collection` object. Filtering uses Shopify's storefront
  filters (`collection.filters`, configured in Search & Discovery): the sidebar
  is a GET <form> that reloads the collection with the chosen facets — so it is
  fully functional, not a visual shell. Sort uses `collection.sort_options`.
  Load more paginates server-side and appends the next page via the Section
  Rendering API. Product cards reuse the shared `ls-product-card` snippet.
{%- endcomment -%}

{%- liquid
  assign co_font = section.settings.font_family
  assign co_font_500 = co_font | font_modify: 'weight', '500'
  assign co_font_600 = co_font | font_modify: 'weight', '600'
  assign co_font_700 = co_font | font_modify: 'weight', '700'

  assign ppp = section.settings.products_per_page | default: 12
  assign noun = section.settings.item_noun | default: 'paints'
  assign total_all = collection.all_products_count
  assign total_filtered = collection.products_count

  # Paint collections carry the "use_paint" product tag; the "tinted to any
  # color" suffix only applies to those. Blank tag setting = always show.
  assign paint_tag = section.settings.paint_use_tag | default: 'use_paint'
  assign is_paint_collection = false
  if paint_tag == blank or collection.all_tags contains paint_tag
    assign is_paint_collection = true
  endif

  assign current_sort = collection.sort_by | default: collection.default_sort_by

  # Count active facet values so "Clear all" only shows when something is applied.
  assign active_facets = 0
  for filter in collection.filters
    assign active_facets = active_facets | plus: filter.active_values.size
    if filter.type == 'price_range'
      if filter.min_value.value != blank or filter.max_value.value != blank
        assign active_facets = active_facets | plus: 1
      endif
    endif
  endfor

  # --- Finish / sheen facet, derived from product titles ---
  # Fallback for stores that can't add a finish tag/metafield: the finish is
  # parsed out of the title (e.g. "... - Semi-Gloss Finish N793"). This is a
  # client-side, demo-grade facet — it filters the products loaded on the page,
  # not the whole collection server-side. Replace with a real metafield/tag
  # filter once product settings can be edited.
  assign finish_opts_raw = section.settings.finish_options | default: 'Flat, Matte, Eggshell, Satin, Semi-Gloss, High Gloss, Low Sheen'
  assign finish_opts = finish_opts_raw | replace: ', ', ',' | split: ','
  assign finish_present = '|'
  if section.settings.show_finish_filter
    for product in collection.products
      assign t_dc = product.title | downcase
      for f in finish_opts
        assign f_dc = f | downcase | strip
        if f_dc != '' and t_dc contains f_dc
          assign f_key = f | handleize
          assign needle = '|' | append: f_key | append: '|'
          unless finish_present contains needle
            assign finish_present = finish_present | append: f_key | append: '|'
          endunless
        endif
      endfor
    endfor
  endif

  # --- Grid columns (forced) + Sample CTA banner (interleaved) ---
  assign grid_cols = section.settings.columns | default: 4
  assign cta_enable = section.settings.cta_enable
  assign cta_after = section.settings.cta_after_products | default: 8
  # Effective insertion point. Normally after `cta_after` products (2 rows). If
  # the collection can't fill that, drop the banner below the FIRST row instead;
  # if there isn't even one full row, place it after the last product.
  assign cta_at = cta_after
  if collection.products.size < cta_after
    assign cta_at = grid_cols
    if collection.products.size < grid_cols
      assign cta_at = collection.products.size
    endif
  endif
-%}

{% style %}
  {{ co_font | font_face: font_display: 'swap' }}
  {{ co_font_500 | font_face: font_display: 'swap' }}
  {{ co_font_600 | font_face: font_display: 'swap' }}
  {{ co_font_700 | font_face: font_display: 'swap' }}

  .ls-col-{{ section.id }} {
    --ls-col-font-family: {{ co_font.family }}, {{ co_font.fallback_families }};
    --ls-col-heading: {{ section.settings.heading_color | default: '#17181b' }};
    --ls-col-text: {{ section.settings.text_color | default: '#17181b' }};
    --ls-col-muted: {{ section.settings.muted_color | default: '#6c7178' }};
    --ls-col-accent: {{ section.settings.accent_color | default: '#c13121' }};
    --ls-col-success: {{ section.settings.success_color | default: '#1e854a' }};
    --ls-col-surface: {{ section.settings.surface_color | default: '#ffffff' }};
    --ls-col-border: {{ section.settings.border_color | default: '#e6e2db' }};
    --ls-col-chip: {{ section.settings.chip_background | default: '#fcf2f0' }};
    --ls-col-radius: {{ section.settings.corner_radius | default: 16 }}px;
    --ls-col-cols: {{ section.settings.columns | default: 4 }};
    /* Sample CTA banner */
    --ls-col-cta-start: {{ section.settings.cta_bg_start | default: '#1e232c' }};
    --ls-col-cta-mid: {{ section.settings.cta_bg_mid | default: '#13161c' }};
    --ls-col-cta-end: {{ section.settings.cta_bg_end | default: '#0b0d11' }};
    --ls-col-cta-w: {{ section.settings.cta_img_width | default: 160 }};
    --ls-col-cta-x: {{ section.settings.cta_img_x | default: 40 }};
    --ls-col-cta-y: {{ section.settings.cta_img_y | default: 0 }};
    --ls-col-cta-r: {{ section.settings.cta_img_rotate | default: 0 }};
    --ls-col-cta-w-m: {{ section.settings.cta_img_width_mobile | default: 140 }};
    --ls-col-cta-x-m: {{ section.settings.cta_img_x_mobile | default: 30 }};
    --ls-col-cta-y-m: {{ section.settings.cta_img_y_mobile | default: 70 }};
    --ls-col-cta-r-m: {{ section.settings.cta_img_rotate_mobile | default: 0 }};
  }
{% endstyle %}

<div
  class="section section--page-width ls-col ls-col-{{ section.id }} spacing-style"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  {%- comment -%} ---------------- Breadcrumbs ---------------- {%- endcomment -%}
  {%- if section.settings.show_breadcrumbs -%}
    <nav class="ls-col__crumbs" aria-label="Breadcrumb">
      <a href="{{ routes.root_url }}">Home</a>
      <svg viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M4.5 2.5l3 3.5-3 3.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
      <span aria-current="page">{{ collection.title }}</span>
    </nav>
  {%- endif -%}

  {%- comment -%} ---------------- Header ---------------- {%- endcomment -%}
  <div class="ls-col__header">
    <div class="ls-col__titles">
      <h1 class="ls-col__title">{{ collection.title }}</h1>
      {%- if total_all > 0 -%}
        <p class="ls-col__subtitle">
          <span class="ls-col__count">{{ total_all }}</span> {{ noun }}{% if section.settings.subtitle_suffix != blank and is_paint_collection %}, {{ section.settings.subtitle_suffix }}{% endif %}
        </p>
      {%- endif -%}
    </div>

    {%- if section.settings.assurance_1 != blank or section.settings.assurance_2 != blank -%}
      <div class="ls-col__assurances">
        {%- if section.settings.assurance_1 != blank -%}
          <span class="ls-col__assurance">
            <span class="ls-col__assurance-dot" aria-hidden="true"></span>
            {{ section.settings.assurance_1 }}
          </span>
        {%- endif -%}
        {%- if section.settings.assurance_2 != blank -%}
          <span class="ls-col__assurance">
            <svg class="ls-col__assurance-icon" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M1.5 5.5h9v7h-9zM10.5 8h3l2.5 2.5v2h-5.5z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/><circle cx="5" cy="14" r="1.6" stroke="currentColor" stroke-width="1.3"/><circle cx="13.5" cy="14" r="1.6" stroke="currentColor" stroke-width="1.3"/></svg>
            {{ section.settings.assurance_2 }}
          </span>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>

  {%- comment -%} ---------------- Body: filters + results ---------------- {%- endcomment -%}
  {%- comment -%}
    Single GET <form> wraps the whole body, so the sidebar facets AND the sort
    <select> (in the toolbar) submit together — a facet change preserves sort and
    vice versa, with no duplicate params.
  {%- endcomment -%}
  <form class="ls-col__body" data-filter-form method="get" action="{{ collection.url }}">
    {%- comment -%} =============== Sidebar facets =============== {%- endcomment -%}
    <aside class="ls-col__sidebar" data-sidebar role="dialog" aria-modal="true" aria-label="{{ section.settings.mobile_filter_label | default: 'Filter & sort' }}">
      {%- comment -%} Mobile bottom-sheet header (hidden on desktop). {%- endcomment -%}
      <div class="ls-col__sheet-head">
        <span class="ls-col__sheet-handle" aria-hidden="true"></span>
        <div class="ls-col__sheet-titlebar">
          <span class="ls-col__sheet-title">
            {{ section.settings.mobile_filter_label | default: 'Filter & sort' }}
            {%- if active_facets > 0 -%}
              <span class="ls-col__badge" data-facet-badge>{{ active_facets }}</span>
            {%- endif -%}
          </span>
          <button type="button" class="ls-col__sheet-close" data-sheet-close aria-label="Close filters">
            <svg viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M5 5l10 10M15 5L5 15" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
          </button>
        </div>
      </div>

      <div class="ls-col__sheet-scroll">
      {%- comment -%} Quick-filter pills — shown inside the sheet on mobile (the toolbar row is hidden there). {%- endcomment -%}
      {%- if section.blocks.size > 0 -%}
        <div class="ls-col__sheet-pills" role="list">
          {%- for block in section.blocks -%}
            {%- if block.type == 'quick_filter' and block.settings.label != blank -%}
              {%- render 'ls-col-quick-pill', block: block, collection: collection -%}
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}
      <div class="ls-col__sidebar-head">
        <span class="ls-col__sidebar-title">
          <svg viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M3 5h14M6 10h8M9 15h2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          {{ section.settings.filters_label | default: 'Filters' }}
        </span>
        {%- if total_filtered > 0 -%}
          <span class="ls-col__sidebar-count">{{ total_filtered }} items</span>
        {%- endif -%}
      </div>

      {%- comment -%}
        Sort — mobile only (the sheet is titled "Filter & sort"). Radios have no
        name so they never submit; JS mirrors the choice into the toolbar's real
        sort <select> on "Show results". On desktop this section is hidden and
        sort lives in the toolbar instead.
      {%- endcomment -%}
      {%- if collection.sort_options.size > 0 -%}
        <details class="ls-col__facet ls-col__facet--sort" data-sort-facet open>
          <summary class="ls-col__facet-summary">
            {{ section.settings.sort_facet_label | default: 'Sort by' }}
            <span class="ls-col__facet-chevron" aria-hidden="true"></span>
          </summary>
          <div class="ls-col__facet-body ls-col__options">
            {%- for option in collection.sort_options -%}
              <label class="ls-col__option ls-col__option--radio">
                <input type="radio" data-sort-value="{{ option.value }}"{% if option.value == current_sort %} checked{% endif %}>
                <span class="ls-col__option-box" aria-hidden="true"></span>
                <span class="ls-col__option-label">{{ option.name }}</span>
              </label>
            {%- endfor -%}
          </div>
        </details>
      {%- endif -%}

      {%- comment -%}
        Finish / sheen — custom facet parsed from titles (no name attr, so it
        never submits with the GET form; filtering is done client-side in JS).
      {%- endcomment -%}
      {%- if section.settings.show_finish_filter and finish_present != '|' -%}
        <details class="ls-col__facet ls-col__facet--finish" data-finish-facet open>
          <summary class="ls-col__facet-summary">
            {{ section.settings.finish_label | default: 'Finish / sheen' }}
            <span class="ls-col__facet-chevron" aria-hidden="true"></span>
          </summary>
          <div class="ls-col__facet-body ls-col__options">
            {%- for f in finish_opts -%}
              {%- assign f_dc = f | strip -%}
              {%- assign f_key = f_dc | handleize -%}
              {%- assign needle = '|' | append: f_key | append: '|' -%}
              {%- if f_dc != '' and finish_present contains needle -%}
                <label class="ls-col__option">
                  <input type="checkbox" data-finish-value="{{ f_key }}">
                  <span class="ls-col__option-box" aria-hidden="true"></span>
                  <span class="ls-col__option-label">{{ f_dc }}</span>
                </label>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </details>
      {%- endif -%}

      {%- if collection.filters.size > 0 -%}
        {%- for filter in collection.filters -%}
          {%- case filter.type -%}
            {%- when 'price_range' -%}
              {%- comment -%}
                Preset price buckets as checkboxes (Figma). Shopify's price filter
                is a single server-side range, so the checkboxes don't submit
                directly — two hidden inputs carry the real gte/lte params and JS
                sets them to span the checked buckets. A bucket is pre-checked when
                it sits inside the currently-applied range.
              {%- endcomment -%}
              {%- assign cur_min = filter.min_value.value -%}
              {%- assign cur_max = filter.max_value.value -%}
              {%- assign buckets = section.settings.price_buckets | default: '0-40, 40-60, 60-80, 80-' | replace: ', ', ',' | split: ',' -%}
              <details class="ls-col__facet" open>
                <summary class="ls-col__facet-summary">
                  {{ filter.label }}
                  <span class="ls-col__facet-chevron" aria-hidden="true"></span>
                </summary>
                <div class="ls-col__facet-body ls-col__options" data-price-buckets>
                  <input type="hidden" name="{{ filter.min_value.param_name }}" value="{{ cur_min }}" data-price-gte>
                  <input type="hidden" name="{{ filter.max_value.param_name }}" value="{{ cur_max }}" data-price-lte>
                  {%- for b in buckets -%}
                    {%- assign parts = b | split: '-' -%}
                    {%- assign bmin = parts[0] | strip -%}
                    {%- assign bmax = parts[1] | strip -%}
                    {%- comment -%} Human label from the numbers. {%- endcomment -%}
                    {%- if bmin == '' or bmin == '0' -%}
                      {%- capture blabel -%}Under {{ cart.currency.symbol }}{{ bmax }}{%- endcapture -%}
                    {%- elsif bmax == '' -%}
                      {%- capture blabel -%}{{ cart.currency.symbol }}{{ bmin }}+{%- endcapture -%}
                    {%- else -%}
                      {%- capture blabel -%}{{ cart.currency.symbol }}{{ bmin }} – {{ cart.currency.symbol }}{{ bmax }}{%- endcapture -%}
                    {%- endif -%}
                    {%- comment -%} Pre-check if this bucket falls within the active range. {%- endcomment -%}
                    {%- assign bmin_n = bmin | plus: 0 -%}
                    {%- assign bmax_n = bmax | plus: 0 -%}
                    {%- assign is_on = true -%}
                    {%- if cur_min == blank and cur_max == blank -%}{%- assign is_on = false -%}{%- endif -%}
                    {%- if cur_min != blank and bmin != '' and bmin_n < cur_min -%}{%- assign is_on = false -%}{%- endif -%}
                    {%- if cur_max != blank -%}
                      {%- if bmax == '' -%}{%- assign is_on = false -%}
                      {%- elsif bmax_n > cur_max -%}{%- assign is_on = false -%}{%- endif -%}
                    {%- endif -%}
                    <label class="ls-col__option">
                      <input type="checkbox" data-price-min="{{ bmin | default: '0' }}" data-price-max="{{ bmax }}"{% if is_on %} checked{% endif %}>
                      <span class="ls-col__option-box" aria-hidden="true"></span>
                      <span class="ls-col__option-label">{{ blabel }}</span>
                    </label>
                  {%- endfor -%}
                </div>
              </details>

            {%- else -%}
              {%- assign is_swatch = false -%}
              {%- if filter.presentation == 'swatch' -%}{%- assign is_swatch = true -%}{%- endif -%}
              <details class="ls-col__facet"{% if is_swatch or filter.active_values.size > 0 %} open{% endif %}>
                <summary class="ls-col__facet-summary">
                  {{ filter.label }}
                  <span class="ls-col__facet-chevron" aria-hidden="true"></span>
                </summary>
                {%- if is_swatch -%}
                  <div class="ls-col__facet-body ls-col__swatches">
                    {%- for value in filter.values -%}
                      <label class="ls-col__swatch{% if value.active %} is-active{% endif %}{% if value.count == 0 and value.active == false %} is-disabled{% endif %}" title="{{ value.label | escape }} ({{ value.count }})">
                        <input type="checkbox" name="{{ value.param_name }}" value="{{ value.value }}"{% if value.active %} checked{% endif %}{% if value.count == 0 and value.active == false %} disabled{% endif %}>
                        <span class="ls-col__swatch-dot"{% if value.swatch.image %} style="background-image:url({{ value.swatch.image | image_url: width: 60 }})"{% elsif value.swatch.color %} style="background:{{ value.swatch.color }}"{% endif %} aria-hidden="true"></span>
                        <span class="visually-hidden">{{ value.label }}</span>
                      </label>
                    {%- endfor -%}
                  </div>
                {%- else -%}
                  <div class="ls-col__facet-body ls-col__options">
                    {%- for value in filter.values -%}
                      <label class="ls-col__option{% if value.count == 0 and value.active == false %} is-disabled{% endif %}">
                        <input type="checkbox" name="{{ value.param_name }}" value="{{ value.value }}"{% if value.active %} checked{% endif %}{% if value.count == 0 and value.active == false %} disabled{% endif %}>
                        <span class="ls-col__option-box" aria-hidden="true"></span>
                        <span class="ls-col__option-label">{{ value.label }}</span>
                        <span class="ls-col__option-count">{{ value.count }}</span>
                      </label>
                    {%- endfor -%}
                  </div>
                {%- endif -%}
              </details>
          {%- endcase -%}
        {%- endfor -%}

        <div class="ls-col__sidebar-foot">
          <button type="submit" class="ls-col__apply" data-apply>Apply filters</button>
          {%- if active_facets > 0 -%}
            <a class="ls-col__clear" href="{{ collection.url }}?sort_by={{ current_sort }}">Clear all</a>
          {%- endif -%}
        </div>
      {%- else -%}
        <p class="ls-col__no-facets">No filters are configured for this collection. Enable storefront filters in Search &amp; Discovery.</p>
      {%- endif -%}
      </div>{%- comment -%} /sheet-scroll {%- endcomment -%}

      {%- comment -%} Mobile bottom-sheet footer (hidden on desktop). {%- endcomment -%}
      <div class="ls-col__sheet-foot">
        <a class="ls-col__sheet-clear" href="{{ collection.url }}">{{ section.settings.clear_label | default: 'Clear' }}</a>
        <button type="submit" class="ls-col__sheet-apply" data-sheet-apply>
          {%- if total_filtered > 0 -%}
            {{ section.settings.show_results_label | default: 'Show' }} {{ total_filtered }} {{ noun }}
          {%- else -%}
            {{ section.settings.show_results_label | default: 'Show' }} results
          {%- endif -%}
        </button>
      </div>
    </aside>

    {%- comment -%} =============== Results =============== {%- endcomment -%}
    <div class="ls-col__main">
      <div class="ls-col__toolbar">
        <button type="button" class="ls-col__filters-toggle" data-filters-toggle aria-expanded="false" aria-haspopup="dialog">
          <svg viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M3 5h14M6 10h8M9 15h2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          {{ section.settings.mobile_filter_label | default: 'Filter & sort' }}
          {%- if active_facets > 0 -%}
            <span class="ls-col__badge" data-facet-badge>{{ active_facets }}</span>
          {%- endif -%}
        </button>

        {%- if section.blocks.size > 0 -%}
          <div class="ls-col__pills" role="list">
            {%- for block in section.blocks -%}
              {%- if block.type == 'quick_filter' and block.settings.label != blank -%}
                {%- render 'ls-col-quick-pill', block: block, collection: collection -%}
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- if collection.sort_options.size > 0 -%}
          <label class="ls-col__sort">
            <span class="ls-col__sort-label">{{ section.settings.sort_label | default: 'Sort:' }}</span>
            <select name="sort_by" data-sort>
              {%- for option in collection.sort_options -%}
                <option value="{{ option.value }}"{% if option.value == current_sort %} selected{% endif %}>{{ option.name }}</option>
              {%- endfor -%}
            </select>
            <svg class="ls-col__sort-caret" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M4 5.5l3 3 3-3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </label>
        {%- endif -%}

        {%- comment -%} Mobile-only result count, sits opposite the "Filter & sort" button. {%- endcomment -%}
        {%- if total_filtered > 0 -%}
          <span class="ls-col__toolbar-count">{{ total_filtered }} {{ noun }}</span>
        {%- endif -%}
      </div>

      {%- paginate collection.products by ppp -%}
        {%- assign shown = paginate.current_offset | plus: collection.products.size -%}
        <p class="ls-col__showing">
          {{ section.settings.showing_label | default: 'Showing' }}
          <span data-shown>{{ shown }}</span> of <span data-total>{{ total_filtered }}</span> {{ noun }}
        </p>

        {%- comment -%}
          Build the CTA banner once so it can be dropped into the grid after the
          configured row (page 1 only). It spans the full grid width.
        {%- endcomment -%}
        {%- capture cta_banner -%}
          <div class="ls-col__cta">
            <div class="ls-col__cta-inner">
              {%- if section.settings.cta_image != blank -%}
                <div class="ls-col__cta-media" aria-hidden="true">
                  {{
                    section.settings.cta_image
                    | image_url: width: 1400
                    | image_tag: class: 'ls-col__cta-img', widths: '600, 900, 1200, 1400', loading: 'lazy', alt: ''
                  }}
                </div>
              {%- endif -%}
              <div class="ls-col__cta-content">
                <div class="ls-col__cta-text">
                  {%- if section.settings.cta_heading != blank -%}
                    <h2 class="ls-col__cta-heading">{{ section.settings.cta_heading }}</h2>
                  {%- endif -%}
                  {%- if section.settings.cta_text != blank -%}
                    <p class="ls-col__cta-sub">{{ section.settings.cta_text }}</p>
                  {%- endif -%}
                </div>
                {%- if section.settings.cta_button_label != blank or section.settings.cta_button2_label != blank -%}
                  <div class="ls-col__cta-actions">
                    {%- if section.settings.cta_button_label != blank -%}
                      <a class="ls-col__cta-btn" href="{{ section.settings.cta_button_link | default: '#' }}">
                        {{ section.settings.cta_button_label }}
                        <svg viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M4 10h11M11 6l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      </a>
                    {%- endif -%}
                    {%- if section.settings.cta_button2_label != blank -%}
                      <a class="ls-col__cta-btn ls-col__cta-btn--secondary" href="{{ section.settings.cta_button2_link | default: '#' }}">
                        {{ section.settings.cta_button2_label }}
                        <svg viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M4 10h11M11 6l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      </a>
                    {%- endif -%}
                  </div>
                {%- endif -%}
              </div>
            </div>
          </div>
        {%- endcapture -%}

        {%- if collection.products.size > 0 -%}
          <div class="ls-col__grid" data-grid>
            {%- for product in collection.products -%}
              {%- comment -%} Derive the finish(es) from the title for the client-side finish facet. {%- endcomment -%}
              {%- assign p_finishes = '' -%}
              {%- if section.settings.show_finish_filter -%}
                {%- assign pt_dc = product.title | downcase -%}
                {%- for f in finish_opts -%}
                  {%- assign f_dc = f | downcase | strip -%}
                  {%- if f_dc != '' and pt_dc contains f_dc -%}
                    {%- assign f_key = f | handleize -%}
                    {%- assign p_finishes = p_finishes | append: ' ' | append: f_key -%}
                  {%- endif -%}
                {%- endfor -%}
              {%- endif -%}
              {%- capture card_attrs -%}data-finish="{{ p_finishes | strip }}"{%- endcapture -%}
              {%- render 'ls-product-card',
                card_product: product,
                card_attributes: card_attrs,
                fallback_rating: section.settings.fallback_rating,
                fallback_review_count: section.settings.fallback_review_count
              -%}
              {%- comment -%} Drop the CTA banner in at the computed row (first page only). {%- endcomment -%}
              {%- if cta_enable and paginate.current_offset == 0 and forloop.index == cta_at -%}
                {{ cta_banner }}
              {%- endif -%}
            {%- endfor -%}
          </div>

          {%- if paginate.next -%}
            <div class="ls-col__loadmore-wrap">
              <a class="ls-col__loadmore" href="{{ paginate.next.url }}" data-loadmore>
                {{ section.settings.load_more_label | default: 'Load more products' }}
              </a>
            </div>
          {%- endif -%}
        {%- else -%}
          <p class="ls-col__empty">{{ section.settings.empty_text | default: 'No products match these filters.' }}</p>
        {%- endif -%}
      {%- endpaginate -%}
    </div>
  </form>

  {%- comment -%} Backdrop for the mobile filter sheet. {%- endcomment -%}
  <div class="ls-col__scrim" data-scrim hidden></div>
</div>

<script>
  (function () {
    function init() {
      var root = document.querySelector('.ls-col-{{ section.id }}');
      if (!root) return;
      root.classList.add('ls-col--js');
      var SECTION_ID = {{ section.id | json }};

      var form = root.querySelector('[data-filter-form]');
      var sidebar = root.querySelector('[data-sidebar]');
      var scrim = root.querySelector('[data-scrim]');
      var toggle = root.querySelector('[data-filters-toggle]');
      var sortSelect = form ? form.querySelector('[data-sort]') : null;

      // At the sheet breakpoint, facets batch-apply via the "Show results" button
      // instead of reloading on every tap.
      function sheetMode() { return window.matchMedia('(max-width: 990px)').matches; }

      // Tracks whether a SERVER-SIDE facet (native checkbox / price / sort) was
      // touched while the sheet is open. "Show results" reloads only when this is
      // true; if only the client-side finish facet changed, it just closes over
      // the already-filtered grid (a reload would wipe that client-side state).
      var nativeDirty = false;

      /* ---------- Facet + sort behavior ---------- */
      if (form) {
        // Native (server-side) checkbox facets: submit instantly on desktop; on
        // mobile defer and mark dirty. Excluded: the client-side finish facet
        // (data-finish-value) and the price buckets (data-price-min), which are
        // handled by dedicated logic below.
        Array.prototype.slice.call(form.querySelectorAll('input[type="checkbox"]:not([data-finish-value]):not([data-price-min])')).forEach(function (cb) {
          cb.addEventListener('change', function () { if (sheetMode()) { nativeDirty = true; } else { form.submit(); } });
        });

        // Price buckets → hidden gte/lte params. Checking several buckets spans
        // them (min of the floors, max of the ceilings); an open-ended bucket
        // (no max) leaves lte empty. Then submit (desktop) / mark dirty (mobile).
        var priceWrap = form.querySelector('[data-price-buckets]');
        if (priceWrap) {
          var gteInput = priceWrap.querySelector('[data-price-gte]');
          var lteInput = priceWrap.querySelector('[data-price-lte]');
          var priceBoxes = Array.prototype.slice.call(priceWrap.querySelectorAll('[data-price-min]'));
          var syncPrice = function () {
            var mins = [], maxs = [], open = false, any = false;
            priceBoxes.forEach(function (cb) {
              if (!cb.checked) return;
              any = true;
              var mn = parseFloat(cb.getAttribute('data-price-min'));
              var mx = cb.getAttribute('data-price-max');
              if (!isNaN(mn)) mins.push(mn);
              if (mx === '' || mx == null) { open = true; } else { maxs.push(parseFloat(mx)); }
            });
            gteInput.value = any && mins.length ? Math.min.apply(null, mins) : '';
            lteInput.value = any && !open && maxs.length ? Math.max.apply(null, maxs) : '';
          };
          priceBoxes.forEach(function (cb) {
            cb.addEventListener('change', function () {
              syncPrice();
              if (sheetMode()) { nativeDirty = true; } else { form.submit(); }
            });
          });
        }
        // Desktop sort <select> (hidden on mobile).
        if (sortSelect) {
          sortSelect.addEventListener('change', function () { if (!sheetMode()) form.submit(); });
        }
        // Mobile sort radios have no shared name, so enforce single-select in JS
        // and mark dirty (sort is server-side — it needs the reload).
        var sortRadios = Array.prototype.slice.call(root.querySelectorAll('[data-sort-value]'));
        sortRadios.forEach(function (r) {
          r.addEventListener('change', function () {
            sortRadios.forEach(function (o) { if (o !== r) o.checked = false; });
            nativeDirty = true;
          });
        });
        // On any real submit, mirror the chosen mobile sort into the real <select>.
        form.addEventListener('submit', function () {
          if (!sortSelect) return;
          var picked = root.querySelector('[data-sort-value]:checked');
          if (picked) sortSelect.value = picked.getAttribute('data-sort-value');
        });
      }

      /* ---------- Mobile filter sheet ---------- */
      function openSheet() {
        if (!sidebar) return;
        if (scrim) { scrim.hidden = false; void scrim.offsetWidth; scrim.classList.add('is-visible'); }
        sidebar.classList.add('is-open');
        document.body.classList.add('ls-col--sheet-open');
        if (toggle) toggle.setAttribute('aria-expanded', 'true');
      }
      function closeSheet() {
        if (!sidebar) return;
        sidebar.classList.remove('is-open');
        document.body.classList.remove('ls-col--sheet-open');
        if (toggle) toggle.setAttribute('aria-expanded', 'false');
        if (scrim) {
          scrim.classList.remove('is-visible');
          var hide = function () { scrim.hidden = true; scrim.removeEventListener('transitionend', hide); };
          scrim.addEventListener('transitionend', hide);
        }
      }
      if (toggle && sidebar) {
        toggle.addEventListener('click', function () {
          if (sidebar.classList.contains('is-open')) closeSheet(); else openSheet();
        });
      }
      if (scrim) scrim.addEventListener('click', closeSheet);
      var sheetClose = root.querySelector('[data-sheet-close]');
      if (sheetClose) sheetClose.addEventListener('click', closeSheet);
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && sidebar && sidebar.classList.contains('is-open')) closeSheet();
      });

      // "Show N results": if a server-side facet/sort changed, let the native
      // submit reload with the new params. Otherwise only the client-side finish
      // filter changed (already applied live) — reveal the filtered grid instead
      // of reloading, which would wipe it.
      var applyBtn = root.querySelector('[data-sheet-apply]');
      if (applyBtn) {
        applyBtn.addEventListener('click', function (e) {
          if (nativeDirty) return;
          e.preventDefault();
          applyFinishFilter();
          closeSheet();
        });
      }

      /* ---------- Finish facet (client-side, title-derived) ---------- */
      var grid = root.querySelector('[data-grid]');
      var shownEl = root.querySelector('[data-shown]');
      var loadedCount = shownEl ? (parseInt(shownEl.textContent, 10) || 0) : 0;
      var finishInputs = Array.prototype.slice.call(root.querySelectorAll('[data-finish-value]'));
      var ctaEl = grid ? grid.querySelector('.ls-col__cta') : null;

      function applyFinishFilter() {
        var active = finishInputs.filter(function (i) { return i.checked; })
          .map(function (i) { return i.getAttribute('data-finish-value'); });
        var visible = 0;
        if (grid) {
          Array.prototype.slice.call(grid.querySelectorAll('.ls-pcard')).forEach(function (card) {
            var finishes = (card.getAttribute('data-finish') || '').split(' ');
            var show = active.length === 0 || active.some(function (a) { return finishes.indexOf(a) !== -1; });
            card.style.display = show ? '' : 'none';
            if (show) visible++;
          });
        }
        // The CTA banner sits at a fixed spot in the grid (after row 2). Once the
        // client-side filter hides cards, that spot is meaningless and its
        // full-row span breaks the reflow into partial rows — so hide it while a
        // finish filter is active and restore it when cleared.
        if (ctaEl) ctaEl.style.display = active.length ? 'none' : '';
        // While filtering, the count reflects what's visible; otherwise the
        // running loaded total.
        if (shownEl) shownEl.textContent = active.length ? visible : loadedCount;
      }
      finishInputs.forEach(function (i) { i.addEventListener('change', applyFinishFilter); });

      /* ---------- Load more (Section Rendering API) ---------- */
      function bindLoadMore() {
        var btn = root.querySelector('[data-loadmore]');
        if (!btn) return;
        btn.addEventListener('click', function (e) {
          e.preventDefault();
          if (btn.classList.contains('is-loading')) return;
          btn.classList.add('is-loading');
          var url = btn.getAttribute('href');
          var sep = url.indexOf('?') > -1 ? '&' : '?';
          fetch(url + sep + 'section_id=' + encodeURIComponent(SECTION_ID))
            .then(function (r) { return r.text(); })
            .then(function (html) {
              var doc = new DOMParser().parseFromString(html, 'text/html');
              var newGrid = doc.querySelector('[data-grid]');
              var newBtn = doc.querySelector('[data-loadmore]');
              if (newGrid && grid) {
                var added = 0;
                Array.prototype.slice.call(newGrid.children).forEach(function (card) {
                  grid.appendChild(card);
                  added++;
                });
                loadedCount += added;
              }
              var wrap = btn.closest('.ls-col__loadmore-wrap');
              if (newBtn) {
                btn.setAttribute('href', newBtn.getAttribute('href'));
                btn.classList.remove('is-loading');
              } else if (wrap) {
                wrap.parentNode.removeChild(wrap); // no more pages
              }
              // Re-apply the finish filter so appended cards respect it and the
              // count stays correct.
              applyFinishFilter();
            })
            .catch(function () {
              btn.classList.remove('is-loading');
              window.location = btn.getAttribute('href'); // fall back to a full navigation
            });
        });
      }
      bindLoadMore();
    }

    init();
    document.addEventListener('shopify:section:load', function (e) {
      if (!e.detail || e.detail.sectionId === '{{ section.id }}') init();
    });
  })();
</script>

{% stylesheet %}
  .ls-col {
    font-family: var(--ls-col-font-family, 'Outfit', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif);
    color: var(--ls-col-text);
    overflow-x: clip;
  }

  /* ---------- Breadcrumbs ---------- */
  .ls-col__crumbs {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8125rem;
    color: var(--ls-col-muted);
    margin-bottom: 1.1rem;
  }
  .ls-col__crumbs a { color: inherit; text-decoration: none; }
  .ls-col__crumbs a:hover { color: var(--ls-col-accent); }
  .ls-col__crumbs svg { width: 12px; height: 12px; flex-shrink: 0; }
  .ls-col__crumbs span[aria-current] { color: var(--ls-col-heading); }

  /* ---------- Header ---------- */
  .ls-col__header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1.75rem;
  }
  .ls-col__title {
    margin: 0;
    font-size: clamp(1.9rem, 3vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--ls-col-heading);
    line-height: 1.05;
  }
  .ls-col__subtitle {
    margin: 0.5rem 0 0;
    font-size: 0.9rem;
    color: var(--ls-col-muted);
  }
  .ls-col__count { font-weight: 700; color: var(--ls-col-heading); }
  .ls-col__assurances { display: flex; gap: 1.25rem; flex-wrap: wrap; }
  .ls-col__assurance {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--ls-col-heading);
  }
  .ls-col__assurance-dot {
    width: 7px; height: 7px; border-radius: 999px;
    background: var(--ls-col-success);
  }
  .ls-col__assurance-icon { width: 16px; height: 16px; color: var(--ls-col-heading); }

  /* ---------- Body layout ---------- */
  .ls-col__body {
    display: grid;
    grid-template-columns: 264px minmax(0, 1fr);
    gap: 2rem;
    align-items: start;
  }

  /* ---------- Sidebar ---------- */
  .ls-col__sidebar {
    background: var(--ls-col-surface);
    border: 1px solid var(--ls-col-border);
    border-radius: var(--ls-col-radius);
    padding: 1.1rem 1.25rem 1.25rem;
    box-shadow: 0 1px 2px rgba(20, 22, 26, 0.03), 0 8px 24px rgba(20, 22, 26, 0.04);
  }
  .ls-col__sidebar-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding-bottom: 0.9rem;
  }
  .ls-col__sidebar-title {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--ls-col-heading);
  }
  .ls-col__sidebar-title svg { width: 18px; height: 18px; color: var(--ls-col-accent); }
  .ls-col__sidebar-count { font-size: 0.8rem; color: var(--ls-col-muted); }

  .ls-col__facet {
    border-top: 1px solid var(--ls-col-border);
    padding: 0.9rem 0;
  }
  .ls-col__facet-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    cursor: pointer;
    list-style: none;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--ls-col-heading);
  }
  .ls-col__facet-summary::-webkit-details-marker { display: none; }
  .ls-col__facet-chevron {
    width: 9px; height: 9px; flex-shrink: 0;
    border-right: 1.6px solid var(--ls-col-muted);
    border-bottom: 1.6px solid var(--ls-col-muted);
    transform: rotate(45deg);
    transition: transform 0.15s ease;
    margin-bottom: 3px;
  }
  .ls-col__facet[open] .ls-col__facet-chevron { transform: rotate(-135deg); margin-bottom: -2px; }
  .ls-col__facet-body { padding-top: 0.85rem; }

  /* Color swatches */
  .ls-col__swatches {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0.5rem;
  }
  .ls-col__swatch { position: relative; cursor: pointer; aspect-ratio: 1 / 1; }
  .ls-col__swatch input { position: absolute; opacity: 0; inset: 0; margin: 0; cursor: pointer; }
  .ls-col__swatch-dot {
    display: block;
    width: 100%; height: 100%;
    border-radius: 10px;
    background: #ddd center/cover no-repeat;
    box-shadow: inset 0 0 0 1px rgba(0, 0, 0, 0.08);
    transition: box-shadow 0.15s ease, transform 0.15s ease;
  }
  .ls-col__swatch:hover .ls-col__swatch-dot { transform: scale(1.04); }
  .ls-col__swatch.is-active .ls-col__swatch-dot {
    box-shadow: inset 0 0 0 1px rgba(0, 0, 0, 0.08), 0 0 0 2px var(--ls-col-accent);
  }
  .ls-col__swatch.is-disabled { opacity: 0.35; pointer-events: none; }

  /* Checkbox options */
  .ls-col__options { display: flex; flex-direction: column; gap: 0.6rem; }
  .ls-col__option {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    cursor: pointer;
    font-size: 0.875rem;
    color: var(--ls-col-text);
  }
  .ls-col__option input { position: absolute; opacity: 0; width: 0; height: 0; }
  .ls-col__option-box {
    width: 18px; height: 18px; flex-shrink: 0;
    border: 1.5px solid var(--ls-col-border);
    border-radius: 5px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.15s ease, background-color 0.15s ease;
  }
  .ls-col__option input:checked ~ .ls-col__option-box {
    background: var(--ls-col-accent);
    border-color: var(--ls-col-accent);
  }
  .ls-col__option input:checked ~ .ls-col__option-box::after {
    content: '';
    width: 5px; height: 9px;
    border: solid #fff;
    border-width: 0 2px 2px 0;
    transform: rotate(45deg) translate(-1px, -1px);
  }
  .ls-col__option input:focus-visible ~ .ls-col__option-box { outline: 2px solid var(--ls-col-accent); outline-offset: 1px; }
  .ls-col__option-label { flex: 1 1 auto; min-width: 0; }
  .ls-col__option-count { color: var(--ls-col-muted); font-size: 0.8rem; }
  .ls-col__option.is-disabled { opacity: 0.4; cursor: default; }

  .ls-col__sidebar-foot { padding-top: 1rem; display: flex; flex-direction: column; gap: 0.6rem; }
  .ls-col__apply {
    appearance: none;
    border: 0;
    background: var(--ls-col-accent);
    color: #fff;
    font: inherit;
    font-weight: 600;
    padding: 0.7rem 1rem;
    border-radius: 999px;
    cursor: pointer;
  }
  /* With JS, facets auto-submit — the Apply button is a no-JS fallback. */
  .ls-col--js .ls-col__apply { display: none; }
  .ls-col__clear {
    text-align: center;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--ls-col-muted);
    text-decoration: none;
  }
  .ls-col__clear:hover { color: var(--ls-col-accent); }
  .ls-col__no-facets { font-size: 0.85rem; color: var(--ls-col-muted); padding-top: 0.5rem; }

  /* ---------- Main / toolbar ---------- */
  .ls-col__toolbar {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 0.5rem;
  }
  .ls-col__filters-toggle {
    display: none;
    align-items: center;
    gap: 0.4rem;
    appearance: none;
    border: 1px solid var(--ls-col-border);
    background: var(--ls-col-surface);
    color: var(--ls-col-heading);
    font: inherit;
    font-weight: 600;
    font-size: 0.85rem;
    padding: 0.55rem 0.9rem;
    border-radius: 999px;
    cursor: pointer;
  }
  .ls-col__filters-toggle svg { width: 16px; height: 16px; }

  .ls-col__pills {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex: 1 1 auto;
    flex-wrap: nowrap;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .ls-col__pills::-webkit-scrollbar { display: none; }
  .ls-col__pill {
    flex-shrink: 0;
    border: 1px solid var(--ls-col-border);
    background: var(--ls-col-surface);
    color: var(--ls-col-text);
    font-size: 0.8125rem;
    font-weight: 500;
    padding: 0.5rem 0.9rem;
    border-radius: 999px;
    text-decoration: none;
    white-space: nowrap;
    transition: border-color 0.15s ease, color 0.15s ease, background-color 0.15s ease;
  }
  .ls-col__pill:hover { border-color: var(--ls-col-heading); color: var(--ls-col-heading); }
  .ls-col__pill.is-active {
    border-color: var(--ls-col-heading);
    background: var(--ls-col-heading);
    color: var(--ls-col-surface);
  }

  .ls-col__sort {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    flex-shrink: 0;
    border: 1px solid var(--ls-col-border);
    background: var(--ls-col-surface);
    border-radius: 999px;
    padding: 0.5rem 2rem 0.5rem 0.95rem;
    font-size: 0.85rem;
  }
  .ls-col__sort-label { color: var(--ls-col-muted); }
  .ls-col__sort select {
    appearance: none;
    border: 0;
    background: none;
    font: inherit;
    font-weight: 600;
    color: var(--ls-col-heading);
    cursor: pointer;
    outline: none;
  }
  .ls-col__sort-caret {
    position: absolute;
    right: 0.85rem;
    width: 14px; height: 14px;
    color: var(--ls-col-muted);
    pointer-events: none;
  }

  .ls-col__showing {
    margin: 0 0 1rem;
    font-size: 0.85rem;
    color: var(--ls-col-muted);
  }

  /* ---------- Grid ---------- */
  .ls-col__grid {
    display: grid;
    grid-template-columns: repeat(var(--ls-col-cols, 4), minmax(0, 1fr));
    gap: 1.5rem;
  }
  .ls-col__empty { color: var(--ls-col-muted); padding: 2rem 0; }

  /* ---------- Sample CTA banner (interleaved) ---------- */
  .ls-col__cta { grid-column: 1 / -1; }
  .ls-col__cta-inner {
    position: relative;
    overflow: hidden;
    border-radius: 26px;
    /* No padding here — the image fills the full card. Inset lives on the
       content below so only the text/button are padded. */
    min-height: 200px;
    background: linear-gradient(139deg, var(--ls-col-cta-start) 0%, var(--ls-col-cta-mid) 55%, var(--ls-col-cta-end) 100%);
  }
  .ls-col__cta-media {
    position: absolute;
    inset: 0;
    overflow: hidden;
    border-radius: inherit;
    pointer-events: none;
  }
  .ls-col__cta-img {
    position: absolute;
    top: 50%;
    right: 0;
    /* Height-driven so it always bleeds top-to-bottom; width follows aspect.
       Size % is relative to the banner height; min-height keeps it full-bleed
       even at smaller size settings. */
    height: calc(var(--ls-col-cta-w, 160) * 1%);
    min-height: 100%;
    width: auto;
    max-width: none;
    transform: translate(calc(var(--ls-col-cta-x, 40) * 1px), calc(-50% + var(--ls-col-cta-y, 0) * 1px)) rotate(calc(var(--ls-col-cta-r, 0) * 1deg));
  }
  .ls-col__cta-content {
    position: relative;
    z-index: 1;
    box-sizing: content-box;
    max-width: 420px;
    padding: 50px;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .ls-col__cta-text { display: flex; flex-direction: column; gap: 6px; }
  .ls-col__cta-heading {
    margin: 0;
    font-size: 30px;
    line-height: 34px;
    font-weight: 700;
    letter-spacing: -0.6px;
    color: #fff;
  }
  .ls-col__cta-sub {
    margin: 0;
    font-size: 15px;
    line-height: 1.4;
    color: rgba(255, 255, 255, 0.72);
    max-width: 354px;
  }
  .ls-col__cta-btn {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--ls-col-accent);
    color: #fff;
    font-weight: 600;
    font-size: 14px;
    padding: 13px 20px;
    border-radius: 999px;
    text-decoration: none;
    transition: filter 0.15s ease;
  }
  .ls-col__cta-btn:hover { filter: brightness(1.06); }
  .ls-col__cta-btn svg { width: 16px; height: 16px; }
  .ls-col__cta-actions { display: flex; flex-wrap: wrap; gap: 10px; }
  .ls-col__cta-btn--secondary {
    background: transparent;
    color: #fff;
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.32);
  }
  .ls-col__cta-btn--secondary:hover {
    filter: none;
    background: rgba(255, 255, 255, 0.08);
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.55);
  }

  @media screen and (max-width: 749px) {
    .ls-col__cta-content { max-width: none; padding: 28px 24px; }
    .ls-col__cta-heading { font-size: 24px; line-height: 28px; }
    .ls-col__cta-img {
      height: calc(var(--ls-col-cta-w-m, 140) * 1%);
      width: auto;
      transform: translate(calc(var(--ls-col-cta-x-m, 30) * 1px), calc(-50% + var(--ls-col-cta-y-m, 70) * 1px)) rotate(calc(var(--ls-col-cta-r-m, 0) * 1deg));
    }
  }

  /* ---------- Load more ---------- */
  .ls-col__loadmore-wrap { display: flex; justify-content: center; margin-top: 2rem; }
  .ls-col__loadmore {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    border: 1px solid var(--ls-col-border);
    background: var(--ls-col-surface);
    color: var(--ls-col-heading);
    font-weight: 600;
    font-size: 0.875rem;
    padding: 0.8rem 1.6rem;
    border-radius: 999px;
    text-decoration: none;
    cursor: pointer;
    transition: border-color 0.15s ease, color 0.15s ease;
  }
  .ls-col__loadmore:hover { border-color: var(--ls-col-heading); }
  .ls-col__loadmore.is-loading { opacity: 0.6; pointer-events: none; }

  /* ---------- Filter sheet chrome (hidden on desktop) ---------- */
  /* The sheet head/foot only exist on mobile. `display:contents` on the scroll
     wrapper lets the desktop card lay out exactly as before. */
  .ls-col__sheet-head,
  .ls-col__sheet-foot { display: none; }
  .ls-col__sheet-scroll { display: contents; }
  .ls-col__toolbar-count { display: none; }
  .ls-col__facet--sort { display: none; }
  .ls-col__sheet-pills { display: none; }

  /* Active-facet badge (on the mobile button + sheet title) */
  .ls-col__badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 20px;
    height: 20px;
    padding: 0 5px;
    border-radius: 999px;
    background: var(--ls-col-accent);
    color: #fff;
    font-size: 0.75rem;
    font-weight: 700;
    line-height: 1;
  }

  /* Radio variant (mobile Sort section) — circular box with a filled dot */
  .ls-col__option--radio .ls-col__option-box { border-radius: 999px; }
  .ls-col__option--radio input:checked ~ .ls-col__option-box {
    background: #fff;
    border-color: var(--ls-col-accent);
  }
  .ls-col__option--radio input:checked ~ .ls-col__option-box::after {
    content: '';
    width: 10px;
    height: 10px;
    border: 0;
    border-radius: 999px;
    background: var(--ls-col-accent);
    transform: none;
  }

  /* Scrim is inert until JS drops the `hidden` attribute on mobile */
  .ls-col__scrim { position: fixed; inset: 0; z-index: 1000; }

  /* ---------- Responsive ---------- */
  /* Columns are forced (var-driven) down to the mobile breakpoint — no 3-up step. */
  @media screen and (max-width: 990px) {
    .ls-col__body { grid-template-columns: minmax(0, 1fr); }

    /* Toolbar → ActionRow: single button + count, pills & sort fold away */
    .ls-col__filters-toggle { display: inline-flex; }
    .ls-col__toolbar-count {
      display: inline-block;
      margin-left: auto;
      color: var(--ls-col-muted);
      font-size: 0.9375rem;
    }
    .ls-col__pills,
    .ls-col__sort,
    .ls-col__showing { display: none; }
    .ls-col__facet--sort { display: block; }
    .ls-col__sheet-pills {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      padding: 2px 0 16px;
    }

    /* Sidebar → bottom sheet */
    .ls-col__sidebar {
      position: fixed;
      left: 0;
      right: 0;
      bottom: 0;
      z-index: 1001;
      display: flex;
      flex-direction: column;
      max-height: 88vh;
      margin: 0;
      padding: 0;
      border: 0;
      border-radius: 22px 22px 0 0;
      box-shadow: 0 -8px 40px rgba(20, 22, 26, 0.22);
      transform: translateY(100%);
      transition: transform 0.28s cubic-bezier(0.32, 0.72, 0, 1);
      overscroll-behavior: contain;
    }
    .ls-col__sidebar.is-open { transform: translateY(0); }

    .ls-col__sheet-head { display: block; padding: 10px 20px 14px; }
    .ls-col__sheet-handle {
      display: block;
      width: 40px;
      height: 4px;
      margin: 0 auto 14px;
      border-radius: 999px;
      background: #d9d9d9;
    }
    .ls-col__sheet-titlebar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
    }
    .ls-col__sheet-title {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 1.375rem;
      font-weight: 700;
      letter-spacing: -0.02em;
      color: var(--ls-col-heading);
    }
    .ls-col__sheet-close {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 40px;
      height: 40px;
      flex-shrink: 0;
      border: 0;
      border-radius: 999px;
      background: var(--ls-col-chip, #eee);
      color: var(--ls-col-heading);
      cursor: pointer;
    }
    .ls-col__sheet-close svg { width: 18px; height: 18px; }

    /* Scrollable facet body between the fixed head and foot */
    .ls-col__sheet-scroll {
      display: block;
      flex: 1 1 auto;
      overflow-y: auto;
      -webkit-overflow-scrolling: touch;
      padding: 0 20px;
    }
    /* Desktop card head + apply/clear foot don't belong in the sheet */
    .ls-col__sidebar-head,
    .ls-col__sidebar-foot { display: none; }
    /* First facet inside the sheet shouldn't carry a top divider */
    .ls-col__sheet-scroll > .ls-col__facet:first-child { border-top: 0; padding-top: 0.2rem; }

    .ls-col__sheet-foot {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 14px 20px calc(14px + env(safe-area-inset-bottom, 0px));
      border-top: 1px solid var(--ls-col-border);
      background: var(--ls-col-surface);
    }
    .ls-col__sheet-clear {
      flex: 0 0 auto;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0.85rem 1.4rem;
      border: 1px solid var(--ls-col-border);
      border-radius: 999px;
      font-weight: 600;
      font-size: 0.9375rem;
      color: var(--ls-col-heading);
      text-decoration: none;
    }
    .ls-col__sheet-apply {
      flex: 1 1 auto;
      appearance: none;
      border: 0;
      cursor: pointer;
      padding: 0.9rem 1.2rem;
      border-radius: 999px;
      background: var(--ls-col-accent);
      color: #fff;
      font: inherit;
      font-weight: 700;
      font-size: 0.9375rem;
    }

    .ls-col__scrim {
      background: rgba(15, 16, 20, 0.5);
      opacity: 0;
      transition: opacity 0.28s ease;
    }
    .ls-col__scrim.is-visible { opacity: 1; }

    /* Lock background scroll while the sheet is open */
    .ls-col--sheet-open { overflow: hidden; }
  }
  @media screen and (max-width: 749px) {
    .ls-col__header { align-items: flex-start; }
    /* 2-up grid holds all the way down (matches the 430px Figma frame). */
    .ls-col__grid { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 1rem; }
    /* Load more spans the row (Figma "Secondary Button"). */
    .ls-col__loadmore-wrap { display: block; }
    .ls-col__loadmore { width: 100%; justify-content: center; }
  }
{% endstylesheet %}

