{%- liquid
  assign rv_font = section.settings.font_family
  assign rv_font_500 = rv_font | font_modify: 'weight', '500'
  assign rv_font_600 = rv_font | font_modify: 'weight', '600'
  assign rv_font_700 = rv_font | font_modify: 'weight', '700'

  assign rating_score = section.settings.rating_score | default: 5.0
  assign rating_score = rating_score | at_most: 5 | at_least: 0
  assign rating_display = rating_score | round: 1
-%}

{% style %}
  {{ rv_font | font_face: font_display: 'swap' }}
  {{ rv_font_500 | font_face: font_display: 'swap' }}
  {{ rv_font_600 | font_face: font_display: 'swap' }}
  {{ rv_font_700 | font_face: font_display: 'swap' }}

  .ls-review-{{ section.id }} {
    --ls-rv-font-family: {{ rv_font.family }}, {{ rv_font.fallback_families }};
    --ls-rv-eyebrow: {{ section.settings.eyebrow_color | default: '#c13121' }};
    --ls-rv-heading: {{ section.settings.heading_color | default: '#1a1a1a' }};
    --ls-rv-accent: {{ section.settings.accent_color | default: '#c13121' }};
    --ls-rv-text: {{ section.settings.text_color | default: '#1a1a1a' }};
    --ls-rv-muted: {{ section.settings.muted_color | default: '#6b7280' }};
    --ls-rv-card-bg: {{ section.settings.card_background | default: '#ffffff' }};
    --ls-rv-card-border: {{ section.settings.card_border_color | default: '#e6e2db' }};
    --ls-rv-radius: {{ section.settings.card_radius | default: 18 }}px;
    --ls-rv-star: {{ section.settings.star_color | default: '#f5b301' }};
    --ls-rv-star-rgb: {{ section.settings.star_color.rgb | default: '245 179 1' }};
    --ls-rv-verified: {{ section.settings.verified_color | default: '#128a4f' }};
    --ls-rv-cols: {{ section.settings.columns | default: 2 }};
  }
{% endstyle %}

{%- if section.settings.background_color != blank -%}
  <div class="section-background" style="background-color: {{ section.settings.background_color }};"></div>
{%- endif -%}
<div
  class="section ls-review ls-review-{{ section.id }} spacing-style"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  <div class="ls-review__inner">
    <div class="ls-review__titles">
      {%- if section.settings.eyebrow != blank -%}
        <p class="ls-review__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="ls-review__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.show_rating -%}
        <div class="ls-review__rating">
          <div class="ls-review__stars" aria-label="{{ 'accessibility.rating' | t: rating: rating_display }}">
            {% render 'ls-stars', rating: rating_score, prefix: 'ls-review' %}
          </div>
          <span class="ls-review__rating-score">{{ rating_display }}</span>
          {%- if section.settings.rating_text != blank -%}
            <span class="ls-review__rating-text">{{ section.settings.rating_text }}</span>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>

    {%- if section.settings.show_arrows -%}
      <div class="ls-review__nav">
        <button type="button" class="ls-review__arrow" data-arrow="prev" aria-label="Previous reviews">
          <svg viewBox="0 0 20 20" fill="none" focusable="false" aria-hidden="true">
            <path d="M12 5l-5 5 5 5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <button type="button" class="ls-review__arrow" data-arrow="next" aria-label="Next reviews">
          <svg viewBox="0 0 20 20" fill="none" focusable="false" aria-hidden="true">
            <path d="M8 5l5 5-5 5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="ls-review__track" data-track>
        {%- for block in section.blocks -%}
          {%- liquid
            assign stars = block.settings.stars | default: 5 | at_most: 5 | at_least: 0
            assign author = block.settings.author | default: 'Verified buyer'
            assign initial = author | strip | slice: 0, 1 | upcase
          -%}
          <article class="ls-review__card" {{ block.shopify_attributes }}>
            <div class="ls-review__card-top">
              <div class="ls-review__stars ls-review__stars--card" aria-label="{{ 'accessibility.rating' | t: rating: stars }}">
                {% render 'ls-stars', rating: stars, prefix: 'ls-review' %}
              </div>
              {%- if block.settings.show_verified -%}
                <span class="ls-review__verified">
                  <svg viewBox="0 0 20 20" fill="none" focusable="false" aria-hidden="true">
                    <circle cx="10" cy="10" r="8.25" stroke="currentColor" stroke-width="1.5"/>
                    <path d="M6.5 10.2l2.3 2.3 4.7-4.9" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  {{ block.settings.verified_label | default: 'Verified' }}
                </span>
              {%- endif -%}
            </div>

            {%- if block.settings.title != blank -%}
              <h3 class="ls-review__card-title">{{ block.settings.title }}</h3>
            {%- endif -%}

            {%- if block.settings.body != blank -%}
              <p class="ls-review__card-body">{{ block.settings.body }}</p>
            {%- endif -%}

            <div class="ls-review__card-foot">
              <div class="ls-review__avatar" aria-hidden="true">
                {%- if block.settings.avatar != blank -%}
                  {{
                    block.settings.avatar
                    | image_url: width: 96
                    | image_tag: class: 'ls-review__avatar-img', widths: '48, 96', alt: author, loading: 'lazy'
                  }}
                {%- else -%}
                  <span class="ls-review__avatar-initial">{{ initial }}</span>
                {%- endif -%}
              </div>
              <div class="ls-review__author">
                <span class="ls-review__author-name">{{ author }}</span>
                {%- if block.settings.author_note != blank -%}
                  <span class="ls-review__author-note">{{ block.settings.author_note }}</span>
                {%- endif -%}
              </div>
            </div>
          </article>
        {%- endfor -%}
      </div>

      {%- if section.settings.show_dots -%}
        <div class="ls-review__dots" data-dots role="tablist" aria-label="Review pages"></div>
      {%- endif -%}
    {%- endif -%}
  </div>
</div>

<script>
  (function () {
    function init() {
      var root = document.querySelector('.ls-review-{{ section.id }}');
      if (!root) return;
      var track = root.querySelector('[data-track]');
      if (!track) return;
      var cards = Array.prototype.slice.call(track.querySelectorAll('.ls-review__card'));
      if (!cards.length) return;
      var prev = root.querySelector('[data-arrow="prev"]');
      var next = root.querySelector('[data-arrow="next"]');
      var dotsWrap = root.querySelector('[data-dots]');
      var dots = [];

      // Absolute scroll offsets of each card's left/right edge relative to the
      // track's scroll origin. Read from live rects so it stays correct
      // regardless of positioned ancestors.
      function edges() {
        var origin = track.getBoundingClientRect().left - track.scrollLeft;
        return cards.map(function (c) {
          var r = c.getBoundingClientRect();
          return { left: Math.round(r.left - origin), right: Math.round(r.right - origin) };
        });
      }

      // Index of the leftmost card currently in view.
      function activeIndex() {
        var cur = track.scrollLeft;
        var e = edges();
        var idx = 0;
        for (var i = 0; i < e.length; i++) {
          if (e[i].left <= cur + 2) idx = i; else break;
        }
        // Snap to the last card once scrolled to the end.
        if (track.scrollLeft >= track.scrollWidth - track.clientWidth - 1) idx = cards.length - 1;
        return idx;
      }

      function updateArrows() {
        if (!prev && !next) return;
        var max = track.scrollWidth - track.clientWidth;
        var noScroll = max <= 1;
        if (prev) prev.disabled = track.scrollLeft <= 1 || noScroll;
        if (next) next.disabled = track.scrollLeft >= max - 1 || noScroll;
      }

      // Distance between consecutive card left edges (card width + gap).
      function cardStride() {
        var e = edges();
        if (e.length < 2) return track.clientWidth || 1;
        return Math.max(1, e[1].left - e[0].left);
      }

      // How many whole cards fit in one viewport — the page size. Measured from
      // layout, so it tracks the responsive columns (e.g. 2 on desktop, 1 on
      // mobile) without reading settings.
      function perPage() {
        return Math.max(1, Math.round(track.clientWidth / cardStride()));
      }

      function pageCount() {
        return Math.max(1, Math.ceil(cards.length / perPage()));
      }

      function activePage() {
        return Math.min(pageCount() - 1, Math.floor(activeIndex() / perPage()));
      }

      function updateDots() {
        if (!dotsWrap) return;
        // Re-page when the viewport changes how many cards fit per page.
        if (dots.length !== pageCount()) buildDots();
        if (!dots.length) return;
        var active = activePage();
        dots.forEach(function (dot, i) {
          var on = i === active;
          dot.classList.toggle('is-active', on);
          dot.setAttribute('aria-selected', on ? 'true' : 'false');
        });
      }

      function sync() {
        updateArrows();
        updateDots();
      }

      // One dot per page; the active dot stretches into a pill (see stylesheet).
      function buildDots() {
        dots = [];
        if (!dotsWrap) return;
        dotsWrap.innerHTML = '';
        for (var i = 0; i < pageCount(); i++) {
          (function (page) {
            var dot = document.createElement('button');
            dot.type = 'button';
            dot.className = 'ls-review__dot';
            dot.setAttribute('role', 'tab');
            dot.setAttribute('aria-label', 'Go to review page ' + (page + 1));
            dot.addEventListener('click', function () {
              var idx = Math.min(page * perPage(), cards.length - 1);
              track.scrollTo({ left: edges()[idx].left, behavior: 'smooth' });
            });
            dotsWrap.appendChild(dot);
            dots.push(dot);
          })(i);
        }
      }

      // Page by a full viewport of cards, snapping to a card edge.
      function page(dir) {
        var e = edges();
        if (!e.length) return;
        var cur = track.scrollLeft;
        var view = track.clientWidth;
        var max = track.scrollWidth - view;
        var viewRight = cur + view;
        var target;
        if (dir > 0) {
          target = max;
          for (var i = 0; i < e.length; i++) {
            if (e[i].right > viewRight + 1) { target = Math.min(e[i].left, max); break; }
          }
        } else {
          target = 0;
          for (var j = e.length - 1; j >= 0; j--) {
            if (e[j].left < cur - 1) { target = Math.max(e[j].right - view, 0); break; }
          }
        }
        track.scrollTo({ left: target, behavior: 'smooth' });
      }

      if (next) next.addEventListener('click', function () { page(1); });
      if (prev) prev.addEventListener('click', function () { page(-1); });
      track.addEventListener('scroll', sync, { passive: true });
      window.addEventListener('resize', sync, { passive: true });

      buildDots();
      sync();
    }

    init();
    document.addEventListener('shopify:section:load', function (e) {
      if (!e.detail || e.detail.sectionId === '{{ section.id }}') init();
    });
  })();
</script>

{% stylesheet %}
  .ls-review__inner {
    font-family: var(--ls-rv-font-family, 'Outfit', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif);
    color: var(--ls-rv-text);
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-areas:
      'titles nav'
      'track track'
      'dots dots';
    column-gap: 1rem;
    row-gap: clamp(1.25rem, 3vw, 1.75rem);
    align-items: start;
  }

  .ls-review__titles {
    grid-area: titles;
  }

  .ls-review__nav {
    grid-area: nav;
    align-self: start;
    justify-self: end;
  }

  .ls-review__track {
    grid-area: track;
  }

  .ls-review__dots {
    grid-area: dots;
  }

  .ls-review__eyebrow {
    margin: 0 0 0.4rem;
    color: var(--ls-rv-eyebrow);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .ls-review__heading {
    margin: 0;
    color: var(--ls-rv-heading);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.05;
  }

  .ls-review__rating {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.85rem;
  }

  .ls-review__stars {
    display: inline-flex;
    align-items: center;
    gap: 0.125rem;
  }

  .ls-review__star {
    position: relative;
    display: inline-block;
    width: 1rem;
    height: 1rem;
  }

  .ls-review__star-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }

  .ls-review__star-bg {
    fill: rgb(var(--ls-rv-star-rgb) / 0.25);
  }

  .ls-review__star-fg {
    fill: var(--ls-rv-star);
    clip-path: inset(0 calc(100% - var(--star-fill, 0%)) 0 0);
  }

  .ls-review__rating-score {
    font-weight: 700;
    font-size: 1rem;
    color: var(--ls-rv-heading);
  }

  .ls-review__rating-text {
    color: var(--ls-rv-muted);
    font-size: 0.9375rem;
  }

  .ls-review__rating-text::before {
    content: '·';
    margin-right: 0.4rem;
  }

  .ls-review__nav {
    display: flex;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .ls-review__arrow {
    appearance: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 999px;
    border: 1px solid rgb(0 0 0 / 0.14);
    background: var(--ls-rv-card-bg);
    color: var(--ls-rv-text);
    cursor: pointer;
    transition: border-color 0.15s ease, color 0.15s ease;
  }

  .ls-review__arrow:hover:not(:disabled) {
    border-color: var(--ls-rv-heading);
    color: var(--ls-rv-accent);
  }

  .ls-review__arrow:disabled {
    opacity: 0.35;
    cursor: default;
  }

  .ls-review__arrow svg {
    width: 20px;
    height: 20px;
  }

  .ls-review__track {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: calc((100% - (var(--ls-rv-cols) - 1) * clamp(1rem, 2vw, 1.5rem)) / var(--ls-rv-cols));
    gap: clamp(1rem, 2vw, 1.5rem);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: 0.25rem;
  }

  .ls-review__track::-webkit-scrollbar {
    display: none;
  }

  .ls-review__card {
    scroll-snap-align: start;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    background: var(--ls-rv-card-bg);
    border: 1px solid var(--ls-rv-card-border);
    border-radius: var(--ls-rv-radius, 18px);
    padding: clamp(1.25rem, 2.5vw, 1.75rem);
    box-shadow: 0 1px 3px rgb(0 0 0 / 0.04), 0 10px 30px rgb(0 0 0 / 0.04);
  }

  .ls-review__card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .ls-review__stars--card .ls-review__star {
    width: 1.05rem;
    height: 1.05rem;
  }

  .ls-review__verified {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    color: var(--ls-rv-verified);
    font-size: 0.8125rem;
    font-weight: 600;
    flex-shrink: 0;
  }

  .ls-review__verified svg {
    width: 1rem;
    height: 1rem;
  }

  .ls-review__card-title {
    margin: 0;
    color: var(--ls-rv-heading);
    font-size: 1.125rem;
    font-weight: 700;
    line-height: 1.3;
  }

  .ls-review__card-body {
    margin: 0;
    color: var(--ls-rv-text);
    font-size: 0.9375rem;
    line-height: 1.55;
    flex-grow: 1;
  }

  .ls-review__card-foot {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 0.5rem;
    padding-top: 1.1rem;
    border-top: 1px solid var(--ls-rv-card-border);
  }

  .ls-review__avatar {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 999px;
    background: var(--ls-rv-heading);
    color: #fff;
    overflow: hidden;
    flex-shrink: 0;
  }

  .ls-review__avatar-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ls-review__avatar-initial {
    font-size: 0.9375rem;
    font-weight: 700;
  }

  .ls-review__author {
    display: flex;
    flex-direction: column;
    line-height: 1.3;
  }

  .ls-review__author-name {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--ls-rv-heading);
  }

  .ls-review__author-note {
    font-size: 0.8125rem;
    color: var(--ls-rv-muted);
  }

  .ls-review__dots {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
  }

  .ls-review__dot {
    appearance: none;
    padding: 0;
    border: 0;
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: rgb(0 0 0 / 0.18);
    cursor: pointer;
    transition: width 0.25s ease, background-color 0.25s ease;
  }

  .ls-review__dot:hover {
    background: rgb(0 0 0 / 0.3);
  }

  /* Active dot stretches into a pill in the accent color. */
  .ls-review__dot.is-active {
    width: 26px;
    background: var(--ls-rv-accent);
  }

  @media screen and (max-width: 749px) {
    /* Arrows drop to the bottom row, sharing it with the dots (dots left,
       arrows right). */
    .ls-review__inner {
      grid-template-areas:
        'titles titles'
        'track track'
        'dots nav';
      align-items: center;
    }

    .ls-review__nav {
      align-self: center;
    }

    .ls-review__dots {
      justify-content: flex-start;
    }

    /* One full-width card per view — the arrows already cue that it's
       swipeable, so no peek of the next card. */
    .ls-review__track {
      grid-auto-columns: 100%;
      gap: 0.75rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "LS Review",
  "tag": "section",
  "class": "ls-review-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "max_blocks": 24,
  "settings": [
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "font_picker",
      "id": "font_family",
      "label": "Font",
      "default": "outfit_n4"
    },
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Reviews"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Trusted by painters"
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "label": "Show summary rating",
      "default": true
    },
    {
      "type": "range",
      "id": "rating_score",
      "label": "Summary rating",
      "info": "Filled stars in the header (0–5). Supports one decimal.",
      "min": 0,
      "max": 5,
      "step": 0.1,
      "default": 5.0
    },
    {
      "type": "text",
      "id": "rating_text",
      "label": "Rating text",
      "default": "verified buyers"
    },
    {
      "type": "header",
      "content": "Carousel"
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show arrows",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_dots",
      "label": "Show pagination dots",
      "default": true
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Cards per view (desktop)",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 2
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Card corner radius",
      "min": 0,
      "max": 28,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section background",
      "default": "#fafafa"
    },
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Eyebrow",
      "default": "#c13121"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent (active dot)",
      "default": "#c13121"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "muted_color",
      "label": "Muted text",
      "default": "#6b7280"
    },
    {
      "type": "color",
      "id": "star_color",
      "label": "Star",
      "default": "#f5b301"
    },
    {
      "type": "color",
      "id": "verified_color",
      "label": "Verified badge",
      "default": "#128a4f"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_border_color",
      "label": "Card border & divider",
      "default": "#e6e2db"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
