{%- liquid
  assign trusted_font = section.settings.font_family
  assign trusted_font_500 = trusted_font | font_modify: 'weight', '500'
-%}

{% style %}
  {{ trusted_font | font_face: font_display: 'swap' }}
  {{ trusted_font_500 | font_face: font_display: 'swap' }}

  .ls-trusted-{{ section.id }} {
    --ls-trusted-font-family: {{ trusted_font.family }}, {{ trusted_font.fallback_families }};
    --ls-trusted-bg: {{ section.settings.background_color | default: '#ffffff' }};
    --ls-trusted-heading: {{ section.settings.heading_color | default: '#6b7280' }};
    --ls-trusted-logo-height: {{ section.settings.logo_height | default: 44 }}px;
    --ls-trusted-gap: {{ section.settings.item_gap | default: 40 }}px;
    --ls-trusted-pad-y: {{ section.settings.section_padding | default: 40 }}px;
    --ls-trusted-pad-y-mobile: {{ section.settings.section_padding_mobile | default: 28 }}px;
    --ls-trusted-speed: {{ section.settings.marquee_speed | default: 30 }}s;
    --ls-trusted-opacity: {{ section.settings.logo_opacity | default: 100 | divided_by: 100.0 }};
  }
{% endstyle %}

<div
  class="section section--full-width ls-trusted ls-trusted-{{ section.id }} spacing-style"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  <div class="ls-trusted__inner">
    {%- if section.settings.heading != blank or section.settings.heading_mobile != blank -%}
      <p class="ls-trusted__heading">
        {%- if section.settings.heading != blank -%}
          <span class="ls-trusted__heading--desktop">{{ section.settings.heading }}</span>
        {%- endif -%}
        {%- if section.settings.heading_mobile != blank -%}
          <span class="ls-trusted__heading--mobile">{{ section.settings.heading_mobile }}</span>
        {%- endif -%}
      </p>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="ls-trusted__logos">
        <div class="ls-trusted__track">
        {%- for pass in (1..2) -%}
        {%- for block in section.blocks -%}
          {%- assign brand_alt = block.settings.name | default: block.settings.logo.alt -%}
          <div
            class="ls-trusted__logo{% if pass == 2 %} ls-trusted__logo--clone{% endif %}"
            {% if pass == 1 %}{{ block.shopify_attributes }}{% else %}aria-hidden="true"{% endif %}
          >
            {%- if block.settings.link != blank -%}
              <a
                href="{{ block.settings.link }}"
                class="ls-trusted__logo-link"
                {% if block.settings.name != blank %}aria-label="{{ block.settings.name }}"{% endif %}
              >
            {%- endif -%}

            {%- if block.settings.logo != blank -%}
              {{
                block.settings.logo
                | image_url: width: 480
                | image_tag:
                  class: 'ls-trusted__logo-img',
                  widths: '120, 200, 300, 400, 480',
                  sizes: '160px',
                  alt: brand_alt,
                  loading: 'lazy'
              }}
            {%- else -%}
              <span class="ls-trusted__logo-placeholder">{{ block.settings.name | default: 'Brand' }}</span>
            {%- endif -%}

            {%- if block.settings.link != blank -%}
              </a>
            {%- endif -%}
          </div>
        {%- endfor -%}
        {%- endfor -%}
        </div>
      </div>
    {%- endif -%}
  </div>
</div>

<script>
  (function () {
    var root = document.querySelector('.ls-trusted-{{ section.id }}');
    if (!root) return;
    var track = root.querySelector('.ls-trusted__track');
    if (!track) return;

    function update() {
      root.classList.remove('ls-trusted--marquee');
      var items = track.querySelectorAll('.ls-trusted__logo:not(.ls-trusted__logo--clone)');
      if (items.length < 2) return;
      var top0 = items[0].offsetTop;
      var wraps = false;
      for (var i = 1; i < items.length; i++) {
        if (items[i].offsetTop - top0 > 2) { wraps = true; break; }
      }
      root.classList.toggle('ls-trusted--marquee', wraps);
    }

    update();

    var timer;
    window.addEventListener('resize', function () {
      clearTimeout(timer);
      timer = setTimeout(update, 150);
    });

    root.querySelectorAll('.ls-trusted__logo-img').forEach(function (img) {
      if (!img.complete) img.addEventListener('load', update, { once: true });
    });
  })();
</script>

{% stylesheet %}
  .ls-trusted__inner {
    background-color: var(--ls-trusted-bg);
    font-family: var(--ls-trusted-font-family, 'Outfit', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif);
    padding: var(--ls-trusted-pad-y, 40px) clamp(1rem, 4vw, 3rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: clamp(1.25rem, 3vw, 2.25rem);
  }

  .ls-trusted__heading {
    margin: 0;
    color: var(--ls-trusted-heading);
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    text-align: center;
  }

  .ls-trusted__logos {
    width: 100%;
  }

  .ls-trusted__track {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--ls-trusted-gap, 40px);
    width: 100%;
  }

  .ls-trusted__logo,
  .ls-trusted__logo-link {
    display: inline-flex;
    align-items: center;
  }

  .ls-trusted__track .ls-trusted__logo--clone {
    display: none;
  }

  .ls-trusted__logo-img {
    height: var(--ls-trusted-logo-height, 44px);
    width: auto;
    max-width: 170px;
    object-fit: contain;
    opacity: var(--ls-trusted-opacity, 1);
    transition: opacity 0.2s ease;
  }

  .ls-trusted__logo-link:hover .ls-trusted__logo-img {
    opacity: 1;
  }

  .ls-trusted__heading--mobile {
    display: none;
  }

  /* Marquee mode — toggled by JS when the logos wrap to more than one row. */
  .ls-trusted--marquee .ls-trusted__logos {
    overflow: hidden;
  }

  .ls-trusted--marquee .ls-trusted__track {
    flex-wrap: nowrap;
    justify-content: flex-start;
    gap: 0;
    width: max-content;
    animation: ls-trusted-marquee var(--ls-trusted-speed, 30s) linear infinite;
  }

  .ls-trusted--marquee .ls-trusted__logo {
    flex: 0 0 auto;
    margin-right: var(--ls-trusted-gap, 40px);
  }

  .ls-trusted--marquee .ls-trusted__track .ls-trusted__logo--clone {
    display: inline-flex;
  }

  @keyframes ls-trusted-marquee {
    from {
      transform: translateX(0);
    }

    to {
      transform: translateX(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ls-trusted--marquee .ls-trusted__track {
      animation: none;
    }
  }

  .ls-trusted__logo-placeholder {
    color: var(--ls-trusted-heading);
    font-weight: 700;
    font-size: 1rem;
    white-space: nowrap;
  }

  @media screen and (max-width: 749px) {
    .ls-trusted__inner {
      padding-block: var(--ls-trusted-pad-y-mobile, 28px);
    }

    .ls-trusted__track {
      justify-content: center;
      gap: clamp(1.25rem, 6vw, var(--ls-trusted-gap, 40px));
    }

    .ls-trusted__heading--desktop:not(:only-child) {
      display: none;
    }

    .ls-trusted__heading--mobile {
      display: inline;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "LS Trusted",
  "tag": "section",
  "class": "ls-trusted-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "max_blocks": 16,
  "settings": [
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "font_picker",
      "id": "font_family",
      "label": "Font",
      "default": "outfit_n4"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The brands you know — trusted by pros, loved by DIYers"
    },
    {
      "type": "text",
      "id": "heading_mobile",
      "label": "Heading (mobile)",
      "info": "Optional. Replaces the heading on mobile."
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading",
      "default": "#6b7280"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "logo_height",
      "label": "Logo height",
      "min": 24,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 44
    },
    {
      "type": "range",
      "id": "item_gap",
      "label": "Space between logos",
      "min": 16,
      "max": 96,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "logo_opacity",
      "label": "Logo opacity",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "Vertical padding",
      "min": 8,
      "max": 96,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "section_padding_mobile",
      "label": "Vertical padding (mobile)",
      "min": 8,
      "max": 96,
      "step": 4,
      "unit": "px",
      "default": 28
    },
    {
      "type": "range",
      "id": "marquee_speed",
      "label": "Marquee speed",
      "info": "Seconds per loop when logos wrap to more than one row and become a marquee.",
      "min": 10,
      "max": 80,
      "step": 2,
      "unit": "s",
      "default": 30
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "Brand",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Brand name",
          "info": "Used for the logo's alt text and shown until a logo is uploaded."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LS Trusted",
      "category": "t:categories.banners",
      "blocks": [
        { "type": "brand", "settings": { "name": "Lenmar" } },
        { "type": "brand", "settings": { "name": "Old Masters" } },
        { "type": "brand", "settings": { "name": "TriTech" } },
        { "type": "brand", "settings": { "name": "Benjamin Moore" } },
        { "type": "brand", "settings": { "name": "Festool" } },
        { "type": "brand", "settings": { "name": "Graco" } },
        { "type": "brand", "settings": { "name": "Rust-Oleum" } },
        { "type": "brand", "settings": { "name": "EVO Eclipse" } }
      ]
    }
  ]
}
{% endschema %}
