{%- liquid
  assign cs_font = section.settings.font_family
  assign cs_font_600 = cs_font | font_modify: 'weight', '600'
  assign cs_font_700 = cs_font | font_modify: 'weight', '700'
-%}

{% style %}
  {{ cs_font | font_face: font_display: 'swap' }}
  {{ cs_font_600 | font_face: font_display: 'swap' }}
  {{ cs_font_700 | font_face: font_display: 'swap' }}

  .ls-cs-{{ section.id }} {
    --ls-cs-font-family: {{ cs_font.family }}, {{ cs_font.fallback_families }};
    --ls-cs-eyebrow: {{ section.settings.eyebrow_color | default: '#c13121' }};
    --ls-cs-heading: {{ section.settings.heading_color | default: '#1a1a1a' }};
    --ls-cs-accent: {{ section.settings.accent_color | default: '#c13121' }};
    --ls-cs-text: {{ section.settings.text_color | default: '#1a1a1a' }};
    --ls-cs-muted: {{ section.settings.muted_color | default: '#6b7280' }};
    --ls-cs-card-bg: {{ section.settings.card_background | default: '#ffffff' }};
    --ls-cs-radius: {{ section.settings.card_radius | default: 18 }}px;
    --ls-cs-card-w: clamp(240px, 22vw, {{ section.settings.card_width | default: 320 }}px);
  }
{% endstyle %}

{%- if section.settings.background_color != blank -%}
  <div class="section-background" style="background-color: {{ section.settings.background_color }};"></div>
{%- endif -%}
<div
  class="section ls-cs ls-cs-{{ section.id }} spacing-style"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  <div class="ls-cs__inner">
    <header class="ls-cs__header">
      <div class="ls-cs__titles">
        {%- if section.settings.eyebrow != blank -%}
          <p class="ls-cs__eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="ls-cs__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
      </div>

      {%- if section.settings.show_arrows -%}
        <div class="ls-cs__nav">
          <button type="button" class="ls-cs__arrow" data-arrow="prev" aria-label="Previous">
            <svg viewBox="0 0 20 20" fill="none" focusable="false" aria-hidden="true">
              <path d="M12 5l-5 5 5 5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <button type="button" class="ls-cs__arrow" data-arrow="next" aria-label="Next">
            <svg viewBox="0 0 20 20" fill="none" focusable="false" aria-hidden="true">
              <path d="M8 5l5 5-5 5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>
      {%- endif -%}
    </header>

    <div class="ls-cs__track" data-track>
      {%- content_for 'blocks' -%}
    </div>

    {%- if section.settings.show_cta -%}
      <div class="ls-cs__cta">
        <span class="ls-cs__cta-icon" aria-hidden="true">
          <svg viewBox="0 0 23 23" fill="none" focusable="false" aria-hidden="true">
            <path d="M13.4166 2.875L20.125 9.58333L17.25 12.4583L10.5416 5.75L13.4166 2.875Z" stroke="currentColor" stroke-width="1.725" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M10.5416 5.75L3.83329 12.4583C2.87496 13.4167 2.87496 16.2917 1.91663 18.2083C3.83329 17.25 6.70829 17.25 7.66663 16.2917L14.375 9.58333" stroke="currentColor" stroke-width="1.725" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
        <div class="ls-cs__cta-copy">
          {%- if section.settings.cta_title != blank -%}
            <p class="ls-cs__cta-title">{{ section.settings.cta_title }}</p>
          {%- endif -%}
          {%- if section.settings.cta_text != blank -%}
            <p class="ls-cs__cta-text">{{ section.settings.cta_text }}</p>
          {%- endif -%}
        </div>
        {%- if section.settings.cta_button_label != blank -%}
          <a class="ls-cs__cta-btn" href="{{ section.settings.cta_button_link | default: '#' }}">
            {{ section.settings.cta_button_label }}
            <svg viewBox="0 0 20 20" fill="none" focusable="false" aria-hidden="true">
              <path d="M4 10h11M11 6l4 4-4 4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</div>

<script>
  (function () {
    function init() {
      var root = document.querySelector('.ls-cs-{{ section.id }}');
      if (!root) return;
      var track = root.querySelector('[data-track]');
      if (!track) return;
      var cards = Array.prototype.slice.call(track.querySelectorAll('.ls-cs__card'));
      var prev = root.querySelector('[data-arrow="prev"]');
      var next = root.querySelector('[data-arrow="next"]');

      function updateArrows() {
        if (!prev && !next) return;
        var max = track.scrollWidth - track.clientWidth;
        var atStart = track.scrollLeft <= 1;
        var atEnd = track.scrollLeft >= max - 1;
        var noScroll = max <= 1;
        if (prev) prev.disabled = atStart || noScroll;
        if (next) next.disabled = atEnd || noScroll;
      }

      // Absolute scroll offsets of each card's left/right edges, from live rects.
      function edges() {
        var origin = track.getBoundingClientRect().left - track.scrollLeft;
        return cards.map(function (c) {
          var r = c.getBoundingClientRect();
          return { left: Math.round(r.left - origin), right: Math.round(r.right - origin) };
        });
      }

      // Page one viewport of cards, snapping to a card edge.
      function scrollToCard(dir) {
        var e = edges();
        if (!e.length) return;
        var cur = track.scrollLeft;
        var view = track.clientWidth;
        var max = track.scrollWidth - view;
        var viewRight = cur + view;
        var target;
        if (dir > 0) {
          for (var i = 0; i < e.length; i++) {
            if (e[i].right > viewRight + 1) { target = e[i].left; break; }
          }
          if (target == null || target <= cur + 1) target = max;
        } else {
          target = 0;
          for (var j = e.length - 1; j >= 0; j--) {
            if (e[j].left < cur - 1) { target = e[j].right - view; break; }
          }
          if (target < 0) target = 0;
        }
        track.scrollTo({ left: target, behavior: 'smooth' });
      }

      if (next) next.addEventListener('click', function () { scrollToCard(1); });
      if (prev) prev.addEventListener('click', function () { scrollToCard(-1); });

      track.addEventListener('scroll', updateArrows, { passive: true });
      window.addEventListener('resize', updateArrows, { passive: true });

      updateArrows();
    }

    init();
    document.addEventListener('shopify:section:load', function (e) {
      if (!e.detail || e.detail.sectionId === '{{ section.id }}') init();
    });
  })();
</script>

{% stylesheet %}
  .ls-cs__inner {
    font-family: var(--ls-cs-font-family, 'Outfit', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif);
    color: var(--ls-cs-text);
  }

  .ls-cs__header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1.25rem;
  }

  .ls-cs__eyebrow {
    margin: 0 0 0.35rem;
    color: var(--ls-cs-eyebrow);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .ls-cs__heading {
    margin: 0;
    color: var(--ls-cs-heading);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.05;
  }

  .ls-cs__nav {
    display: flex;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .ls-cs__arrow {
    appearance: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 999px;
    border: 1px solid rgb(0 0 0 / 0.14);
    background: var(--ls-cs-card-bg);
    color: var(--ls-cs-text);
    cursor: pointer;
    transition: border-color 0.15s ease, color 0.15s ease;
  }

  .ls-cs__arrow:hover:not(:disabled) {
    border-color: var(--ls-cs-heading);
    color: var(--ls-cs-accent);
  }

  .ls-cs__arrow:disabled {
    opacity: 0.35;
    cursor: default;
  }

  .ls-cs__arrow svg {
    width: 20px;
    height: 20px;
  }

  .ls-cs__track {
    display: flex;
    gap: clamp(1rem, 1.6vw, 1.5rem);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: 0.5rem;
    scroll-padding-left: 2px;
  }

  .ls-cs__track::-webkit-scrollbar {
    display: none;
  }

  .ls-cs__card {
    flex: 0 0 var(--ls-cs-card-w, 280px);
    width: var(--ls-cs-card-w, 280px);
    scroll-snap-align: start;
    border-radius: var(--ls-cs-radius, 18px);
    overflow: hidden;
    background: var(--ls-cs-card-bg);
    box-shadow: 0 1px 3px rgb(0 0 0 / 0.06), 0 8px 24px rgb(0 0 0 / 0.05);
  }

  .ls-cs__media {
    position: relative;
    display: block;
    aspect-ratio: 5 / 4;
    overflow: hidden;
  }

  .ls-cs__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .ls-cs__card:hover .ls-cs__img {
    transform: scale(1.04);
  }

  .ls-cs__img--placeholder {
    display: grid;
    place-items: center;
    background: rgb(0 0 0 / 0.05);
  }

  .ls-cs__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 0.5rem;
    padding: 1rem 1.1rem 1.05rem;
    background: linear-gradient(to top, rgb(0 0 0 / 0.72) 0%, rgb(0 0 0 / 0.34) 32%, rgb(0 0 0 / 0) 62%);
  }

  .ls-cs__card-title {
    margin: 0;
    color: #fff;
    font-size: 1.25rem;
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.01em;
  }

  .ls-cs__card-title a {
    color: inherit;
    text-decoration: none;
  }

  /* Stretched link: the title covers the whole image, swatches stay above it. */
  .ls-cs__card-title a::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .ls-cs__card-sub {
    margin: 0;
    color: rgb(255 255 255 / 0.82);
    font-size: 0.8125rem;
    line-height: 1.3;
  }

  .ls-cs__swatches {
    position: relative;
    z-index: 2;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.15rem;
  }

  .ls-cs__swatch {
    display: block;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 7px;
    overflow: hidden;
    background: rgb(255 255 255 / 0.12);
    border: 1.5px solid rgb(255 255 255 / 0.85);
    box-shadow: 0 1px 3px rgb(0 0 0 / 0.28);
    transition: transform 0.15s ease;
  }

  a.ls-cs__swatch:hover {
    transform: translateY(-2px) scale(1.06);
  }

  .ls-cs__swatch-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Footer CTA bar */
  .ls-cs__cta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 1.25rem;
    padding: 0.9rem 1.1rem;
    background: var(--ls-cs-card-bg);
    border: 1px solid rgb(0 0 0 / 0.1);
    border-radius: 12px;
  }

  .ls-cs__cta-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 47px;
    height: 47px;
    border-radius: 12px;
    background: color-mix(in srgb, var(--ls-cs-accent) 14%, transparent);
    color: var(--ls-cs-accent);
  }

  .ls-cs__cta-icon svg {
    width: 23px;
    height: 23px;
  }

  .ls-cs__cta-copy {
    min-width: 0;
    flex: 1;
  }

  .ls-cs__cta-title {
    margin: 0;
    color: var(--ls-cs-heading);
    font-size: 0.9375rem;
    font-weight: 700;
  }

  .ls-cs__cta-text {
    margin: 0.15rem 0 0;
    color: var(--ls-cs-muted);
    font-size: 0.8125rem;
    line-height: 1.3;
  }

  .ls-cs__cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    flex-shrink: 0;
    padding: 0.65rem 1.15rem;
    border-radius: 999px;
    background: var(--ls-cs-accent);
    color: #fff;
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    transition: filter 0.15s ease, transform 0.15s ease;
  }

  .ls-cs__cta-btn:hover {
    filter: brightness(0.94);
  }

  .ls-cs__cta-btn svg {
    width: 18px;
    height: 18px;
    transition: transform 0.15s ease;
  }

  .ls-cs__cta-btn:hover svg {
    transform: translateX(2px);
  }

  @media screen and (max-width: 749px) {
    /* Arrows hidden on mobile — cards are swiped directly. */
    .ls-cs__nav {
      display: none;
    }

    .ls-cs__track {
      gap: 0.75rem;
    }

    /* One-and-a-bit cards, with the next peeking in to cue swiping. */
    .ls-cs__card {
      flex-basis: 78%;
      width: 78%;
    }

    .ls-cs__cta {
      flex-wrap: wrap;
      border-radius: 26px;
    }

    .ls-cs__cta-btn {
      width: 100%;
      justify-content: center;
    }
  }

  @media screen and (min-width: 750px) {
    .ls-cs__card-title {
      font-size: 1.375rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "LS Color Swatch",
  "tag": "section",
  "class": "ls-cs-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "max_blocks": 16,
  "settings": [
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "font_picker",
      "id": "font_family",
      "label": "Font",
      "default": "outfit_n4"
    },
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "For your space"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Find your color"
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show carousel arrows",
      "default": true
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "card_width",
      "label": "Max card width",
      "info": "Cards scale with the viewport (min 240px) up to this width.",
      "min": 220,
      "max": 440,
      "step": 10,
      "unit": "px",
      "default": 320
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Card corner radius",
      "min": 0,
      "max": 28,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "header",
      "content": "Sample CTA bar"
    },
    {
      "type": "checkbox",
      "id": "show_cta",
      "label": "Show sample CTA bar",
      "default": true
    },
    {
      "type": "text",
      "id": "cta_title",
      "label": "CTA title",
      "default": "Not sure yet? Order a color sample."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA text",
      "default": "Peel-&-stick samples and pints shipped before you commit to a gallon."
    },
    {
      "type": "text",
      "id": "cta_button_label",
      "label": "Button label",
      "default": "Order samples"
    },
    {
      "type": "url",
      "id": "cta_button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section background",
      "default": "#fafafa"
    },
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Eyebrow",
      "default": "#c13121"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent (button & arrows)",
      "default": "#c13121"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "muted_color",
      "label": "Muted text",
      "default": "#6b7280"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card & CTA background",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "checkbox",
      "id": "use_mobile_padding",
      "label": "Use custom mobile padding",
      "default": false
    },
    {
      "type": "range",
      "id": "padding-block-start-mobile",
      "label": "Mobile top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 32,
      "visible_if": "{{ section.settings.use_mobile_padding }}"
    },
    {
      "type": "range",
      "id": "padding-block-end-mobile",
      "label": "Mobile bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 32,
      "visible_if": "{{ section.settings.use_mobile_padding }}"
    }
  ],
  "blocks": [
    {
      "type": "ls-color-card"
    }
  ],
  "presets": [
    {
      "name": "LS Color Swatch",
      "category": "t:categories.collections",
      "blocks": {
        "card-1": {
          "type": "ls-color-card",
          "settings": { "title": "Whites & Off-Whites", "subtitle": "Chantilly Lace · Simply White" },
          "blocks": {
            "s1": { "type": "ls-color-swatch" },
            "s2": { "type": "ls-color-swatch" },
            "s3": { "type": "ls-color-swatch" }
          },
          "block_order": ["s1", "s2", "s3"]
        },
        "card-2": {
          "type": "ls-color-card",
          "settings": { "title": "Blues & Greens", "subtitle": "Hale Navy · Caldwell Green" },
          "blocks": {
            "s1": { "type": "ls-color-swatch" },
            "s2": { "type": "ls-color-swatch" },
            "s3": { "type": "ls-color-swatch" }
          },
          "block_order": ["s1", "s2", "s3"]
        },
        "card-3": {
          "type": "ls-color-card",
          "settings": { "title": "Bold & Moody", "subtitle": "Black Beauty · Caliente" },
          "blocks": {
            "s1": { "type": "ls-color-swatch" },
            "s2": { "type": "ls-color-swatch" },
            "s3": { "type": "ls-color-swatch" }
          },
          "block_order": ["s1", "s2", "s3"]
        },
        "card-4": {
          "type": "ls-color-card",
          "settings": { "title": "Cabinet & Trim", "subtitle": "Cloud White · Kendall Charcoal" },
          "blocks": {
            "s1": { "type": "ls-color-swatch" },
            "s2": { "type": "ls-color-swatch" },
            "s3": { "type": "ls-color-swatch" }
          },
          "block_order": ["s1", "s2", "s3"]
        }
      },
      "block_order": ["card-1", "card-2", "card-3", "card-4"]
    }
  ]
}
{% endschema %}
