{%- comment -%}
  LS Product Detail
  -----------------
  Self-contained product detail (PDP) scaffold matching the Figma layout:
  breadcrumbs · gallery + trust pills · rating · price/compare/save ·
  sheen/color/size selectors · quantity + add-to-cart · dynamic checkout ·
  frequently-paired cross-sell · spec accordions.

  Reads the live `product` object. Variant selection is resilient: it renders
  whatever options exist (options_with_values) and maps the designated
  "color" option to a dropdown, the "size" option to price cards, everything
  else (e.g. Sheen) to segmented buttons. If those option names aren't present
  it degrades to buttons for every option and still switches variants correctly.
{%- endcomment -%}

{%- liquid
  assign pd_font = section.settings.font_family
  assign pd_font_500 = pd_font | font_modify: 'weight', '500'
  assign pd_font_600 = pd_font | font_modify: 'weight', '600'
  assign pd_font_700 = pd_font | font_modify: 'weight', '700'

  assign has_product = false
  if product != blank and product.id != blank
    assign has_product = true
  endif

  assign current_variant = product.selected_or_first_available_variant
  assign price = current_variant.price
  assign compare = current_variant.compare_at_price
  assign on_sale = false
  if compare != blank and compare > price
    assign on_sale = true
    assign savings = compare | minus: price
  endif

  # The "Price per Gallon" suffix only makes sense when the product is actually
  # sold by the gallon. Detect a gallon among the variants (any option position),
  # falling back to the title for single-variant products sold as one gallon.
  assign has_gallon = false
  for gv in product.variants
    assign gv_title = gv.title | downcase
    if gv_title contains 'gallon'
      assign has_gallon = true
      break
    endif
  endfor
  if has_gallon == false and product.variants.size <= 1
    assign gp_title = product.title | downcase
    if gp_title contains 'gallon'
      assign has_gallon = true
    endif
  endif

  # --- Which option renders as color / size ---
  assign color_name = section.settings.color_option_name | default: 'Color' | downcase
  assign size_name = section.settings.size_option_name | default: 'Size' | downcase
  # Variant options never shown to the consumer (e.g. internal Material ID).
  assign hidden_names = section.settings.hidden_option_names | default: 'Material ID' | downcase | replace: ', ', ',' | split: ','

  # Sheen/grit siblings are modelled the way the live store does it: each finish
  # (or grit) is a separate product, and the whole set shares one
  # productfamily_* collection (e.g. productfamily_rswip = Regal Select Interior,
  # whose members are Flat/Matte/Eggshell/Satin/Semi-Gloss). Find the first such
  # collection this product belongs to; its members are the siblings, rendered
  # directly from the collection (no search needed). Each sibling's finish/grit
  # label is the title after " - " (e.g. "Semi-Gloss N551").
  assign family_prefix = section.settings.family_collection_handle_prefix | default: 'productfamily' | downcase
  assign family_col = null
  for fam_c in product.collections
    if fam_c.handle contains family_prefix
      assign family_col = fam_c
      break
    endif
  endfor
  assign family_current = product.title | split: ' - ' | last | strip

  # Show only when a family collection with 2+ members is found.
  assign family_show = false
  if family_col != blank and family_col.all_products_count > 1
    assign family_show = true
  endif

  # Field label: "Sheen" by default, "Grit" for sanding/abrasive products
  # (matched by product type). Once grit families exist as productfamily_*
  # collections they light up automatically with the right label.
  assign family_label = section.settings.sheen_label | default: 'Sheen'
  assign grit_types = section.settings.grit_product_types | default: 'Sanding' | downcase | replace: ', ', ',' | split: ','
  assign product_type_dc = product.type | downcase | strip
  if product_type_dc != '' and grit_types contains product_type_dc
    assign family_label = section.settings.grit_label | default: 'Grit'
  endif

  # Color picker only applies to products that belong to a color family
  # (i.e. carry at least one colorcollection_* tag).
  assign color_fam_check = section.settings.paint_family_tag_prefix | default: 'colorcollection_' | downcase
  assign color_allowed = false
  for tag in product.tags
    assign tag_dc = tag | downcase
    if tag_dc contains color_fam_check
      assign color_allowed = true
      break
    endif
  endfor

  # --- Color-sample products ---
  # A swatch/sample product declares its own colour family via a
  # color_collection_<fam> tag (never a colorcollection_* tag — those live on
  # paints). Detect it so the PDP can offer "Shop this color in <paint>" links
  # that carry the colour to a full-size paint via ?color=<code>. The code is
  # the leading token of the title (e.g. "OC-150 White Down" -> "OC-150").
  assign swatch_fam_prefix = section.settings.color_family_tag_prefix | default: 'color_collection_' | downcase
  assign is_color_swatch = false
  assign swatch_family = ''
  for tag in product.tags
    assign tag_dc = tag | downcase
    if tag_dc contains swatch_fam_prefix
      assign is_color_swatch = true
      assign swatch_family = tag_dc | remove: swatch_fam_prefix | strip
      break
    endif
  endfor
  assign swatch_code = product.title | split: ' ' | first

  # When enabled (require_color) and the colour selector is shown, a colour (or
  # custom colour/code) is required before checkout — used to disable
  # add-to-cart + dynamic checkout on load (JS keeps it in sync as the shopper
  # picks). Turn off require_color to let shoppers check out without a colour.
  assign color_required = false
  if section.settings.require_color and section.settings.show_color_field and color_allowed
    assign color_required = true
  endif

  # --- Rating: metafield (Shopify Product Reviews shape) or manual setting ---
  assign rating_value = 0
  assign rating_count = 0
  if section.settings.rating_source == 'metafield'
    assign rating_mf = product.metafields.reviews.rating.value
    if rating_mf != blank
      assign rating_value = rating_mf.rating
    endif
    assign rating_count = product.metafields.reviews.rating_count.value | default: 0
  else
    assign rating_value = section.settings.manual_rating
    assign rating_count = section.settings.manual_review_count
  endif
  # Coerce to numbers — review apps/metafields may return strings, which would
  # break the numeric comparisons below (Liquid "comparison ... failed").
  assign rating_value = rating_value | times: 1
  assign rating_count = rating_count | times: 1
  # Display: drop a zero decimal (5.0 -> "5") but keep real fractions (3.5 -> "3.5").
  assign rating_floor = rating_value | floor
  if rating_value == rating_floor
    assign rating_display = rating_floor
  else
    assign rating_display = rating_value
  endif
-%}

{% style %}
  {{ pd_font | font_face: font_display: 'swap' }}
  {{ pd_font_500 | font_face: font_display: 'swap' }}
  {{ pd_font_600 | font_face: font_display: 'swap' }}
  {{ pd_font_700 | font_face: font_display: 'swap' }}

  .ls-pdp-{{ section.id }} {
    --ls-pd-font-family: {{ pd_font.family }}, {{ pd_font.fallback_families }};
    --ls-pd-heading: {{ section.settings.heading_color | default: '#1a1a1a' }};
    --ls-pd-text: {{ section.settings.text_color | default: '#1a1a1a' }};
    --ls-pd-muted: {{ section.settings.muted_color | default: '#989898' }};
    --ls-pd-accent: {{ section.settings.accent_color | default: '#c13121' }};
    --ls-pd-icon-chip: {{ section.settings.icon_chip_background | default: '#ffeae7' }};
    --ls-pd-success: {{ section.settings.success_color | default: '#1e854a' }};
    --ls-pd-surface: {{ section.settings.surface_color | default: '#ffffff' }};
    --ls-pd-tile-bg: {{ section.settings.media_tile_background | default: '#f5f4f2' }};
    --ls-pd-border: {{ section.settings.border_color | default: '#e5e7eb' }};
    --ls-pd-radius: {{ section.settings.corner_radius | default: 16 }}px;
  }
{% endstyle %}

<div
  class="section section--page-width ls-pdp ls-pdp-{{ section.id }} spacing-style"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  {%- unless has_product -%}
    <p class="ls-pdp__empty">This section renders on a product page. Preview a product to see the layout.</p>
  {%- else -%}

    {%- comment -%} ---------------- Breadcrumbs ---------------- {%- endcomment -%}
    {%- if section.settings.show_breadcrumbs -%}
      {%- assign crumb_collection = collection | default: product.collections.first -%}
      <nav class="ls-pdp__crumbs" aria-label="Breadcrumb">
        <a href="{{ routes.root_url }}">Home</a>
        <span aria-hidden="true">/</span>
        {%- if crumb_collection.url != blank -%}
          <a href="{{ crumb_collection.url }}">{{ crumb_collection.title }}</a>
          <span aria-hidden="true">/</span>
        {%- endif -%}
        <span class="ls-pdp__crumbs-current" aria-current="page">{{ product.title }}</span>
      </nav>
    {%- endif -%}

    <div class="ls-pdp__grid">
      {%- comment -%} ================= MEDIA ================= {%- endcomment -%}
      <div class="ls-pdp__media-col">
        <div class="ls-pdp__gallery">
          <div class="ls-pdp__stage" data-stage>
            {%- if product.media.size > 0 -%}
              {%- for media in product.media -%}
                <img
                  class="ls-pdp__stage-img{% if forloop.first %} is-active{% endif %}"
                  src="{{ media.preview_image | image_url: width: 1200 }}"
                  srcset="{{ media.preview_image | image_url: width: 600 }} 600w, {{ media.preview_image | image_url: width: 900 }} 900w, {{ media.preview_image | image_url: width: 1200 }} 1200w"
                  sizes="(min-width: 750px) 48vw, 92vw"
                  alt="{{ media.preview_image.alt | default: product.title | escape }}"
                  width="{{ media.preview_image.width }}"
                  height="{{ media.preview_image.height }}"
                  loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                  data-media-id="{{ media.id }}"
                  data-stage-slide="{{ forloop.index0 }}"
                  {% unless forloop.first %}hidden{% endunless %}
                >
              {%- endfor -%}
            {%- else -%}
              <div class="ls-pdp__stage-img is-active ls-pdp__stage-img--placeholder">
                {{ 'product-1' | placeholder_svg_tag: 'placeholder-image' }}
              </div>
            {%- endif -%}

            {%- if product.media.size > 1 -%}
              <button type="button" class="ls-pdp__nav ls-pdp__nav--prev" data-stage-prev aria-label="Previous image">
                <svg viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M12 5l-5 5 5 5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </button>
              <button type="button" class="ls-pdp__nav ls-pdp__nav--next" data-stage-next aria-label="Next image">
                <svg viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M8 5l5 5-5 5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </button>
            {%- endif -%}
          </div>

          {%- if product.media.size > 1 -%}
            <div class="ls-pdp__thumbs" data-thumbs role="list">
              {%- for media in product.media limit: 8 -%}
                <button
                  type="button"
                  class="ls-pdp__thumb{% if forloop.first %} is-active{% endif %}"
                  data-thumb="{{ forloop.index0 }}"
                  aria-label="View image {{ forloop.index }}"
                >
                  {{ media.preview_image | image_url: width: 160 | image_tag: widths: '80, 160', loading: 'lazy', alt: media.preview_image.alt | default: product.title }}
                </button>
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>

        {%- comment -%} Trust / assurance pills under the gallery {%- endcomment -%}
        {%- assign assurance_blocks = section.blocks | where: 'type', 'assurance' -%}
        {%- if assurance_blocks.size > 0 -%}
          <ul class="ls-pdp__assurances" role="list">
            {%- for block in assurance_blocks -%}
              <li class="ls-pdp__assurance" {{ block.shopify_attributes }}>
                <span class="ls-pdp__assurance-icon" aria-hidden="true">
                  {%- render 'ls-pdp-icon', name: block.settings.icon -%}
                </span>
                <span class="ls-pdp__assurance-text">
                  <span class="ls-pdp__assurance-title">{{ block.settings.title }}</span>
                  {%- if block.settings.subtitle != blank -%}
                    <span class="ls-pdp__assurance-sub">{{ block.settings.subtitle }}</span>
                  {%- endif -%}
                </span>
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>

      {%- comment -%} ================= DETAILS ================= {%- endcomment -%}
      <div class="ls-pdp__details">
        {%- comment -%} Ships nationwide {%- endcomment -%}
        {%- if section.settings.ships_text != blank -%}
          <p class="ls-pdp__ships" role="note">
            <svg class="ls-pdp__ships-icon" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M1.5 5.5h9v7h-9zM10.5 8h3l2.5 2.5v2h-5.5z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/><circle cx="5" cy="14" r="1.6" stroke="currentColor" stroke-width="1.3"/><circle cx="13.5" cy="14" r="1.6" stroke="currentColor" stroke-width="1.3"/></svg>
            <span>{{ section.settings.ships_text }}</span>
          </p>
        {%- endif -%}

        {%- comment -%} Rating {%- endcomment -%}
        {%- if section.settings.show_rating and rating_value != blank and rating_value > 0 -%}
          <div class="ls-pdp__rating">
            <span class="ls-pdp__stars" role="img" aria-label="Rated {{ rating_display }} out of 5">
              {%- render 'ls-stars', rating: rating_value, prefix: 'ls-pdp' -%}
            </span>
            <span class="ls-pdp__rating-text">
              Rated {{ rating_display }}/5
              {%- if rating_count != blank and rating_count > 0 %} from {{ rating_count }} verified reviews{% endif -%}
            </span>
          </div>
        {%- endif -%}

        <h1 class="ls-pdp__title">{{ product.title }}</h1>

        {%- comment -%} Price {%- endcomment -%}
        <div class="ls-pdp__price-block">
          <div class="ls-pdp__price-row">
            <span class="ls-pdp__price" data-price>{{ price | money }}</span>
            {%- if on_sale -%}
              <s class="ls-pdp__compare" data-compare>{{ compare | money }}</s>
              <span class="ls-pdp__save" data-save>Save {{ savings | money_without_trailing_zeros }}</span>
            {%- else -%}
              <s class="ls-pdp__compare" data-compare hidden></s>
              <span class="ls-pdp__save" data-save hidden></span>
            {%- endif -%}
          </div>
          <div class="ls-pdp__price-meta">
            {%- if section.settings.show_stock -%}
              <span class="ls-pdp__stock" data-stock>
                <span class="ls-pdp__stock-dot" aria-hidden="true"></span>
                <span data-stock-label>
                  {%- if current_variant.available -%}{{ section.settings.in_stock_text }}{%- else -%}{{ section.settings.out_of_stock_text }}{%- endif -%}
                </span>
              </span>
            {%- endif -%}
            {%- if section.settings.price_suffix != blank and has_gallon -%}
              <span class="ls-pdp__price-suffix">{{ section.settings.price_suffix }}</span>
            {%- endif -%}
          </div>
        </div>

        {%- comment -%} =============== Variant form =============== {%- endcomment -%}
        {%- assign pd_form_id = 'ls-pdp-form-' | append: section.id -%}
        <product-form-component
          data-section-id="{{ section.id }}"
          data-product-id="{{ product.id }}"
          on:submit="/handleSubmit"
          class="ls-pdp__form"
        >
          <div class="visually-hidden" role="status" aria-live="assertive" aria-atomic="true" ref="liveRegion"></div>
          {%- form 'product', product, id: pd_form_id, novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
            <input
              type="hidden"
              name="id"
              ref="variantId"
              data-variant-id
              value="{{ current_variant.id }}"
              {% unless current_variant.available %}disabled{% endunless %}
            >

            <div class="ls-pdp__selectors" data-selectors>
              {%- comment -%}
                Sheen / grit — sibling products sharing a productfamily_*
                collection. Rendered server-side straight from the collection's
                members (each links to that sibling's product page); clicks are
                intercepted for an AJAX swap that preserves the shopper's state.
              {%- endcomment -%}
              {%- if section.settings.show_sheen and family_show -%}
                <div
                  class="ls-pdp__selector ls-pdp__selector--sheen"
                  data-sheen
                  data-current-url="{{ product.url }}"
                >
                  <div class="ls-pdp__selector-head">
                    <span class="ls-pdp__selector-label">Select {{ family_label }}</span>
                    <span class="ls-pdp__selector-value" data-sheen-selected>{{ family_current }}</span>
                  </div>
                  <div class="ls-pdp__pills" data-sheen-pills>
                    {%- comment -%} Active sheen (this product) renders first so it leads the row. {%- endcomment -%}
                    <a class="ls-pdp__pill is-active" href="{{ product.url }}" aria-current="true">{{ family_current }}</a>
                    {%- for sib in family_col.products -%}
                      {%- if sib.id == product.id -%}{%- continue -%}{%- endif -%}
                      {%- unless sib.available -%}{%- continue -%}{%- endunless -%}
                      {%- assign sib_label = sib.title | split: ' - ' | last | strip -%}
                      <a class="ls-pdp__pill" href="{{ sib.url }}">{{ sib_label }}</a>
                    {%- endfor -%}
                  </div>
                </div>
              {%- endif -%}

              {%- comment -%}
                Pass 1 — variant options that are NOT Size or Color (e.g. Finish /
                Sheen) render as pills. Single-value options, hidden options (e.g.
                Material ID), and Color are skipped. Variant matching in JS keys
                only off the visible selections, so skipped options don't block it.
                Color is a line-item property here, rendered in the combobox below.
              {%- endcomment -%}
              {%- for option in product.options_with_values -%}
                {%- assign opt_name_dc = option.name | downcase -%}
                {%- if option.values.size <= 1 -%}{%- continue -%}{%- endif -%}
                {%- if opt_name_dc == size_name or opt_name_dc == color_name -%}{%- continue -%}{%- endif -%}
                {%- if hidden_names contains opt_name_dc -%}{%- continue -%}{%- endif -%}
                <div class="ls-pdp__selector ls-pdp__selector--buttons" data-option-position="{{ option.position }}">
                  <div class="ls-pdp__selector-head">
                    <span class="ls-pdp__selector-label">Select {{ option.name }}</span>
                    <span class="ls-pdp__selector-value" data-option-selected>{{ option.selected_value }}</span>
                  </div>
                  <div class="ls-pdp__pills" role="radiogroup" aria-label="Select {{ option.name }}">
                    {%- for value in option.values -%}
                      <button
                        type="button"
                        class="ls-pdp__pill{% if value.name == option.selected_value %} is-active{% endif %}"
                        data-option-input
                        data-value="{{ value.name | escape }}"
                        role="radio"
                        aria-checked="{% if value.name == option.selected_value %}true{% else %}false{% endif %}"
                      >
                        {{ value.name }}
                      </button>
                    {%- endfor -%}
                  </div>
                </div>
              {%- endfor -%}

              {%- comment -%}
                Color — searchable line-item property (not a variant). Options are
                the colour-swatch products from the source collection whose family
                tag (color_family_tag_prefix + code) is one of the families this
                paint supports (its paint_family_tag_prefix tags). The chosen value
                is written to properties[<color_property_key>] and submitted with
                add-to-cart. NOTE: Liquid renders at most ~50 collection products
                in one pass — for the full BM fandeck this list must move to
                search-as-you-type (see notes).
              {%- endcomment -%}
              {%- if section.settings.show_color_field and color_allowed -%}
                {%- liquid
                  assign fam_prefix = section.settings.paint_family_tag_prefix | default: 'colorcollection_' | downcase
                  assign color_fam_prefix = section.settings.color_family_tag_prefix | default: 'color_collection_' | downcase
                  assign color_prop_key = section.settings.color_property_key | default: 'Color'
                  assign color_source = section.settings.color_source_collection
                  assign color_limit = section.settings.color_options_limit | default: 50
                  assign color_mode = section.settings.color_source_mode | default: 'by_family_tags'
                  assign fam_col_prefix = section.settings.family_collection_prefix | downcase
                  assign fam_col_suffix = section.settings.family_collection_suffix | downcase

                  # Families this paint supports, from its colorcollection_* tags.
                  assign supported = '|'
                  for tag in product.tags
                    assign t = tag | downcase
                    if t contains fam_prefix
                      assign fam = t | remove: fam_prefix | strip
                      assign supported = supported | append: fam | append: '|'
                    endif
                  endfor
                -%}
                <div class="ls-pdp__selector ls-pdp__selector--color">
                  <div class="ls-pdp__selector-head">
                    <span class="ls-pdp__selector-label">Select {{ section.settings.color_label | default: 'Color' }}</span>
                    <span class="ls-pdp__selector-value" data-color-selected></span>
                  </div>

                  <input type="hidden" name="properties[{{ color_prop_key }}]" data-color-value value="">

                  <div class="ls-pdp__color-row">
                  <div class="ls-pdp__combo" data-combo data-search-url="{{ routes.search_url }}" data-families="{{ supported }}" data-min-chars="2">
                    <button type="button" class="ls-pdp__combo-toggle" data-combo-toggle aria-haspopup="listbox" aria-expanded="false">
                      <span class="ls-pdp__combo-chip" data-combo-chip aria-hidden="true"></span>
                      <span class="ls-pdp__combo-textwrap">
                        <span class="ls-pdp__combo-name" data-combo-label>{{ section.settings.color_placeholder | default: 'Search & select a color' }}</span>
                        <span class="ls-pdp__combo-code" data-combo-code hidden></span>
                      </span>
                      <svg class="ls-pdp__combo-caret" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M6 8l4 4 4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </button>
                    <div class="ls-pdp__combo-panel" data-combo-panel hidden>
                      <div class="ls-pdp__combo-search">
                        <input type="text" class="ls-pdp__combo-input" data-combo-input placeholder="{{ section.settings.color_search_placeholder | default: 'Type a color name or code…' }}" autocomplete="off">
                      </div>
                      <ul class="ls-pdp__combo-list" role="listbox" data-combo-list>
                        {%- assign rendered = 0 -%}
                        {%- assign seen = '|' -%}
                        {%- if color_mode == 'by_family_tags' -%}
                          {%- comment -%}
                            Use the paint's own family tags: for each colorcollection_<fam>
                            tag, pull the matching family collection (handle =
                            prefix + <fam> + suffix, defaults to the bare family code
                            e.g. "oc") and list its color products.
                          {%- endcomment -%}
                          {%- for tag in product.tags -%}
                            {%- if rendered >= color_limit -%}{%- break -%}{%- endif -%}
                            {%- assign t = tag | downcase -%}
                            {%- unless t contains fam_prefix -%}{%- continue -%}{%- endunless -%}
                            {%- assign fam = t | remove: fam_prefix | strip -%}
                            {%- assign fam_handle = fam_col_prefix | append: fam | append: fam_col_suffix -%}
                            {%- assign fam_col = collections[fam_handle] -%}
                            {%- for cprod in fam_col.products -%}
                              {%- if rendered >= color_limit -%}{%- break -%}{%- endif -%}
                              {%- assign idkey = '|' | append: cprod.id | append: '|' -%}
                              {%- unless seen contains idkey -%}
                                {%- assign seen = seen | append: cprod.id | append: '|' -%}
                                {%- render 'ls-pdp-color-option', cprod: cprod -%}
                                {%- assign rendered = rendered | plus: 1 -%}
                              {%- endunless -%}
                            {%- endfor -%}
                          {%- endfor -%}
                        {%- elsif color_source != blank -%}
                          {%- comment -%} Single collection of all colors, filtered by family tag. {%- endcomment -%}
                          {%- for cprod in color_source.products -%}
                            {%- if rendered >= color_limit -%}{%- break -%}{%- endif -%}
                            {%- assign cfam = '' -%}
                            {%- for tag in cprod.tags -%}
                              {%- assign ct = tag | downcase -%}
                              {%- if ct contains color_fam_prefix -%}{%- assign cfam = ct | remove: color_fam_prefix | strip -%}{%- endif -%}
                            {%- endfor -%}
                            {%- assign needle = '|' | append: cfam | append: '|' -%}
                            {%- if supported == '|' or cfam == '' or supported contains needle -%}
                              {%- render 'ls-pdp-color-option', cprod: cprod -%}
                              {%- assign rendered = rendered | plus: 1 -%}
                            {%- endif -%}
                          {%- endfor -%}
                        {%- endif -%}

                        {%- if rendered == 0 -%}
                          <li class="ls-pdp__combo-note">Type a color name or code to search all colors (e.g. OC-150).</li>
                        {%- endif -%}
                        <li class="ls-pdp__combo-empty" data-combo-empty hidden>No colors match.</li>
                      </ul>
                      {%- if rendered >= color_limit -%}
                        <div class="ls-pdp__combo-foot" data-combo-foot>Showing the first {{ rendered }} — type to search all colors.</div>
                      {%- endif -%}
                    </div>
                  </div>

                    {%- if section.settings.show_custom_color -%}
                      <button type="button" class="ls-pdp__custom-toggle" data-custom-toggle aria-expanded="false">
                        <span class="ls-pdp__custom-toggle-icon" aria-hidden="true">+</span>
                        {{ section.settings.custom_color_toggle_text | default: 'Enter custom color' }}
                      </button>
                      <label class="ls-pdp__custom-field" data-custom-field>
                        <span class="ls-pdp__custom-icon" aria-hidden="true">
                          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M13 8H8V13C8 13.2652 7.89464 13.5196 7.70711 13.7071C7.51957 13.8946 7.26522 14 7 14C6.73478 14 6.48043 13.8946 6.29289 13.7071C6.10536 13.5196 6 13.2652 6 13V8H1C0.734784 8 0.48043 7.89464 0.292893 7.70711C0.105357 7.51957 0 7.26522 0 7C0 6.73478 0.105357 6.48043 0.292893 6.29289C0.48043 6.10536 0.734784 6 1 6H6V1C6 0.734784 6.10536 0.480429 6.29289 0.292893C6.48043 0.105357 6.73478 0 7 0C7.26522 0 7.51957 0.105357 7.70711 0.292893C7.89464 0.480429 8 0.734784 8 1V6H13C13.2652 6 13.5196 6.10536 13.7071 6.29289C13.8946 6.48043 14 6.73478 14 7C14 7.26522 13.8946 7.51957 13.7071 7.70711C13.5196 7.89464 13.2652 8 13 8Z" fill="currentColor"/></svg>
                        </span>
                        <input
                          type="text"
                          name="properties[{{ section.settings.custom_color_property_key | default: 'Custom Color' }}]"
                          class="ls-pdp__custom-input"
                          placeholder="{{ section.settings.custom_color_label | default: 'Custom color / code' }}"
                          aria-label="{{ section.settings.custom_color_label | default: 'Custom color / code' | escape }}"
                        >
                      </label>
                    {%- endif -%}
                  </div>

                  {%- if section.settings.show_additional_details -%}
                    <div class="ls-pdp__prop-field">
                      <label class="ls-pdp__selector-label" for="ls-pdp-notes-{{ section.id }}">{{ section.settings.additional_details_label | default: 'Additional details' }}</label>
                      <textarea
                        id="ls-pdp-notes-{{ section.id }}"
                        name="properties[{{ section.settings.additional_details_property_key | default: 'Additional Details' }}]"
                        class="ls-pdp__textarea"
                        rows="2"
                        placeholder="{{ section.settings.additional_details_placeholder | default: 'Anything the mixing team should know…' }}"
                      ></textarea>
                    </div>
                  {%- endif -%}
                </div>

                {%- if section.settings.color_disclaimer_text != blank -%}
                  <p class="ls-pdp__color-disclaimer" role="note">
                    <svg class="ls-pdp__color-disclaimer-icon" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M10 6.5v4M10 13.5h.01M10 1.5 1.5 16.5h17L10 1.5Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    <span>{{ section.settings.color_disclaimer_text }}</span>
                  </p>
                {%- endif -%}
              {%- endif -%}

              {%- comment -%} Pass 2 — Size renders as price cards, after Color (Figma order). {%- endcomment -%}
              {%- for option in product.options_with_values -%}
                {%- assign opt_name_dc = option.name | downcase -%}
                {%- if option.values.size <= 1 -%}{%- continue -%}{%- endif -%}
                {%- unless opt_name_dc == size_name -%}{%- continue -%}{%- endunless -%}
                <div class="ls-pdp__selector ls-pdp__selector--cards" data-option-position="{{ option.position }}">
                  <div class="ls-pdp__selector-head">
                    <span class="ls-pdp__selector-label">Select {{ option.name }}</span>
                    <span class="ls-pdp__selector-value" data-option-selected>{{ option.selected_value }}</span>
                  </div>
                  <div class="ls-pdp__size-cards" role="radiogroup" aria-label="Select {{ option.name }}">
                    {%- comment -%}
                      Order size cards by volume (ascending) so they always read
                      Quart · Gallon · 5 Gallon, regardless of the variant option order.
                      Build "sortkey:index" pairs — sortkey is volume in half-quart
                      integers (Quart 2 · Gallon 8 · Pint 1), offset to a fixed width so
                      a plain lexical sort orders them numerically — then iterate sorted.
                    {%- endcomment -%}
                    {%- assign size_order_list = '' -%}
                    {%- for v in option.values -%}
                      {%- liquid
                        assign v_dc = v.name | downcase
                        assign v_num = v.name | split: ' ' | first | times: 1
                        if v_num == 0
                          assign v_num = 1
                        endif
                        assign v_hq = 0
                        if v_dc contains 'gallon' or v_dc contains 'gal'
                          assign v_hq = 8
                        elsif v_dc contains 'quart' or v_dc contains 'qt'
                          assign v_hq = 2
                        elsif v_dc contains 'pint'
                          assign v_hq = 1
                        endif
                        assign v_key = v_num | times: v_hq | plus: 1000000
                        assign size_order_list = size_order_list | append: v_key | append: ':' | append: forloop.index0 | append: '|'
                      -%}
                    {%- endfor -%}
                    {%- assign size_order = size_order_list | split: '|' | sort -%}
                    {%- for size_entry in size_order -%}
                      {%- assign size_i = size_entry | split: ':' | last | times: 1 -%}
                      {%- assign value = option.values[size_i] -%}
                      {%- liquid
                        # `value.variant` is the variant this size combines with, given the
                        # other currently-selected options — used for the card's price.
                        # It only resolves when the value uniquely identifies a variant, so
                        # with extra variant options (e.g. a hidden Material ID) it's nil for
                        # every size except the selected one. Fall back to the first variant
                        # that carries this size value so all cards show a price.
                        assign card_variant = value.variant
                        unless card_variant
                          assign size_idx = option.position | minus: 1
                          for v in product.variants
                            if v.options[size_idx] == value.name
                              assign card_variant = v
                              break
                            endif
                          endfor
                        endunless
                        assign card_badge = card_variant.metafields.custom.badge.value
                        # Fall back to the configured Popular / Best value pills,
                        # matched by size name (a variant metafield badge wins).
                        if card_badge == blank
                          assign vname_dc = value.name | downcase | strip
                          assign pop_dc = section.settings.popular_size | downcase | strip
                          assign bv_dc = section.settings.best_value_size | downcase | strip
                          if pop_dc != blank and vname_dc == pop_dc
                            assign card_badge = section.settings.popular_label | default: 'Popular'
                          elsif bv_dc != blank and vname_dc == bv_dc
                            assign card_badge = section.settings.best_value_label | default: 'Best value'
                          endif
                        endif

                        # Original (compare-at) price and the shopper's savings on
                        # this size when it's on sale.
                        assign card_compare = card_variant.compare_at_price
                        assign card_on_sale = false
                        assign card_savings = 0
                        if card_compare != blank and card_compare > card_variant.price
                          assign card_on_sale = true
                          assign card_savings = card_compare | minus: card_variant.price
                        endif
                      -%}
                      <button
                        type="button"
                        class="ls-pdp__size-card{% if value.name == option.selected_value %} is-active{% endif %}"
                        data-option-input
                        data-value="{{ value.name | escape }}"
                        data-variant-id="{{ card_variant.id }}"
                        role="radio"
                        aria-checked="{% if value.name == option.selected_value %}true{% else %}false{% endif %}"
                      >
                        {%- if card_badge != blank -%}
                          <span class="ls-pdp__size-flag">{{ card_badge }}</span>
                        {%- endif -%}
                        <span class="ls-pdp__size-name">{{ value.name }}</span>
                        {%- if card_variant.price != blank -%}
                          <span class="ls-pdp__size-pricing">
                            <span class="ls-pdp__size-price">{{ card_variant.price | money }}</span>
                            {%- if card_on_sale -%}
                              <s class="ls-pdp__size-compare">{{ card_compare | money }}</s>
                            {%- endif -%}
                          </span>
                          {%- if card_on_sale -%}
                            <span class="ls-pdp__size-unit">Save {{ card_savings | money }}</span>
                          {%- endif -%}
                        {%- endif -%}
                      </button>
                    {%- endfor -%}
                  </div>
                </div>
              {%- endfor -%}
            </div>

            {%- comment -%} Quantity + add to cart {%- endcomment -%}
            <div class="ls-pdp__buy">
              <div class="ls-pdp__qty" data-qty>
                <button type="button" class="ls-pdp__qty-btn" data-qty-minus aria-label="Decrease quantity">&minus;</button>
                <input
                  class="ls-pdp__qty-input"
                  type="number"
                  name="quantity"
                  data-qty-input
                  value="1"
                  min="1"
                  inputmode="numeric"
                  aria-label="Quantity"
                >
                <button type="button" class="ls-pdp__qty-btn" data-qty-plus aria-label="Increase quantity">+</button>
              </div>

              <button
                type="submit"
                name="add"
                ref="addToCartButton"
                class="ls-pdp__atc"
                data-atc
                {% if current_variant.available == false or color_required %}disabled{% endif %}
              >
                <svg viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M3 3h2l1.2 9.2a1 1 0 0 0 1 .8h7.6a1 1 0 0 0 1-.8L18 6H6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><circle cx="8" cy="17" r="1.2" fill="currentColor"/><circle cx="15" cy="17" r="1.2" fill="currentColor"/></svg>
                <span data-atc-label>
                  {%- if current_variant.available == false -%}
                    {{ section.settings.sold_out_text }}
                  {%- elsif color_required -%}
                    {{ section.settings.color_required_text | default: 'Select a color to continue' }}
                  {%- else -%}
                    {{ section.settings.add_to_cart_text }} &mdash; <span data-atc-price>{{ price | money }}</span>
                  {%- endif -%}
                </span>
              </button>
            </div>

            {%- if section.settings.show_dynamic_checkout -%}
              <div class="ls-pdp__dynamic{% if color_required %} ls-pdp__dynamic--disabled{% endif %}" aria-disabled="{% if color_required %}true{% else %}false{% endif %}">{{ form | payment_button }}</div>
            {%- endif -%}
          {%- endform -%}
        </product-form-component>

        {%- if section.settings.secure_note != blank -%}
          <p class="ls-pdp__secure">
            <svg viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M5 9V7a5 5 0 0 1 10 0v2" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/><rect x="4" y="9" width="12" height="8" rx="2" stroke="currentColor" stroke-width="1.4"/></svg>
            {{ section.settings.secure_note }}
          </p>
        {%- endif -%}

        {%- comment -%}
          =============== Shop this color in (color-sample products) ===============
          On a swatch/sample PDP, offer the same colour in every full-size paint
          line that supports it. Auto-discovered: loop the store's paint-line
          collections (handle contains the productfamily prefix), keep those with
          at least one product tagged for this swatch's family (colorcollection_<fam>),
          and link to that line's first supporting product with ?color=<code> so
          the paint PDP auto-selects the colour. No merchant setup required.
        {%- endcomment -%}
        {%- if is_color_swatch and swatch_family != blank -%}
          {%- assign shop_color_tag = section.settings.paint_family_tag_prefix | default: 'colorcollection_' | downcase | append: swatch_family -%}
          {%- assign shop_color_seen = '|' -%}
          {%- capture shop_color_html -%}
            {%- for c in collections -%}
              {%- unless c.handle contains family_prefix -%}{%- continue -%}{%- endunless -%}
              {%- assign rep = null -%}
              {%- for cp in c.products -%}
                {%- for ptag in cp.tags -%}
                  {%- assign ptag_dc = ptag | downcase -%}
                  {%- if ptag_dc == shop_color_tag -%}{%- assign rep = cp -%}{%- break -%}{%- endif -%}
                {%- endfor -%}
                {%- if rep -%}{%- break -%}{%- endif -%}
              {%- endfor -%}
              {%- if rep -%}
                {%- assign ckey = '|' | append: c.id | append: '|' -%}
                {%- unless shop_color_seen contains ckey -%}
                  {%- assign shop_color_seen = shop_color_seen | append: c.id | append: '|' -%}
                  <a class="ls-pdp__shop-color-link" href="{{ rep.url }}?color={{ swatch_code | url_encode }}">
                    <span class="ls-pdp__shop-color-name">{{ c.title }}</span>
                    <span class="ls-pdp__shop-color-price">{{ rep.price_min | money }}{% if rep.price_varies %}+{% endif %}</span>
                    <svg class="ls-pdp__shop-color-arrow" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M8 5l5 5-5 5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </a>
                {%- endunless -%}
              {%- endif -%}
            {%- endfor -%}
          {%- endcapture -%}
          {%- if shop_color_html contains 'ls-pdp__shop-color-link' -%}
            <div class="ls-pdp__shop-color" data-shopcolor data-shopcolor-page-size="3">
              <div class="ls-pdp__shop-color-headrow">
                <span class="ls-pdp__shop-color-head">{{ section.settings.shop_color_heading | default: 'Shop this color in' }}</span>
                <div class="ls-pdp__shop-color-nav" data-shopcolor-nav hidden>
                  <button type="button" class="ls-pdp__shop-color-arrow-btn" data-shopcolor-prev aria-label="Previous">
                    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M15 5l-7 7 7 7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </button>
                  <button type="button" class="ls-pdp__shop-color-arrow-btn" data-shopcolor-next aria-label="Next">
                    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M9 5l7 7-7 7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </button>
                </div>
              </div>
              <div class="ls-pdp__shop-color-list" data-shopcolor-list>{{ shop_color_html }}</div>
            </div>
          {%- endif -%}
        {%- endif -%}

        {%- comment -%}
          =============== Frequently paired ===============
          Source priority (highest first):
            1. Manual `paired_product` blocks — explicit merchant override.
            2. Complementary products curated in the Search & Discovery app,
               read straight from the product metafield and rendered server-side
               (no fetch, no layout shift).
            3. Shopify Product Recommendations API (client-side fallback):
               complementary intent first, then algorithmic related.
          Tiers 2 and 3 only apply when paired_source = 'recommendations'. See
          the ls-frequently-paired section + the "Frequently paired" script below.
        {%- endcomment -%}
        {%- assign paired_blocks = section.blocks | where: 'type', 'paired_product' -%}
        {%- assign paired_limit = section.settings.paired_limit | default: 6 -%}
        {%- comment -%}
          Optional hand-picked product, shown alongside the API/curated list (doesn't replace it).
          If a "pinned collection" is set, it only shows when THIS product is in that collection.
        {%- endcomment -%}
        {%- assign paired_pinned = section.settings.paired_pinned_product -%}
        {%- assign paired_pin_gate = section.settings.paired_pinned_collection -%}
        {%- if paired_pinned != blank and paired_pin_gate != blank -%}
          {%- assign paired_pin_in = false -%}
          {%- for paired_pc in product.collections -%}
            {%- if paired_pc.id == paired_pin_gate.id -%}
              {%- assign paired_pin_in = true -%}
              {%- break -%}
            {%- endif -%}
          {%- endfor -%}
          {%- unless paired_pin_in -%}
            {%- assign paired_pinned = blank -%}
          {%- endunless -%}
        {%- endif -%}
        {%- assign paired_reco = false -%}
        {%- if paired_blocks.size == 0 and section.settings.paired_source == 'recommendations' -%}
          {%- assign paired_reco = true -%}
        {%- endif -%}

        {%- comment -%} Tier 2: curated complementary products (Search & Discovery metafield). {%- endcomment -%}
        {%- assign complementary = '' -%}
        {%- assign complementary_count = 0 -%}
        {%- if paired_reco -%}
          {%- assign complementary = product.metafields.shopify--discovery--product_recommendation.complementary_products.value -%}
          {%- if complementary != blank -%}
            {%- assign complementary_count = complementary | size -%}
          {%- endif -%}
        {%- endif -%}

        {%- comment -%} Tier 3: fetch from the recommendations API only when tiers 1 and 2 are empty. {%- endcomment -%}
        {%- assign paired_dynamic = false -%}
        {%- if paired_reco and complementary_count == 0 -%}
          {%- assign paired_dynamic = true -%}
        {%- endif -%}

        {%- if paired_blocks.size > 0 or complementary_count > 0 or paired_dynamic or paired_pinned != blank -%}
          {%- assign paired_reco_section = section.settings.paired_section_id | default: 'ls-frequently-paired' -%}
          {%- comment -%} SSR count (manual blocks or curated complementary); JS recounts for the dynamic tier. {%- endcomment -%}
          {%- assign paired_static_count = paired_blocks.size | plus: complementary_count -%}
          {%- if paired_pinned != blank -%}
            {%- assign paired_static_count = paired_static_count | plus: 1 -%}
          {%- endif -%}
          <div
            class="ls-pdp__paired"
            data-paired
            {% if paired_dynamic %}
              data-paired-dynamic
              data-reco-url="{{ routes.product_recommendations_url }}?section_id={{ paired_reco_section }}&product_id={{ product.id }}&limit={{ paired_limit }}"
            {% endif %}
          >
            <div class="ls-pdp__paired-head">
              <h2 class="ls-pdp__paired-title">
                {{ section.settings.paired_heading }}
                <span class="ls-pdp__paired-count" data-paired-count{% if paired_dynamic %} hidden{% endif %}>{{ paired_static_count }}</span>
              </h2>
              <div class="ls-pdp__paired-nav" data-paired-nav{% unless paired_static_count > 1 %} hidden{% endunless %}>
                <button type="button" class="ls-pdp__paired-arrow" data-paired-prev aria-label="Previous">
                  <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M15 5l-7 7 7 7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </button>
                <button type="button" class="ls-pdp__paired-arrow" data-paired-next aria-label="Next">
                  <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M9 5l7 7-7 7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </button>
              </div>
            </div>
            <div class="ls-pdp__paired-track" data-paired-track>
              {%- comment -%} Pinned product first — kept across the dynamic refresh by the JS below. {%- endcomment -%}
              {%- if paired_pinned != blank -%}
                {%- capture paired_pinned_attrs -%}data-paired-pinned data-paired-id="{{ paired_pinned.id }}"{%- endcapture -%}
                {%- render 'ls-pdp-paired-card',
                  card_product: paired_pinned,
                  quick_add_text: section.settings.quick_add_text,
                  sold_out_text: section.settings.sold_out_text,
                  card_attributes: paired_pinned_attrs
                -%}
              {%- endif -%}
              {%- if paired_dynamic -%}
                {%- comment -%} Filled by JS; skeleton avoids layout shift while fetching. {%- endcomment -%}
                <div class="ls-pdp__paired-skeleton" data-paired-skeleton aria-hidden="true"></div>
              {%- elsif complementary_count > 0 -%}
                {%- for card_product in complementary limit: paired_limit -%}
                  {%- if paired_pinned != blank and card_product.id == paired_pinned.id -%}{%- continue -%}{%- endif -%}
                  {%- render 'ls-pdp-paired-card',
                    card_product: card_product,
                    quick_add_text: section.settings.quick_add_text,
                    sold_out_text: section.settings.sold_out_text
                  -%}
                {%- endfor -%}
              {%- else -%}
                {%- for block in paired_blocks -%}
                  {%- if paired_pinned != blank and block.settings.product.id == paired_pinned.id -%}{%- continue -%}{%- endif -%}
                  {%- render 'ls-pdp-paired-card',
                    card_product: block.settings.product,
                    title_override: block.settings.title_override,
                    quick_add_text: section.settings.quick_add_text,
                    sold_out_text: section.settings.sold_out_text,
                    card_attributes: block.shopify_attributes
                  -%}
                {%- endfor -%}
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}

        {%- comment -%}
          =============== Accordions (from description) ===============
          Accordions are derived from the product description at render time —
          one panel per heading section, in the order they appear — so a product
          only shows the panels it actually has content for (Details, Features,
          Data Sheets, Coverage, Technical data, …). No per-block setup: the
          description's own "<tag>Heading</tag>" structure drives the whole list.

          A section is skipped when its heading or its body is empty, when the
          heading is in the merchant's exclude list, and trailing <gtin> barcode
          tags are cut off. If nothing qualifies, the wrapper isn't rendered.
        {%- endcomment -%}
        {%- liquid
          assign acc_tag = section.settings.description_heading_tag | default: 'h2'
          assign acc_open = '<' | append: acc_tag
          assign acc_close = '</' | append: acc_tag | append: '>'
          assign acc_exclude = section.settings.accordion_exclude_headings | default: '' | downcase | replace: ', ', ',' | split: ','
          assign acc_first_open = section.settings.accordions_first_open
          # Drop trailing <gtin> barcodes, then break the description into
          # heading-led sections. Chunk 0 is any preamble before the first
          # heading — skipped.
          assign acc_desc = product.description | split: '<gtin' | first
          assign acc_chunks = acc_desc | split: acc_open
        -%}
        {%- capture accordions_html -%}
          {%- assign acc_rendered = 0 -%}
          {%- for chunk in acc_chunks -%}
            {%- if forloop.first -%}{%- continue -%}{%- endif -%}
            {%- comment -%}
              chunk looks like ">Details</h2>…body…" (or "><span>Details</span></h2>…",
              or " class=…>Details</h2>…"). Split off the heading, then derive the
              title from its text and the body from everything after "</tag>".
            {%- endcomment -%}
            {%- assign acc_head_raw = chunk | split: acc_close | first -%}
            {%- assign acc_title = acc_head_raw | strip_html | split: '>' | last | strip -%}
            {%- if acc_title == blank -%}{%- continue -%}{%- endif -%}
            {%- assign acc_title_dc = acc_title | downcase -%}
            {%- if acc_exclude contains acc_title_dc -%}{%- continue -%}{%- endif -%}
            {%- assign acc_body = chunk | remove_first: acc_head_raw | remove_first: acc_close | strip -%}
            {%- comment -%} Require real (non-markup) content, so empty/placeholder sections drop out. {%- endcomment -%}
            {%- assign acc_body_text = acc_body | strip_html | strip -%}
            {%- if acc_body_text == blank -%}{%- continue -%}{%- endif -%}
            {%- assign acc_rendered = acc_rendered | plus: 1 -%}
            <details class="ls-pdp__accordion"{% if acc_first_open and acc_rendered == 1 %} open{% endif %}>
              <summary class="ls-pdp__accordion-summary">
                <span>{{ acc_title }}</span>
                <span class="ls-pdp__accordion-icon" aria-hidden="true"></span>
              </summary>
              <div class="ls-pdp__accordion-body rte">{{ acc_body }}</div>
            </details>
          {%- endfor -%}
        {%- endcapture -%}
        {%- assign accordions_html = accordions_html | strip -%}
        {%- if accordions_html != blank -%}
          <div class="ls-pdp__accordions" data-accordions>{{ accordions_html }}</div>
        {%- endif -%}
      </div>
    </div>
  {%- endunless -%}
</div>

{%- if has_product -%}
  <script>
    (function () {
      var variants = {{ product.variants | json }};
      var SECTION_ID = {{ section.id | json }};

      function init() {
        var root = document.querySelector('.ls-pdp-{{ section.id }}');
        if (!root) return;

        /* ---------- AJAX sheen switch (preserve shopper state) ---------- */
        // Snapshot the shopper's own inputs so they survive a product swap.
        function captureState() {
          var cv = root.querySelector('[data-color-value]');
          var cl = root.querySelector('[data-combo-label]');
          var cc = root.querySelector('[data-combo-code]');
          var chip = root.querySelector('[data-combo-chip]');
          var ci = root.querySelector('.ls-pdp__custom-input');
          var ad = root.querySelector('.ls-pdp__prop-field textarea');
          var qi = root.querySelector('[data-qty-input]');
          var activeSize = root.querySelector('.ls-pdp__size-card.is-active');
          return {
            colorValue: cv ? cv.value : '',
            colorName: cl && cl.classList.contains('is-filled') ? cl.textContent : '',
            colorCode: cc ? cc.textContent : '',
            colorChip: chip ? chip.style.backgroundImage : '',
            custom: ci ? ci.value : '',
            details: ad ? ad.value : '',
            qty: qi ? qi.value : '',
            size: activeSize ? activeSize.getAttribute('data-value') : ''
          };
        }

        function restoreState(s) {
          if (!s) return;
          if (s.colorValue) {
            var cv = root.querySelector('[data-color-value]');
            var cl = root.querySelector('[data-combo-label]');
            var cc = root.querySelector('[data-combo-code]');
            var cs = root.querySelector('[data-color-selected]');
            var chip = root.querySelector('[data-combo-chip]');
            if (cv) cv.value = s.colorValue;
            if (cl) { cl.textContent = s.colorName || s.colorValue; cl.classList.add('is-filled'); }
            if (cc) { if (s.colorCode) { cc.textContent = s.colorCode; cc.hidden = false; } else { cc.hidden = true; } }
            if (cs) cs.textContent = s.colorName || s.colorValue;
            if (chip && s.colorChip) chip.style.backgroundImage = s.colorChip;
          }
          var ci = root.querySelector('.ls-pdp__custom-input'); if (ci && s.custom != null) ci.value = s.custom;
          var ad = root.querySelector('.ls-pdp__prop-field textarea'); if (ad && s.details != null) ad.value = s.details;
          var qi = root.querySelector('[data-qty-input]'); if (qi && s.qty) qi.value = s.qty;
          if (s.size) {
            Array.prototype.slice.call(root.querySelectorAll('.ls-pdp__size-card')).forEach(function (b) {
              if (b.getAttribute('data-value') === s.size) b.click();
            });
          }
        }

        function ajaxSwitchProduct(url) {
          if (!url) return;
          window.__lsPdpPendingState = captureState();
          var sep = url.indexOf('?') > -1 ? '&' : '?';
          fetch(url + sep + 'sections=' + encodeURIComponent(SECTION_ID))
            .then(function (r) { return r.json(); })
            .then(function (data) {
              var html = data[SECTION_ID];
              var wrapper = document.getElementById('shopify-section-' + SECTION_ID);
              if (!html || !wrapper) { window.location = url; return; }
              wrapper.innerHTML = html;
              // innerHTML doesn't execute <script>; recreate them so init() re-runs.
              Array.prototype.slice.call(wrapper.querySelectorAll('script')).forEach(function (old) {
                var s = document.createElement('script');
                for (var i = 0; i < old.attributes.length; i++) { s.setAttribute(old.attributes[i].name, old.attributes[i].value); }
                s.textContent = old.textContent;
                old.parentNode.replaceChild(s, old);
              });
              if (window.history && window.history.pushState) { window.history.pushState({ lsPdp: true }, '', url); }
            })
            .catch(function () { window.location = url; });
        }

        // Back/forward: reload so the URL and content stay in sync.
        if (!window.__lsPdpPop) {
          window.__lsPdpPop = true;
          window.addEventListener('popstate', function () { window.location.reload(); });
        }

        /* ---------- Gallery ---------- */
        var slides = Array.prototype.slice.call(root.querySelectorAll('[data-stage-slide]'));
        var thumbs = Array.prototype.slice.call(root.querySelectorAll('[data-thumb]'));
        var current = 0;

        var prev = root.querySelector('[data-stage-prev]');
        var next = root.querySelector('[data-stage-next]');

        function showSlide(i) {
          if (!slides.length) return;
          if (i < 0) i = 0;
          if (i >= slides.length) i = slides.length - 1;
          slides.forEach(function (s, idx) {
            var active = idx === i;
            s.classList.toggle('is-active', active);
            if (active) { s.removeAttribute('hidden'); } else { s.setAttribute('hidden', ''); }
          });
          thumbs.forEach(function (t, idx) { t.classList.toggle('is-active', idx === i); });
          if (prev) prev.disabled = i <= 0;
          if (next) next.disabled = i >= slides.length - 1;
          current = i;
        }

        thumbs.forEach(function (t) {
          t.addEventListener('click', function () { showSlide(parseInt(t.getAttribute('data-thumb'), 10)); });
        });
        if (prev) prev.addEventListener('click', function () { showSlide(current - 1); });
        if (next) next.addEventListener('click', function () { showSlide(current + 1); });
        showSlide(current);

        /* ---------- Frequently paired (upsell) ---------- */
        (function () {
          var paired = root.querySelector('[data-paired]');
          if (!paired) return;
          var track = paired.querySelector('[data-paired-track]');
          var countEl = paired.querySelector('[data-paired-count]');
          var navWrap = paired.querySelector('[data-paired-nav]');
          var pPrev = paired.querySelector('[data-paired-prev]');
          var pNext = paired.querySelector('[data-paired-next]');
          if (!track) return;

          function cards() { return Array.prototype.slice.call(track.querySelectorAll('.ls-pdp__paired-card')); }

          function refreshNav() {
            var n = cards().length;
            if (countEl) {
              countEl.textContent = n;
              if (n > 0) { countEl.removeAttribute('hidden'); } else { countEl.setAttribute('hidden', ''); }
            }
            if (navWrap) { if (n > 1) { navWrap.removeAttribute('hidden'); } else { navWrap.setAttribute('hidden', ''); } }
            updateArrows();
          }

          function updateArrows() {
            if (!pPrev || !pNext) return;
            var max = track.scrollWidth - track.clientWidth - 1;
            pPrev.disabled = track.scrollLeft <= 0;
            pNext.disabled = track.scrollLeft >= max;
          }

          function step(dir) {
            var first = track.querySelector('.ls-pdp__paired-card');
            var amount = first ? first.getBoundingClientRect().width + 12 : track.clientWidth;
            track.scrollBy({ left: dir * amount, behavior: 'smooth' });
          }
          if (pPrev) pPrev.addEventListener('click', function () { step(-1); });
          if (pNext) pNext.addEventListener('click', function () { step(1); });
          track.addEventListener('scroll', updateArrows, { passive: true });

          // Manual blocks: already server-rendered, just wire nav.
          if (!paired.hasAttribute('data-paired-dynamic')) { refreshNav(); return; }

          // Dynamic: complementary (curated) first, fall back to related.
          var baseUrl = paired.getAttribute('data-reco-url');
          function fetchIntent(intent) {
            return fetch(baseUrl + '&intent=' + intent)
              .then(function (r) { return r.ok ? r.text() : ''; })
              .then(function (text) {
                if (!text) return [];
                var holder = document.createElement('div');
                holder.innerHTML = text;
                var box = holder.querySelector('.ls-fpaired');
                return box ? Array.prototype.slice.call(box.querySelectorAll('.ls-pdp__paired-card')) : [];
              })
              .catch(function () { return []; });
          }

          function hide() { paired.setAttribute('hidden', ''); }

          // A pinned card is server-rendered and must survive the dynamic refresh.
          var pinnedCard = track.querySelector('[data-paired-pinned]');
          var pinnedId = pinnedCard ? pinnedCard.getAttribute('data-paired-id') : null;
          function removeSkeleton() {
            var sk = track.querySelector('[data-paired-skeleton]');
            if (sk && sk.parentNode) sk.parentNode.removeChild(sk);
          }
          function keepPinnedOrHide() {
            // No API results: keep the pinned card if there is one, otherwise hide the whole block.
            if (pinnedCard) { removeSkeleton(); refreshNav(); } else { hide(); }
          }

          if (!baseUrl) { keepPinnedOrHide(); return; }
          fetchIntent('complementary')
            .then(function (list) { return (list && list.length) ? list : fetchIntent('related'); })
            .then(function (list) {
              if (!list || !list.length) { keepPinnedOrHide(); return; }
              track.innerHTML = '';
              if (pinnedCard) track.appendChild(pinnedCard);
              list.forEach(function (c) {
                // Drop any API card that duplicates the pinned product.
                if (pinnedId) {
                  var pf = c.querySelector('[data-product-id]');
                  if (pf && pf.getAttribute('data-product-id') === pinnedId) return;
                }
                track.appendChild(c);
              });
              refreshNav();
            })
            .catch(keepPinnedOrHide);
        })();

        function showMediaId(mediaId) {
          if (mediaId == null) return;
          for (var i = 0; i < slides.length; i++) {
            if (String(slides[i].getAttribute('data-media-id')) === String(mediaId)) { showSlide(i); return; }
          }
        }

        /* ---------- Variant selection ---------- */
        var form = root.querySelector('[data-selectors]');
        var variantInput = root.querySelector('[data-variant-id]');
        var priceEl = root.querySelector('[data-price]');
        var compareEl = root.querySelector('[data-compare]');
        var saveEl = root.querySelector('[data-save]');
        var stockLabel = root.querySelector('[data-stock-label]');
        var stockWrap = root.querySelector('[data-stock]');
        var atcBtn = root.querySelector('[data-atc]');
        var atcPrice = root.querySelector('[data-atc-price]');
        var atcLabel = root.querySelector('[data-atc-label]');
        var selectors = form ? Array.prototype.slice.call(form.querySelectorAll('.ls-pdp__selector')) : [];
        var dynamicWrap = root.querySelector('.ls-pdp__dynamic');
        var colorRequired = {{ color_required | json }};
        var colorValInput = root.querySelector('[data-color-value]');
        var customColorInput = root.querySelector('.ls-pdp__custom-input');
        // Assigned inside the combobox block below; clears the picked swatch so a
        // typed custom colour and a selected swatch are mutually exclusive.
        var clearColorSelection = null;

        var texts = {
          addToCart: {{ section.settings.add_to_cart_text | json }},
          soldOut: {{ section.settings.sold_out_text | json }},
          unavailable: {{ section.settings.unavailable_text | json }},
          colorRequired: {{ section.settings.color_required_text | default: 'Select a color to continue' | json }},
          inStock: {{ section.settings.in_stock_text | json }},
          outOfStock: {{ section.settings.out_of_stock_text | json }},
          moneyFormat: {{ shop.money_format | json }}
        };

        function formatMoney(cents) {
          try {
            return (cents / 100).toLocaleString(undefined, { style: 'currency', currency: {{ shop.currency | json }} });
          } catch (e) {
            return '$' + (cents / 100).toFixed(2);
          }
        }

        // Collect only the values the consumer actually picked (visible
        // selectors), keyed by 0-based option index. Options hidden from the UI
        // (single-value bases, internal Material ID) are intentionally left out,
        // so the first variant matching the visible choices is used.
        function selectedValues() {
          var sel = {};
          selectors.forEach(function (s) {
            var pos = parseInt(s.getAttribute('data-option-position'), 10);
            if (isNaN(pos)) return;
            var dropdown = s.querySelector('select[data-option-input]');
            var active = s.querySelector('.is-active[data-option-input]');
            var val = dropdown ? dropdown.value : (active ? active.getAttribute('data-value') : null);
            if (val != null) sel[pos - 1] = val;
          });
          return sel;
        }

        function findVariant(sel) {
          return variants.find(function (v) {
            for (var i in sel) {
              if (v.options[i] !== sel[i]) return false;
            }
            return true;
          });
        }

        function variantMatchesSelection(v, sel) {
          for (var i in sel) {
            if (v.options[i] !== sel[i]) return false;
          }
          return true;
        }

        // Each size card names the exact variant its price belongs to
        // (data-variant-id). ADVANCE-style products carry hidden option(s) beyond
        // Size (Material ID / tint base), so matching by the visible Size alone can
        // resolve a different base than the one priced — and add a cheaper/wrong
        // variant (e.g. a bonding-primer base). Prefer the card's own variant so
        // the cart always matches the price shown; fall back to size matching.
        function resolveVariant() {
          var sel = selectedValues();
          var activeCard = form ? form.querySelector('.ls-pdp__size-card.is-active[data-variant-id]') : null;
          if (activeCard) {
            var id = activeCard.getAttribute('data-variant-id');
            if (id) {
              var byId = variants.find(function (v) { return String(v.id) === String(id); });
              if (byId && variantMatchesSelection(byId, sel)) return byId;
            }
          }
          return findVariant(sel);
        }

        // Checkout requires a colour: either a picked swatch (data-color-value) or
        // a typed custom colour / code. No colour selector on this product → no gate.
        function colorSatisfied() {
          if (!colorRequired) return true;
          var hasColor = colorValInput && colorValInput.value.trim() !== '';
          var hasCustom = customColorInput && customColorInput.value.trim() !== '';
          return hasColor || hasCustom;
        }

        function updateDynamic(enabled) {
          if (!dynamicWrap) return;
          dynamicWrap.classList.toggle('ls-pdp__dynamic--disabled', !enabled);
          dynamicWrap.setAttribute('aria-disabled', enabled ? 'false' : 'true');
        }

        function updateUI(variant) {
          if (variantInput) {
            if (variant) {
              variantInput.value = variant.id;
              variantInput.removeAttribute('disabled');
            } else {
              variantInput.setAttribute('disabled', '');
            }
          }

          if (!variant) {
            if (atcBtn) { atcBtn.setAttribute('disabled', ''); }
            if (atcLabel) atcLabel.textContent = texts.unavailable;
            updateDynamic(false);
            return;
          }

          if (priceEl) priceEl.textContent = formatMoney(variant.price);
          if (compareEl) {
            if (variant.compare_at_price && variant.compare_at_price > variant.price) {
              compareEl.textContent = formatMoney(variant.compare_at_price);
              compareEl.removeAttribute('hidden');
              if (saveEl) {
                saveEl.textContent = 'Save ' + formatMoney(variant.compare_at_price - variant.price);
                saveEl.removeAttribute('hidden');
              }
            } else {
              compareEl.setAttribute('hidden', '');
              if (saveEl) saveEl.setAttribute('hidden', '');
            }
          }

          if (stockLabel) stockLabel.textContent = variant.available ? texts.inStock : texts.outOfStock;
          if (stockWrap) stockWrap.classList.toggle('is-out', !variant.available);

          var colorOk = colorSatisfied();
          if (atcBtn) {
            if (!variant.available) {
              atcBtn.setAttribute('disabled', '');
              if (atcLabel) atcLabel.textContent = texts.soldOut;
            } else if (!colorOk) {
              atcBtn.setAttribute('disabled', '');
              if (atcLabel) atcLabel.textContent = texts.colorRequired;
            } else {
              atcBtn.removeAttribute('disabled');
              if (atcLabel) {
                atcLabel.innerHTML = texts.addToCart + ' &mdash; <span data-atc-price>' + formatMoney(variant.price) + '</span>';
              }
            }
          }
          updateDynamic(variant.available && colorOk);

          if (variant.featured_media && variant.featured_media.id != null) {
            showMediaId(variant.featured_media.id);
          }

          // Reflect the selected value labels in each selector head — index by
          // the option's position, not DOM order (hidden options shift order).
          selectors.forEach(function (sel) {
            var pos = parseInt(sel.getAttribute('data-option-position'), 10) - 1;
            var label = sel.querySelector('[data-option-selected]');
            if (label && variant.options[pos]) label.textContent = variant.options[pos];
          });
        }

        function onSelect() {
          updateUI(resolveVariant());
        }

        selectors.forEach(function (sel) {
          var dropdown = sel.querySelector('select[data-option-input]');
          if (dropdown) {
            dropdown.addEventListener('change', onSelect);
          }
          var buttons = Array.prototype.slice.call(sel.querySelectorAll('button[data-option-input]'));
          buttons.forEach(function (btn) {
            btn.addEventListener('click', function () {
              buttons.forEach(function (b) {
                b.classList.remove('is-active');
                b.setAttribute('aria-checked', 'false');
              });
              btn.classList.add('is-active');
              btn.setAttribute('aria-checked', 'true');
              onSelect();
            });
          });
        });

        // Re-evaluate the colour gate as the shopper types a custom colour / code.
        // A typed custom colour clears any picked swatch — the two are mutually
        // exclusive ways to name one colour.
        if (customColorInput) customColorInput.addEventListener('input', function () {
          if (customColorInput.value.trim() !== '' && clearColorSelection) clearColorSelection();
          onSelect();
        });

        // Establish the initial state (price + colour gate) on load.
        onSelect();

        /* ---------- Quantity ---------- */
        var qtyInput = root.querySelector('[data-qty-input]');
        var qtyMinus = root.querySelector('[data-qty-minus]');
        var qtyPlus = root.querySelector('[data-qty-plus]');
        function clampQty() {
          var n = parseInt(qtyInput.value, 10);
          if (isNaN(n) || n < 1) n = 1;
          qtyInput.value = n;
        }
        if (qtyMinus) qtyMinus.addEventListener('click', function () { qtyInput.value = Math.max(1, (parseInt(qtyInput.value, 10) || 1) - 1); });
        if (qtyPlus) qtyPlus.addEventListener('click', function () { qtyInput.value = (parseInt(qtyInput.value, 10) || 1) + 1; });
        if (qtyInput) qtyInput.addEventListener('change', clampQty);

        /* ---------- Custom-color reveal (mobile link) ---------- */
        var customToggle = root.querySelector('[data-custom-toggle]');
        if (customToggle) {
          customToggle.addEventListener('click', function () {
            var row = customToggle.closest('.ls-pdp__color-row');
            if (row) row.setAttribute('data-custom-open', '');
            customToggle.setAttribute('aria-expanded', 'true');
            if (customColorInput) customColorInput.focus();
          });
        }

        /* ---------- Color combobox (line-item property, live search) ---------- */
        var combo = root.querySelector('[data-combo]');
        if (combo) {
          var comboToggle = combo.querySelector('[data-combo-toggle]');
          var comboPanel = combo.querySelector('[data-combo-panel]');
          var comboInput = combo.querySelector('[data-combo-input]');
          var comboList = combo.querySelector('[data-combo-list]');
          var comboLabel = combo.querySelector('[data-combo-label]');
          var comboCode = combo.querySelector('[data-combo-code]');
          var comboChip = combo.querySelector('[data-combo-chip]');
          var comboFoot = combo.querySelector('[data-combo-foot]');
          var colorValueInput = root.querySelector('[data-color-value]');
          var colorSelected = root.querySelector('[data-color-selected]');
          // Placeholder text to fall back to when the selection is cleared.
          var comboPlaceholder = comboLabel ? comboLabel.textContent : '';

          // Reset the combobox to its unselected state (used when a custom colour
          // is typed). Hoisted to the outer scope via clearColorSelection.
          clearColorSelection = function () {
            if (colorValueInput) colorValueInput.value = '';
            if (comboLabel) { comboLabel.textContent = comboPlaceholder; comboLabel.classList.remove('is-filled'); }
            if (comboCode) { comboCode.textContent = ''; comboCode.hidden = true; }
            if (comboChip) comboChip.style.backgroundImage = '';
            if (colorSelected) colorSelected.textContent = '';
          };

          var searchUrl = combo.getAttribute('data-search-url') || '/search';
          var families = (combo.getAttribute('data-families') || '').split('|').filter(Boolean);
          var minChars = parseInt(combo.getAttribute('data-min-chars'), 10) || 2;
          // Server-rendered starting options (by family tags), restored when cleared.
          var initialHTML = comboList.innerHTML;

          function comboEmptyEl() { return comboList.querySelector('[data-combo-empty]'); }

          function openCombo(open) {
            if (!comboPanel) return;
            if (open) { comboPanel.removeAttribute('hidden'); } else { comboPanel.setAttribute('hidden', ''); }
            comboToggle.setAttribute('aria-expanded', open ? 'true' : 'false');
            if (open && comboInput) { setTimeout(function () { comboInput.focus(); }, 0); }
          }

          function familyOk(li) {
            if (!families.length) return true;
            var f = li.getAttribute('data-family');
            if (!f) return true;
            return families.indexOf(f) !== -1;
          }

          function setStatus(text) {
            comboList.innerHTML = '';
            var li = document.createElement('li');
            li.className = 'ls-pdp__combo-note';
            li.textContent = text;
            comboList.appendChild(li);
          }

          // Filter the currently-rendered options by substring (used for the
          // initial list; live results are already server-matched).
          function filterVisible(term) {
            term = (term || '').toLowerCase().trim();
            var shown = 0;
            Array.prototype.slice.call(comboList.querySelectorAll('.ls-pdp__combo-opt')).forEach(function (li) {
              var hit = !term || li.getAttribute('data-search').indexOf(term) !== -1;
              li.hidden = !hit;
              if (hit) shown++;
            });
            var empty = comboEmptyEl();
            if (empty) empty.hidden = shown !== 0;
          }

          var reqToken = 0;
          function liveSearch(term, done) {
            var token = ++reqToken;
            if (comboFoot) comboFoot.hidden = true; // starter-list footer doesn't apply to results
            setStatus('Searching…');
            var url = searchUrl + '?q=' + encodeURIComponent(term) + '*&type=product&section_id=ls-color-results';
            fetch(url)
              .then(function (r) { return r.text(); })
              .then(function (html) {
                if (token !== reqToken) return; // a newer keystroke won
                var tmp = document.createElement('div');
                tmp.innerHTML = html;
                var all = Array.prototype.slice.call(tmp.querySelectorAll('.ls-pdp__combo-opt'));
                var found = all.filter(familyOk);
                // Safeguard: if the family filter removed everything (e.g. the
                // color-product family codes don't line up with the paint's
                // colorcollection_* codes), fall back to the full result set so
                // the shopper still sees matches rather than an empty box.
                if (found.length === 0) found = all;
                comboList.innerHTML = '';
                found.forEach(function (li) { comboList.appendChild(li); });
                var empty = document.createElement('li');
                empty.className = 'ls-pdp__combo-empty';
                empty.setAttribute('data-combo-empty', '');
                empty.textContent = 'No colors match “' + term + '”.';
                empty.hidden = found.length !== 0;
                comboList.appendChild(empty);
                if (done) done();
              })
              .catch(function () {
                if (token === reqToken) setStatus('Search unavailable — try again.');
              });
          }

          var debounce;
          function onInput() {
            var term = comboInput.value.trim();
            clearTimeout(debounce);
            if (term.length < minChars) {
              comboList.innerHTML = initialHTML;
              if (comboFoot) comboFoot.hidden = false; // restore starter footer
              filterVisible(term);
              return;
            }
            debounce = setTimeout(function () { liveSearch(term); }, 250);
          }

          function chooseColor(li) {
            var val = li.getAttribute('data-value');
            var nm = li.getAttribute('data-name') || val;
            var code = li.getAttribute('data-code') || '';
            if (colorValueInput) colorValueInput.value = val; // full "code name" saved to the order
            if (comboLabel) { comboLabel.textContent = nm; comboLabel.classList.add('is-filled'); }
            if (comboCode) {
              if (code && code !== nm) { comboCode.textContent = code; comboCode.hidden = false; }
              else { comboCode.textContent = ''; comboCode.hidden = true; }
            }
            if (colorSelected) colorSelected.textContent = nm;
            if (comboChip) {
              var sw = li.querySelector('.ls-pdp__combo-swatch');
              comboChip.style.backgroundImage = sw ? sw.style.backgroundImage : '';
            }
            openCombo(false);
            onSelect(); // a colour is now set — refresh the checkout gate
          }

          if (comboToggle) {
            comboToggle.addEventListener('click', function () { openCombo(comboPanel.hasAttribute('hidden')); });
          }
          if (comboInput) comboInput.addEventListener('input', onInput);
          // Event delegation so both initial and fetched options are clickable.
          comboList.addEventListener('click', function (e) {
            var li = e.target.closest ? e.target.closest('.ls-pdp__combo-opt') : null;
            if (li) chooseColor(li);
          });
          document.addEventListener('click', function (e) {
            if (!combo.contains(e.target)) openCombo(false);
          });
          combo.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') openCombo(false);
          });

          // Autopopulate from ?color=<code> (e.g. arriving from a color-sample
          // page). Prefer an already-rendered starter option; otherwise run the
          // same live search and pick the exact code match. Skip if the shopper
          // already has a colour (e.g. one restored from an AJAX sheen swap).
          (function () {
            var incoming = '';
            try { incoming = new URLSearchParams(window.location.search).get('color') || ''; } catch (e) {}
            incoming = incoming.trim();
            if (!incoming) return;
            if (colorValueInput && colorValueInput.value.trim() !== '') return;
            function optByCode(code) {
              var lc = code.toLowerCase();
              var opts = Array.prototype.slice.call(comboList.querySelectorAll('.ls-pdp__combo-opt'));
              // Exact code match first, then a value that starts with the code.
              return opts.filter(function (li) { return (li.getAttribute('data-code') || '').toLowerCase() === lc; })[0]
                  || opts.filter(function (li) { return (li.getAttribute('data-value') || '').toLowerCase().indexOf(lc) === 0; })[0]
                  || null;
            }
            var hit = optByCode(incoming);
            if (hit) { chooseColor(hit); return; }
            liveSearch(incoming, function () {
              var m = optByCode(incoming);
              if (m) chooseColor(m);
              else { comboList.innerHTML = initialHTML; filterVisible(''); } // no match — restore starter list
            });
          })();
        }

        /* ---------- Sheen / grit (sibling products via productfamily collection) ---------- */
        // Pills are sibling-product links rendered server-side (correct active
        // state included). We only intercept clicks to AJAX-swap the product
        // instead of a full navigation, so color/size/qty state carries over.
        var sheen = root.querySelector('[data-sheen]');
        if (sheen) {
          var sheenPills = sheen.querySelector('[data-sheen-pills]');
          if (sheenPills) {
            sheenPills.addEventListener('click', function (e) {
              var a = e.target.closest ? e.target.closest('a.ls-pdp__pill') : null;
              if (!a) return;
              e.preventDefault();
              if (a.classList.contains('is-active')) return;
              ajaxSwitchProduct(a.getAttribute('href'));
            });
          }
        }

        /* ---------- Drag-to-swipe pill rows (sheen + variant options) ---------- */
        // Native overflow-x handles touch/trackpad; on desktop a mouse drag just
        // grabs the link, so add pointer drag-to-scroll for mouse/pen and swallow
        // the click that ends a real drag (so it scrolls instead of navigating).
        Array.prototype.slice.call(
          root.querySelectorAll('.ls-pdp__selector--sheen .ls-pdp__pills, .ls-pdp__selector--buttons .ls-pdp__pills')
        ).forEach(function (row) {
          var isDown = false, moved = false, startX = 0, startScroll = 0, suppressClick = false;
          row.addEventListener('pointerdown', function (e) {
            if (e.pointerType === 'touch') return; // let native scroll handle touch
            if (e.button != null && e.button !== 0) return;
            isDown = true; moved = false; suppressClick = false;
            startX = e.clientX; startScroll = row.scrollLeft;
          });
          row.addEventListener('pointermove', function (e) {
            if (!isDown) return;
            var dx = e.clientX - startX;
            if (!moved && Math.abs(dx) > 4) {
              moved = true;
              row.classList.add('is-dragging');
              try { row.setPointerCapture(e.pointerId); } catch (err) {}
            }
            if (moved) { row.scrollLeft = startScroll - dx; e.preventDefault(); }
          });
          function endDrag() {
            if (!isDown) return;
            isDown = false;
            suppressClick = moved; // a real drag just happened → eat the next click
            row.classList.remove('is-dragging');
          }
          row.addEventListener('pointerup', endDrag);
          row.addEventListener('pointercancel', endDrag);
          row.addEventListener('click', function (e) {
            if (suppressClick) { e.preventDefault(); e.stopPropagation(); suppressClick = false; }
          }, true);
          // Plain vertical wheel scrolls the row horizontally while hovering it.
          row.addEventListener('wheel', function (e) {
            var raw = Math.abs(e.deltaY) > Math.abs(e.deltaX) ? e.deltaY : e.deltaX;
            if (!raw) return;
            // Normalise line/page-based wheels (deltaMode 1/2) to pixels so mice
            // that report small line counts still move a sensible distance.
            var unit = e.deltaMode === 1 ? 16 : (e.deltaMode === 2 ? row.clientWidth : 1);
            var delta = raw * unit;
            var maxScroll = row.scrollWidth - row.clientWidth;
            if (maxScroll <= 0) return; // nothing to scroll
            var atStart = row.scrollLeft <= 0;
            var atEnd = row.scrollLeft >= maxScroll - 1;
            // Let the page scroll when we're already at the edge in that direction.
            if ((delta < 0 && atStart) || (delta > 0 && atEnd)) return;
            row.scrollLeft += delta;
            e.preventDefault();
          }, { passive: false });
        });

        /* ---------- "Shop this color in" pager (3 lines per page) ---------- */
        var shopColor = root.querySelector('[data-shopcolor]');
        if (shopColor) {
          var scList = shopColor.querySelector('[data-shopcolor-list]');
          var scNav = shopColor.querySelector('[data-shopcolor-nav]');
          var scPrev = shopColor.querySelector('[data-shopcolor-prev]');
          var scNext = shopColor.querySelector('[data-shopcolor-next]');
          var scItems = scList ? Array.prototype.slice.call(scList.querySelectorAll('.ls-pdp__shop-color-link')) : [];
          var scSize = parseInt(shopColor.getAttribute('data-shopcolor-page-size'), 10) || 3;
          var scPages = Math.ceil(scItems.length / scSize);
          var scPage = 0;

          function scRender() {
            scItems.forEach(function (el, i) {
              var onPage = Math.floor(i / scSize) === scPage;
              if (onPage) { el.removeAttribute('hidden'); } else { el.setAttribute('hidden', ''); }
            });
            if (scPrev) scPrev.disabled = scPage <= 0;
            if (scNext) scNext.disabled = scPage >= scPages - 1;
          }

          if (scPages > 1) {
            if (scNav) scNav.hidden = false;
            if (scPrev) scPrev.addEventListener('click', function () { if (scPage > 0) { scPage--; scRender(); } });
            if (scNext) scNext.addEventListener('click', function () { if (scPage < scPages - 1) { scPage++; scRender(); } });
            scRender();
          }
        }

        // Re-apply shopper state carried over from an AJAX sheen switch.
        if (window.__lsPdpPendingState) {
          restoreState(window.__lsPdpPendingState);
          window.__lsPdpPendingState = null;
          onSelect(); // refresh price + colour gate against the restored state
        }
      }

      init();
      document.addEventListener('shopify:section:load', function (e) {
        if (!e.detail || e.detail.sectionId === '{{ section.id }}') init();
      });
    })();
  </script>
{%- endif -%}

{% stylesheet %}
  .ls-pdp {
    font-family: var(--ls-pd-font-family, 'Outfit', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif);
    color: var(--ls-pd-text);
    /* Guarantee nothing spills sideways. `clip` (not `hidden`) keeps vertical
       overflow visible — e.g. the "POPULAR" size badges — and doesn't create a
       scroll container, so the desktop sticky media column still works. */
    overflow-x: clip;
  }

  .ls-pdp__empty {
    color: var(--ls-pd-muted);
    text-align: center;
    padding: 3rem 0;
  }

  /* ---------- Breadcrumbs ---------- */
  .ls-pdp__crumbs {
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    gap: 0.4rem;
    min-width: 0;
    font-size: 0.8125rem;
    color: var(--ls-pd-muted);
    margin-bottom: 1.25rem;
  }

  /* Keep links + separators intact; truncate the long current-page title. */
  .ls-pdp__crumbs a,
  .ls-pdp__crumbs span[aria-hidden] { flex-shrink: 0; white-space: nowrap; }

  .ls-pdp__crumbs a {
    color: inherit;
    text-decoration: none;
  }

  .ls-pdp__crumbs a:hover { color: var(--ls-pd-accent); }
  .ls-pdp__crumbs-current {
    color: var(--ls-pd-heading);
    font-weight: 600;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* ---------- Grid ---------- */
  .ls-pdp__grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 2rem;
  }
  /* minmax(0,…) tracks let children shrink instead of forcing the grid wider
     than the viewport; belt-and-suspenders min-width:0 on the columns too. */
  .ls-pdp__media-col,
  .ls-pdp__details { min-width: 0; }

  /* ---------- Media column ---------- */
  /* Mobile: no panel background — the gallery sits directly on the page.
     The gray preview panel is applied desktop-only (see Desktop block). */

  /* ---------- Gallery ---------- */
  .ls-pdp__stage {
    position: relative;
    background: var(--ls-pd-surface);
    border-radius: var(--ls-pd-radius);
    overflow: hidden;
    aspect-ratio: 1 / 1;
    display: grid;
    place-items: center;
  }

  .ls-pdp__stage-img {
    grid-area: 1 / 1;
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  .ls-pdp__stage-img[hidden] { display: none; }

  .ls-pdp__stage-img--placeholder { display: grid; place-items: center; }

  .ls-pdp__nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 999px;
    border: 1px solid var(--ls-pd-border);
    background: var(--ls-pd-surface);
    color: var(--ls-pd-text);
    cursor: pointer;
    box-shadow: 0 1px 1px rgba(20, 22, 26, 0.06), 0 1px 2px rgba(20, 22, 26, 0.05);
    transition: box-shadow 0.15s ease, color 0.15s ease, opacity 0.15s ease;
  }

  .ls-pdp__nav:hover {
    color: var(--ls-pd-accent);
    box-shadow: 0 2px 4px rgba(20, 22, 26, 0.1), 0 4px 10px rgba(20, 22, 26, 0.08);
  }
  .ls-pdp__nav:disabled { opacity: 0.35; cursor: default; box-shadow: 0 1px 1px rgba(20, 22, 26, 0.06); }
  .ls-pdp__nav:disabled:hover { color: var(--ls-pd-text); }
  .ls-pdp__nav svg { width: 20px; height: 20px; }
  .ls-pdp__nav--prev { left: 1.25rem; }
  .ls-pdp__nav--next { right: 1.25rem; }

  .ls-pdp__thumbs {
    display: flex;
    gap: 0.75rem;
    margin-top: 0.6rem;
  }

  .ls-pdp__thumb {
    appearance: none;
    padding: 0;
    flex: 1 1 0;
    min-width: 0;
    aspect-ratio: 99 / 77;
    border: 1.5px solid transparent;
    border-radius: 12px;
    overflow: hidden;
    background: var(--ls-pd-surface);
    cursor: pointer;
    transition: border-color 0.15s ease;
  }

  .ls-pdp__thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .ls-pdp__thumb.is-active { border-color: var(--ls-pd-accent); }

  /* ---------- Assurance pills ---------- */
  .ls-pdp__assurances {
    list-style: none;
    margin: 1rem 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 0.75rem;
  }
  /* Hidden on mobile — they live under the gallery and crowd the small screen. */
  @media screen and (max-width: 749px) {
    .ls-pdp__assurances { display: none; }
  }

  .ls-pdp__assurance {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 0.85rem 0.6rem 0.6rem;
    border: 1px solid var(--ls-pd-border);
    border-radius: 14px;
    background: var(--ls-pd-surface);
    box-shadow: 0 2px 2px rgba(20, 22, 26, 0.04), 0 8px 12px rgba(20, 22, 26, 0.06);
  }

  .ls-pdp__assurance-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    flex-shrink: 0;
    border-radius: 14px;
    background: var(--ls-pd-icon-chip);
    color: var(--ls-pd-accent);
  }
  .ls-pdp__assurance-icon svg { width: 20px; height: 20px; }
  .ls-pdp__assurance-text { display: flex; flex-direction: column; min-width: 0; gap: 1px; }
  .ls-pdp__assurance-title { font-size: 0.875rem; font-weight: 600; color: var(--ls-pd-heading); line-height: 1.2; }
  .ls-pdp__assurance-sub { font-size: 0.8125rem; color: var(--ls-pd-muted); line-height: 1.3; }

  /* ---------- Details ---------- */
  .ls-pdp__details { display: flex; flex-direction: column; }

  .ls-pdp__ships {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    align-self: flex-start;
    margin: 0 0 0.85rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--ls-pd-heading);
  }
  .ls-pdp__ships-icon { flex: 0 0 auto; width: 16px; height: 16px; }

  .ls-pdp__rating { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.85rem; }
  .ls-pdp__stars { display: inline-flex; gap: 2px; }
  .ls-pdp__star { position: relative; width: 15px; height: 15px; display: inline-block; }
  .ls-pdp__star-svg { position: absolute; inset: 0; width: 100%; height: 100%; }
  .ls-pdp__star-bg { fill: #e2e2e2; }
  .ls-pdp__star-fg { fill: #f5a623; clip-path: inset(0 calc(100% - var(--star-fill)) 0 0); }
  .ls-pdp__rating-text { font-size: 0.8125rem; color: #17181B; }

  .ls-pdp__title {
    margin: 0 0 1rem;
    color: var(--ls-pd-heading);
    font-size: clamp(1.6rem, 3vw, 2.1rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  .ls-pdp__price-block { padding-bottom: 1.25rem; border-bottom: 1px solid var(--ls-pd-border); margin-bottom: 1.25rem; }
  .ls-pdp__price-row { display: flex; align-items: baseline; flex-wrap: wrap; gap: 0.6rem; }
  .ls-pdp__price { font-size: 1.9rem; font-weight: 700; color: var(--ls-pd-heading); letter-spacing: -0.01em; }
  .ls-pdp__compare { color: var(--ls-pd-muted); font-size: 1.05rem; }
  .ls-pdp__compare[hidden], .ls-pdp__save[hidden] { display: none; }

  .ls-pdp__save {
    background: var(--ls-pd-success);
    color: #fff;
    font-size: 0.78rem;
    font-weight: 600;
    padding: 0.25rem 0.6rem;
    border-radius: 999px;
  }

  .ls-pdp__price-meta { display: flex; flex-wrap: wrap; align-items: center; gap: 0.4rem 1rem; margin-top: 0.5rem; }
  .ls-pdp__stock { display: inline-flex; align-items: center; gap: 0.4rem; font-size: 0.78rem; font-weight: 600; color: var(--ls-pd-success); }
  .ls-pdp__stock-dot { width: 7px; height: 7px; border-radius: 999px; background: currentColor; }
  .ls-pdp__stock.is-out { color: var(--ls-pd-muted); }
  .ls-pdp__price-suffix { font-size: 0.78rem; color: var(--ls-pd-muted); }
  .ls-pdp__price-suffix::before { content: '· '; }

  /* ---------- Selectors ---------- */
  .ls-pdp__form { margin: 0; }
  .ls-pdp__selectors { display: flex; flex-direction: column; gap: 1.15rem; }
  /* min-width:0 lets a selector shrink below its content so the swipeable pill
     rows below overflow-x:auto instead of stretching the whole column wide. */
  .ls-pdp__selector { min-width: 0; }
  .ls-pdp__selector-head { display: flex; align-items: baseline; gap: 0.5rem; margin-bottom: 0.55rem; }
  .ls-pdp__selector-label { font-size: 0.85rem; font-weight: 600; color: var(--ls-pd-heading); }
  .ls-pdp__selector-value { font-size: 0.8rem; color: var(--ls-pd-muted); }
  .ls-pdp__selector-value:not(:empty)::before { content: '· '; }

  .ls-pdp__pills { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .ls-pdp__pill {
    appearance: none;
    border: 1.5px solid var(--ls-pd-border);
    background: var(--ls-pd-surface);
    color: var(--ls-pd-text);
    font: inherit;
    font-size: 0.85rem;
    font-weight: 500;
    padding: 0.6rem 1rem;
    border-radius: 999px;
    cursor: pointer;
    transition: border-color 0.15s ease, color 0.15s ease;
  }

  .ls-pdp__pill:hover { border-color: var(--ls-pd-heading); }
  .ls-pdp__pill.is-active {
    border-color: var(--ls-pd-accent);
    color: #d24f46;
    background: #fcf2f0;
    font-weight: 700;
  }
  /* Sheen pills are links to sibling products. */
  a.ls-pdp__pill { display: inline-flex; align-items: center; text-decoration: none; }

  /* Sheen + variant-option pills: swipeable single row instead of wrapping. */
  .ls-pdp__selector--sheen .ls-pdp__pills,
  .ls-pdp__selector--buttons .ls-pdp__pills {
    flex-wrap: nowrap;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    cursor: grab;
    /* room so the scrolled pills aren't flush against the edge */
    padding-bottom: 2px;
  }
  .ls-pdp__selector--sheen .ls-pdp__pills::-webkit-scrollbar,
  .ls-pdp__selector--buttons .ls-pdp__pills::-webkit-scrollbar { display: none; }
  .ls-pdp__selector--sheen .ls-pdp__pill,
  .ls-pdp__selector--buttons .ls-pdp__pill {
    flex-shrink: 0;
    white-space: nowrap;
  }
  /* Mouse drag-to-scroll affordance (JS handles the actual scroll). */
  .ls-pdp__selector--sheen .ls-pdp__pills.is-dragging,
  .ls-pdp__selector--buttons .ls-pdp__pills.is-dragging {
    cursor: grabbing;
    user-select: none;
    -webkit-user-select: none;
  }
  /* Stop the browser from ghost-dragging the sheen links during a swipe. */
  .ls-pdp__selector--sheen a.ls-pdp__pill { -webkit-user-drag: none; }

  /* ---------- Color combobox (searchable) ---------- */
  .ls-pdp__color-row { display: flex; align-items: stretch; gap: 0.6rem; }
  .ls-pdp__combo { position: relative; flex: 3 1 0; min-width: 0; }

  .ls-pdp__combo-toggle {
    appearance: none;
    display: flex;
    align-items: center;
    gap: 0.65rem;
    width: 100%;
    height: 100%;
    border: 1.5px solid var(--ls-pd-border);
    background: var(--ls-pd-surface);
    color: var(--ls-pd-text);
    font: inherit;
    font-size: 0.9rem;
    padding: 0.5rem 0.8rem;
    border-radius: 12px;
    cursor: pointer;
    text-align: left;
    transition: border-color 0.15s ease;
  }

  .ls-pdp__combo-toggle:hover { border-color: var(--ls-pd-heading); }
  .ls-pdp__combo-toggle[aria-expanded="true"] { border-color: var(--ls-pd-accent); }

  .ls-pdp__combo-chip {
    width: 40px;
    height: 40px;
    border-radius: 8px;
    flex-shrink: 0;
    border: 1px solid var(--ls-pd-border);
    background-color: var(--ls-pd-tile-bg);
    background-size: cover;
    background-position: center;
  }

  .ls-pdp__combo-textwrap {
    flex: 1 1 auto;
    min-width: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    line-height: 1.2;
  }

  .ls-pdp__combo-name {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    color: var(--ls-pd-muted);
  }

  .ls-pdp__combo-name.is-filled { color: var(--ls-pd-heading); font-weight: 600; }
  .ls-pdp__combo-code { font-size: 0.75rem; color: var(--ls-pd-muted); }
  .ls-pdp__combo-code[hidden] { display: none; }
  .ls-pdp__combo-caret { width: 18px; height: 18px; flex-shrink: 0; color: var(--ls-pd-muted); }

  .ls-pdp__combo-panel {
    position: absolute;
    z-index: 20;
    top: calc(100% + 6px);
    left: 0;
    right: 0;
    background: var(--ls-pd-surface);
    border: 1px solid var(--ls-pd-border);
    border-radius: 12px;
    box-shadow: 0 12px 32px rgb(0 0 0 / 0.12);
    overflow: hidden;
  }

  .ls-pdp__combo-panel[hidden] { display: none; }

  .ls-pdp__combo-search { padding: 0.55rem; border-bottom: 1px solid var(--ls-pd-border); }

  .ls-pdp__combo-input {
    width: 100%;
    border: 1.5px solid var(--ls-pd-border);
    border-radius: 8px;
    background: var(--ls-pd-surface);
    color: var(--ls-pd-text);
    font: inherit;
    font-size: 0.875rem;
    padding: 0.5rem 0.7rem;
  }

  .ls-pdp__combo-input:focus { outline: none; border-color: var(--ls-pd-accent); }

  .ls-pdp__combo-list {
    list-style: none;
    margin: 0;
    padding: 0.3rem;
    max-height: 260px;
    overflow-y: auto;
  }

  .ls-pdp__combo-opt {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.5rem 0.6rem;
    border-radius: 10px;
    cursor: pointer;
    font-size: 0.875rem;
  }

  .ls-pdp__combo-opt[hidden] { display: none; }
  .ls-pdp__combo-opt:hover { background: color-mix(in srgb, var(--ls-pd-accent) 10%, transparent); }
  .ls-pdp__combo-opt[aria-selected="true"] { background: color-mix(in srgb, var(--ls-pd-accent) 14%, transparent); }

  .ls-pdp__combo-swatch {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    flex-shrink: 0;
    border: 1px solid var(--ls-pd-border);
    background-color: var(--ls-pd-tile-bg);
    background-size: cover;
    background-position: center;
  }

  .ls-pdp__combo-opttext { display: flex; flex-direction: column; min-width: 0; line-height: 1.2; }
  .ls-pdp__combo-optname { font-weight: 600; color: var(--ls-pd-heading); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .ls-pdp__combo-optcode { font-size: 0.75rem; color: var(--ls-pd-muted); }

  .ls-pdp__combo-empty,
  .ls-pdp__combo-note { padding: 0.7rem 0.6rem; color: var(--ls-pd-muted); font-size: 0.8125rem; }
  .ls-pdp__combo-empty[hidden] { display: none; }

  .ls-pdp__color-disclaimer {
    display: flex;
    align-items: flex-start;
    gap: 0.4rem;
    margin: 0.5rem 0 0;
    color: var(--ls-pd-muted);
    font-size: 0.75rem;
    line-height: 1.35;
  }
  .ls-pdp__color-disclaimer-icon { flex: 0 0 auto; width: 0.9375rem; height: 0.9375rem; margin-top: 0.05rem; }

  /* Footer sits below the scrolling list, so nothing scrolls under it. */
  .ls-pdp__combo-foot {
    padding: 0.6rem;
    border-top: 1px solid var(--ls-pd-border);
    background: var(--ls-pd-surface);
    color: var(--ls-pd-muted);
    font-size: 0.8125rem;
    font-style: italic;
  }
  .ls-pdp__combo-foot[hidden] { display: none; }

  /* ---------- Custom color / property fields ---------- */
  .ls-pdp__custom-field {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex: 2 1 0;
    min-width: 0;
    border: 1.5px solid var(--ls-pd-border);
    border-radius: 12px;
    padding: 0.55rem 0.8rem;
    background: var(--ls-pd-surface);
    transition: border-color 0.15s ease;
  }

  .ls-pdp__custom-field:focus-within { border-color: var(--ls-pd-accent); }
  .ls-pdp__custom-icon { flex-shrink: 0; line-height: 0; color: var(--ls-pd-muted); }
  .ls-pdp__custom-icon svg { width: 14px; height: 14px; display: block; }

  .ls-pdp__custom-input {
    flex: 1 1 auto;
    min-width: 0;
    border: 0;
    background: transparent;
    color: var(--ls-pd-text);
    font: inherit;
    font-size: 0.875rem;
    padding: 0;
    outline: none;
  }

  .ls-pdp__custom-input::placeholder { color: var(--ls-pd-muted); }

  /* Desktop shows the custom-color field inline; the toggle link is mobile-only. */
  .ls-pdp__custom-toggle { display: none; }

  /* On narrow screens the combo goes full-width and the custom-color field
     collapses behind an "Enter custom color" link (revealed on tap). */
  @media screen and (max-width: 480px) {
    .ls-pdp__color-row { flex-wrap: wrap; }
    .ls-pdp__combo { flex-basis: 100%; }
    .ls-pdp__custom-toggle {
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
      flex-basis: 100%;
      background: none;
      border: 0;
      padding: 0.15rem 0;
      color: var(--ls-pd-accent);
      font: inherit;
      font-size: 0.85rem;
      font-weight: 600;
      cursor: pointer;
      text-decoration: underline;
      text-underline-offset: 2px;
    }
    .ls-pdp__custom-toggle-icon { font-size: 1rem; text-decoration: none; }
    .ls-pdp__custom-field { display: none; flex-basis: 100%; }
    .ls-pdp__color-row[data-custom-open] .ls-pdp__custom-toggle { display: none; }
    .ls-pdp__color-row[data-custom-open] .ls-pdp__custom-field { display: flex; }

    /* Keep the three size cards on one row on phones. */
    .ls-pdp__size-cards { grid-template-columns: repeat(auto-fit, minmax(92px, 1fr)); gap: 0.45rem; }
    .ls-pdp__size-card { padding: 0.7rem 0.6rem; }

    /* Add-to-cart: trim padding + qty width so the label fits on one line. */
    .ls-pdp__atc { padding: 0 0.75rem; gap: 0.35rem; }
    .ls-pdp__atc svg { width: 17px; height: 17px; }
    .ls-pdp__qty-btn { width: 2rem; }
    .ls-pdp__qty-input { width: 1.8rem; }

    /* Centre the secure-checkout note + its lock icon. */
    .ls-pdp__secure { justify-content: center; text-align: center; }
  }

  .ls-pdp__prop-field { margin-top: 0.6rem; }
  .ls-pdp__prop-field[hidden] { display: none; }
  .ls-pdp__prop-field .ls-pdp__selector-label { display: block; margin-bottom: 0.4rem; }

  .ls-pdp__textarea {
    width: 100%;
    border: 1.5px solid var(--ls-pd-border);
    border-radius: 10px;
    background: var(--ls-pd-surface);
    color: var(--ls-pd-text);
    font: inherit;
    font-size: 0.875rem;
    padding: 0.6rem 0.8rem;
    resize: vertical;
  }

  .ls-pdp__textarea:focus { outline: none; border-color: var(--ls-pd-accent); }

  /* ---------- Size cards ---------- */
  .ls-pdp__size-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(110px, 1fr));
    gap: 0.6rem;
  }

  .ls-pdp__size-card {
    position: relative;
    /* Container so the text below can scale to the card's width (cqi units). */
    container-type: inline-size;
    appearance: none;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    text-align: left;
    border: 1.5px solid var(--ls-pd-border);
    background: var(--ls-pd-surface);
    color: var(--ls-pd-text);
    font: inherit;
    padding: 0.85rem 0.9rem;
    border-radius: 12px;
    cursor: pointer;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }

  .ls-pdp__size-card:hover { border-color: var(--ls-pd-heading); }
  .ls-pdp__size-card.is-active {
    border-color: var(--ls-pd-accent);
    box-shadow: inset 0 0 0 1px var(--ls-pd-accent);
    background: #fcf2f0;
  }
  .ls-pdp__size-card.is-active .ls-pdp__size-price { color: #d24f46; }

  .ls-pdp__size-flag {
    position: absolute;
    top: -0.6rem;
    left: 50%;
    transform: translateX(-50%);
    background: var(--ls-pd-heading);
    color: #fff;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    white-space: nowrap;
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
  }

  /* Text scales with the card width (cqi) and is capped, so long prices like
     "$419.01 $492.95" stay on one line inside the pill on any screen. */
  .ls-pdp__size-name { font-size: clamp(0.72rem, 11cqi, 0.85rem); font-weight: 600; color: var(--ls-pd-heading); }
  .ls-pdp__size-pricing { display: flex; align-items: baseline; gap: 0.25rem; flex-wrap: nowrap; white-space: nowrap; }
  .ls-pdp__size-price { font-size: clamp(0.72rem, 12.5cqi, 1.0625rem); font-weight: 700; color: var(--ls-pd-heading); }
  .ls-pdp__size-compare { font-size: clamp(0.55rem, 8cqi, 0.72rem); color: var(--ls-pd-muted); text-decoration: line-through; }
  .ls-pdp__size-unit { font-size: clamp(0.68rem, 10cqi, 0.875rem); color: var(--ls-pd-success); font-weight: 700; }

  /* ---------- Buy row ---------- */
  .ls-pdp__buy { display: flex; gap: 0.75rem; margin-top: 1.5rem; }

  .ls-pdp__qty {
    display: inline-flex;
    align-items: center;
    border: 1.5px solid var(--ls-pd-border);
    border-radius: 999px;
    overflow: hidden;
    flex-shrink: 0;
  }

  .ls-pdp__qty-btn {
    appearance: none;
    border: 0;
    background: transparent;
    color: var(--ls-pd-text);
    width: 2.6rem;
    height: 3rem;
    font-size: 1.1rem;
    cursor: pointer;
  }

  .ls-pdp__qty-btn:hover { color: var(--ls-pd-accent); }

  .ls-pdp__qty-input {
    width: 2.5rem;
    border: 0;
    background: transparent;
    text-align: center;
    font: inherit;
    font-weight: 600;
    color: var(--ls-pd-text);
    -moz-appearance: textfield;
  }

  .ls-pdp__qty-input::-webkit-outer-spin-button,
  .ls-pdp__qty-input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }

  .ls-pdp__atc {
    flex: 1 1 auto;
    min-width: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    border: 0;
    background: var(--ls-pd-accent);
    color: #fff;
    font: inherit;
    font-size: clamp(0.78rem, 2.8vw, 0.95rem);
    font-weight: 600;
    padding: 0 1.5rem;
    border-radius: 999px;
    cursor: pointer;
    white-space: nowrap;
    transition: background-color 0.15s ease, opacity 0.15s ease;
  }

  .ls-pdp__atc svg { width: 19px; height: 19px; }
  .ls-pdp__atc:hover:not(:disabled) { background: color-mix(in srgb, var(--ls-pd-accent) 88%, #000); }
  .ls-pdp__atc:disabled { opacity: 0.5; cursor: default; }

  .ls-pdp__dynamic { margin-top: 0.75rem; }
  .ls-pdp__dynamic .shopify-payment-button__button { border-radius: 999px; }
  /* Colour not chosen yet — block the dynamic checkout buttons. */
  .ls-pdp__dynamic--disabled { opacity: 0.5; pointer-events: none; filter: grayscale(0.3); }

  .ls-pdp__secure {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    margin: 0.9rem 0 0;
    font-size: 0.78rem;
    color: var(--ls-pd-muted);
  }

  .ls-pdp__secure svg { width: 17px; height: 17px; flex-shrink: 0; }

  /* ---------- Shop this color in (color-sample products) ---------- */
  .ls-pdp__shop-color { margin-top: 1.5rem; }
  .ls-pdp__shop-color-headrow {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.6rem;
  }
  .ls-pdp__shop-color-head {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--ls-pd-heading);
  }
  .ls-pdp__shop-color-nav { display: flex; gap: 0.4rem; }
  .ls-pdp__shop-color-nav[hidden] { display: none; }
  .ls-pdp__shop-color-arrow-btn {
    appearance: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 999px;
    border: 1px solid var(--ls-pd-border);
    background: var(--ls-pd-surface);
    color: var(--ls-pd-text);
    cursor: pointer;
    transition: color 0.15s ease, border-color 0.15s ease, opacity 0.15s ease;
  }
  .ls-pdp__shop-color-arrow-btn:hover:not(:disabled) { color: var(--ls-pd-accent); border-color: var(--ls-pd-accent); }
  .ls-pdp__shop-color-arrow-btn:disabled { opacity: 0.35; cursor: default; }
  .ls-pdp__shop-color-arrow-btn svg { width: 18px; height: 18px; }
  .ls-pdp__shop-color-list { display: flex; flex-direction: column; gap: 0.5rem; }
  .ls-pdp__shop-color-link[hidden] { display: none; }
  .ls-pdp__shop-color-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.85rem 1rem;
    border: 1.5px solid var(--ls-pd-border);
    border-radius: 14px;
    background: var(--ls-pd-surface);
    color: var(--ls-pd-text);
    text-decoration: none;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }
  .ls-pdp__shop-color-link:hover {
    border-color: var(--ls-pd-accent);
    box-shadow: 0 2px 4px rgba(20, 22, 26, 0.06), 0 6px 14px rgba(20, 22, 26, 0.07);
  }
  .ls-pdp__shop-color-name { font-weight: 500; flex: 1 1 auto; min-width: 0; }
  .ls-pdp__shop-color-price { font-weight: 600; color: var(--ls-pd-heading); white-space: nowrap; }
  .ls-pdp__shop-color-arrow { width: 18px; height: 18px; flex-shrink: 0; color: var(--ls-pd-muted); }
  .ls-pdp__shop-color-link:hover .ls-pdp__shop-color-arrow { color: var(--ls-pd-accent); }

  /* ---------- Frequently paired ---------- */
  .ls-pdp__paired { margin-top: 1.75rem; }
  .ls-pdp__paired[hidden] { display: none; }

  .ls-pdp__paired-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.9rem;
  }

  .ls-pdp__paired-title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0;
    font-size: 1.1875rem;
    font-weight: 700;
    color: var(--ls-pd-heading);
  }

  .ls-pdp__paired-count {
    display: inline-grid;
    place-items: center;
    min-width: 1.35rem;
    height: 1.35rem;
    padding: 0 0.4rem;
    border-radius: 999px;
    background: var(--ls-pd-accent);
    color: #fff;
    font-size: 0.8rem;
    font-weight: 700;
    line-height: 1;
  }
  .ls-pdp__paired-count[hidden] { display: none; }

  .ls-pdp__paired-nav { display: flex; align-items: center; gap: 0.5rem; }
  .ls-pdp__paired-nav[hidden] { display: none; }

  .ls-pdp__paired-arrow {
    appearance: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    padding: 0;
    border: 0;
    background: transparent;
    color: var(--ls-pd-heading);
    cursor: pointer;
    transition: color 0.15s ease, opacity 0.15s ease;
  }
  .ls-pdp__paired-arrow svg { width: 22px; height: 22px; }
  .ls-pdp__paired-arrow:hover { color: var(--ls-pd-accent); }
  .ls-pdp__paired-arrow:disabled { opacity: 0.3; cursor: default; color: var(--ls-pd-heading); }

  .ls-pdp__paired-track {
    display: flex;
    gap: 0.75rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    scroll-behavior: smooth;
  }
  .ls-pdp__paired-track::-webkit-scrollbar { display: none; }

  .ls-pdp__paired-skeleton {
    flex: 0 0 100%;
    height: 129px;
    border-radius: 20px;
    background: color-mix(in srgb, var(--ls-pd-accent) 5%, var(--ls-pd-surface));
    border: 1px solid color-mix(in srgb, var(--ls-pd-accent) 25%, var(--ls-pd-surface));
  }

  .ls-pdp__paired-card {
    flex: 0 0 100%;
    scroll-snap-align: start;
    display: flex;
    align-items: center;
    gap: 1.25rem;
    background: color-mix(in srgb, var(--ls-pd-accent) 5%, var(--ls-pd-surface));
    border: 1px solid var(--ls-pd-accent);
    border-radius: 20px;
    padding: 1.5rem;
    box-shadow: 0 2px 2px rgba(20, 22, 26, 0.04), 0 8px 12px rgba(20, 22, 26, 0.06);
  }

  .ls-pdp__paired-media { flex-shrink: 0; width: 6.375rem; height: 4.3rem; border-radius: 8px; overflow: hidden; }
  .ls-pdp__paired-img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .ls-pdp__paired-body { flex: 1 1 auto; min-width: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .ls-pdp__paired-name { display: block; font-size: 1.1875rem; font-weight: 700; line-height: 1.15; color: var(--ls-pd-accent); text-decoration: none; }
  .ls-pdp__paired-name:hover { text-decoration: underline; }
  .ls-pdp__paired-price { display: flex; gap: 0.4rem; font-size: 0.875rem; }
  .ls-pdp__paired-price s { color: var(--ls-pd-muted); }
  .ls-pdp__paired-form { flex-shrink: 0; margin: 0; }

  .ls-pdp__paired-add {
    appearance: none;
    border: 0;
    background: var(--ls-pd-accent);
    color: #fff;
    font: inherit;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    padding: 0.7rem 1rem;
    border-radius: 999px;
    cursor: pointer;
    white-space: nowrap;
    transition: filter 0.15s ease, opacity 0.15s ease;
  }

  .ls-pdp__paired-add:hover:not(:disabled) { filter: brightness(0.92); }
  .ls-pdp__paired-add:disabled { opacity: 0.5; cursor: default; }

  /* Compact the paired card on mobile so image · title · price · button
     sit comfortably on one row. */
  @media screen and (max-width: 749px) {
    .ls-pdp__paired-card { gap: 0.9rem; padding: 1.1rem 1.15rem; }
    .ls-pdp__paired-media { width: 5.25rem; height: 3.5rem; }
    .ls-pdp__paired-body { gap: 0.35rem; }
    .ls-pdp__paired-name { font-size: 1.0625rem; }
    .ls-pdp__paired-add { padding: 0.6rem 0.85rem; font-size: 0.72rem; }
    .ls-pdp__paired-skeleton { height: 96px; }
  }

  /* Narrow phones: the fixed media + non-shrinking add button can't fit on one
     row, which clips the button. Let the row wrap so the button drops to its own
     full-width line; the card keeps scaling to the viewport at flex 0 0 100%. */
  @media screen and (max-width: 560px) {
    .ls-pdp__paired-card { flex-wrap: wrap; row-gap: 0.9rem; }
    .ls-pdp__paired-body { flex: 1 1 auto; }
    .ls-pdp__paired-form { flex: 1 1 100%; width: 100%; }
    .ls-pdp__paired-add { width: 100%; }
  }

  /* ---------- Accordions ---------- */
  .ls-pdp__accordions { margin-top: 1.5rem; border-top: 1px solid var(--ls-pd-border); }
  .ls-pdp__accordion { border-bottom: 1px solid var(--ls-pd-border); }
  .ls-pdp__accordion:last-child { border-bottom: 0; }

  .ls-pdp__accordion-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 0;
    cursor: pointer;
    list-style: none;
    font-size: clamp(1.125rem, 1.6vw, 1.375rem);
    font-weight: 600;
    color: var(--ls-pd-heading);
  }

  .ls-pdp__accordion-summary::-webkit-details-marker { display: none; }

  .ls-pdp__accordion-icon { position: relative; width: 16px; height: 16px; flex-shrink: 0; }
  .ls-pdp__accordion-icon::before,
  .ls-pdp__accordion-icon::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: var(--ls-pd-text);
  }
  .ls-pdp__accordion-icon::before { width: 14px; height: 1.5px; }
  .ls-pdp__accordion-icon::after { width: 1.5px; height: 14px; transition: opacity 0.15s ease; }
  .ls-pdp__accordion[open] .ls-pdp__accordion-icon::after { opacity: 0; }

  .ls-pdp__accordion-body { padding: 0 0 1.1rem; font-size: 0.875rem; line-height: 1.55; color: var(--ls-pd-text); }
  .ls-pdp__accordion-body > *:first-child { margin-top: 0; }

  /* ---------- Desktop ---------- */
  @media screen and (min-width: 750px) {
    .ls-pdp__grid { grid-template-columns: minmax(0, 1fr) minmax(0, 1fr); gap: 3rem; align-items: start; }
    .ls-pdp__media-col {
      position: sticky;
      top: 1.5rem;
      background: #eeeeee;
      border-radius: var(--ls-pd-radius);
      padding: 1.5rem;
    }
    .ls-pdp__title { font-size: clamp(1.9rem, 2.4vw, 2.4rem); }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "LS Product Detail",
  "tag": "section",
  "class": "ls-pdp-section",
  "settings": [
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "font_picker",
      "id": "font_family",
      "label": "Font",
      "default": "outfit_n4"
    },
    {
      "type": "header",
      "content": "Header & rating"
    },
    {
      "type": "checkbox",
      "id": "show_breadcrumbs",
      "label": "Show breadcrumbs",
      "default": true
    },
    {
      "type": "text",
      "id": "ships_text",
      "label": "Ships note",
      "info": "Shown at the top of the product details with a truck icon. Leave blank to hide.",
      "default": "Ships nationwide"
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "label": "Show rating",
      "default": true
    },
    {
      "type": "select",
      "id": "rating_source",
      "label": "Rating source",
      "options": [
        { "value": "manual", "label": "Manual (settings below)" },
        { "value": "metafield", "label": "Product reviews metafield" }
      ],
      "default": "manual",
      "info": "Metafield reads reviews.rating and reviews.rating_count (Shopify Product Reviews / Judge.me shape)."
    },
    {
      "type": "range",
      "id": "manual_rating",
      "label": "Manual rating",
      "min": 0,
      "max": 5,
      "step": 0.5,
      "default": 4.5,
      "visible_if": "{{ section.settings.rating_source == 'manual' }}"
    },
    {
      "type": "text",
      "id": "manual_review_count",
      "label": "Manual review count",
      "default": "233",
      "visible_if": "{{ section.settings.rating_source == 'manual' }}"
    },
    {
      "type": "header",
      "content": "Price"
    },
    {
      "type": "checkbox",
      "id": "show_stock",
      "label": "Show stock status",
      "default": true
    },
    {
      "type": "text",
      "id": "in_stock_text",
      "label": "In stock text",
      "default": "In stock · ships in 1-2 business days"
    },
    {
      "type": "text",
      "id": "out_of_stock_text",
      "label": "Out of stock text",
      "default": "Currently unavailable"
    },
    {
      "type": "text",
      "id": "price_suffix",
      "label": "Price suffix",
      "info": "Only shown when the product has a gallon variant (e.g. 'Price per Gallon'). Hidden for products with no gallon size.",
      "default": "Price per Gallon"
    },
    {
      "type": "header",
      "content": "Variant selectors"
    },
    {
      "type": "text",
      "id": "size_option_name",
      "label": "Size option name",
      "info": "Variant option with this exact name renders as price cards.",
      "default": "Size"
    },
    {
      "type": "text",
      "id": "popular_size",
      "label": "\"Popular\" size",
      "info": "Size value that gets the pill (e.g. Gallon). A variant metafield custom.badge overrides this.",
      "default": "Gallon"
    },
    {
      "type": "text",
      "id": "popular_label",
      "label": "\"Popular\" pill text",
      "default": "Popular"
    },
    {
      "type": "text",
      "id": "best_value_size",
      "label": "\"Best value\" size",
      "info": "Size value that gets the pill (e.g. 5 Gallon).",
      "default": "5 Gallon"
    },
    {
      "type": "text",
      "id": "best_value_label",
      "label": "\"Best value\" pill text",
      "default": "Best value"
    },
    {
      "type": "text",
      "id": "color_option_name",
      "label": "Color option name to hide",
      "info": "If a product happens to have a variant option with this name, it is hidden here because color is captured as a line-item property below (not a variant).",
      "default": "Color"
    },
    {
      "type": "text",
      "id": "hidden_option_names",
