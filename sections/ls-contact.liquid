      "default": 60
    },
    {
      "type": "range",
      "id": "glow_size_y_mobile",
      "label": "Size (vertical, mobile)",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 60
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Card corner radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 20
