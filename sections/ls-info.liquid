{%- comment -%}
  LS Info
  -------
  A standalone info bar of icon + title + subtitle items (in-store pickup, free
  delivery, ships nationwide, …). Split out of LS Purpose so it can be placed on
  its own — e.g. under the collection grid or above the footer.

  Reuses the shared `ls-purpose-icon` snippet for the built-in icons.
{%- endcomment -%}

{%- liquid
  assign if_font = section.settings.font_family
  assign if_font_500 = if_font | font_modify: 'weight', '500'
  assign if_font_600 = if_font | font_modify: 'weight', '600'
  assign if_font_700 = if_font | font_modify: 'weight', '700'

  assign info_blocks = section.blocks | where: 'type', 'info'
-%}

{% style %}
  {{ if_font | font_face: font_display: 'swap' }}
  {{ if_font_500 | font_face: font_display: 'swap' }}
  {{ if_font_600 | font_face: font_display: 'swap' }}
  {{ if_font_700 | font_face: font_display: 'swap' }}

  .ls-info-{{ section.id }} {
    --ls-if-font-family: {{ if_font.family }}, {{ if_font.fallback_families }};
    --ls-if-eyebrow: {{ section.settings.eyebrow_color | default: '#c13121' }};
    --ls-if-heading: {{ section.settings.heading_color | default: '#1a1a1a' }};
    --ls-if-accent: {{ section.settings.accent_color | default: '#c13121' }};
    --ls-if-muted: {{ section.settings.muted_color | default: '#6b7280' }};
    --ls-if-border: {{ section.settings.border_color | default: '#e5e7eb' }};
    --ls-if-radius: {{ section.settings.corner_radius | default: 20 }}px;
  }
{% endstyle %}

{%- if section.settings.background_color != blank -%}
  <div class="section-background" style="background-color: {{ section.settings.background_color }};"></div>
{%- endif -%}
<div
  class="section ls-info ls-info-{{ section.id }} spacing-style"
  style="{% render 'spacing-style', settings: section.settings %}{% if section.settings.bar_background != blank %}--ls-if-bar-bg: {{ section.settings.bar_background }};{% endif %}"
>
  {%- if section.settings.eyebrow != blank or section.settings.heading != blank -%}
    <div class="ls-info__head">
      {%- if section.settings.eyebrow != blank -%}
        <p class="ls-info__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="ls-info__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- if info_blocks.size > 0 -%}
    <div class="ls-info__bar">
      {%- for block in info_blocks -%}
        <div class="ls-info__item" {{ block.shopify_attributes }}>
          <span class="ls-info__icon" aria-hidden="true">
            {%- if block.settings.custom_icon != blank -%}
              <img src="{{ block.settings.custom_icon | image_url: width: 80 }}" alt="" width="18" height="18" loading="lazy">
            {%- else -%}
              {%- render 'ls-purpose-icon', name: block.settings.icon -%}
            {%- endif -%}
          </span>
          <div class="ls-info__text">
            {%- if block.settings.title != blank -%}
              <span class="ls-info__title">{{ block.settings.title }}</span>
            {%- endif -%}
            {%- if block.settings.subtitle != blank -%}
              <span class="ls-info__subtitle">{{ block.settings.subtitle }}</span>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  {%- endif -%}
</div>

{% stylesheet %}
  .ls-info {
    font-family: var(--ls-if-font-family, 'Outfit', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif);
    color: var(--ls-if-heading);
  }

  .ls-info__head {
    margin-bottom: clamp(1rem, 2vw, 1.5rem);
  }

  .ls-info__eyebrow {
    margin: 0 0 0.4rem;
    color: var(--ls-if-eyebrow);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.01em;
  }

  .ls-info__heading {
    margin: 0;
    color: var(--ls-if-heading);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  /* ---------- Info bar ---------- */
  .ls-info__bar {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    background: var(--ls-if-bar-bg, transparent);
    border: 1px solid var(--ls-if-border);
    border-radius: var(--ls-if-radius, 20px);
    overflow: hidden;
  }

  .ls-info__item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: clamp(1rem, 1.6vw, 1.25rem) clamp(1rem, 1.8vw, 1.5rem);
    border-bottom: 1px solid var(--ls-if-border);
  }

  .ls-info__item:last-child {
    border-bottom: 0;
  }

  .ls-info__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 10px;
    flex-shrink: 0;
    background: color-mix(in srgb, var(--ls-if-accent) 10%, transparent);
    color: var(--ls-if-accent);
  }

  .ls-info__icon svg {
    width: 18px;
    height: 18px;
  }

  .ls-info__icon img {
    width: 18px;
    height: 18px;
    object-fit: contain;
  }

  .ls-info__text {
    display: flex;
    flex-direction: column;
    line-height: 1.3;
  }

  .ls-info__title {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--ls-if-heading);
  }

  .ls-info__subtitle {
    font-size: 0.8125rem;
    color: var(--ls-if-muted);
  }

  @media screen and (max-width: 749px) {
    /* Stacked, no dividers on mobile. */
    .ls-info__item {
      border-bottom: 0;
    }
  }

  @media screen and (min-width: 750px) {
    .ls-info__bar {
      grid-auto-flow: column;
      grid-auto-columns: 1fr;
    }

    .ls-info__item {
      border-bottom: 0;
      border-right: 1px solid var(--ls-if-border);
    }

    .ls-info__item:last-child {
      border-right: 0;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "LS Info",
  "tag": "section",
  "class": "ls-info-section",
  "settings": [
    {
      "type": "header",
      "content": "Heading (optional)"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "font_picker",
      "id": "font_family",
      "label": "Font",
      "default": "outfit_n4"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section background"
    },
    {
      "type": "color",
      "id": "bar_background",
      "label": "Bar background",
      "info": "Leave blank for a transparent bar."
    },
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Eyebrow",
      "default": "#c13121"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Title text",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Icon accent",
      "default": "#c13121"
    },
    {
      "type": "color",
      "id": "muted_color",
      "label": "Subtitle text",
      "default": "#6b7280"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Bar border / dividers",
      "default": "#e5e7eb"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "corner_radius",
      "label": "Corner radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "info",
      "name": "Info item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "location", "label": "Map pin" },
            { "value": "truck", "label": "Truck" },
            { "value": "guarantee", "label": "Shield" },
            { "value": "brush", "label": "Brush" },
            { "value": "color", "label": "Color / tint" }
          ],
          "default": "location"
        },
        {
          "type": "image_picker",
          "id": "custom_icon",
          "label": "Custom icon",
          "info": "Optional. Overrides the icon above."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "In-store pickup"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "Ready at the counter"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "LS Info",
      "category": "t:categories.banners",
      "blocks": [
        {
          "type": "info",
          "settings": {
            "icon": "location",
            "title": "In-store pickup",
            "subtitle": "Ready at the counter"
          }
        },
        {
          "type": "info",
          "settings": {
            "icon": "truck",
            "title": "Free curbside",
            "subtitle": "Call ahead, we load it"
          }
        },
        {
          "type": "info",
          "settings": {
            "icon": "truck",
            "title": "Free local delivery",
            "subtitle": "On 48-gal qualifying orders"
          }
        },
        {
          "type": "info",
          "settings": {
            "icon": "guarantee",
            "title": "Ships nationwide",
            "subtitle": "Securely packed & tracked"
          }
        }
      ]
    }
  ]
}
{% endschema %}
